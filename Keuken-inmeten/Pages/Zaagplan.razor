@page "/zaagplan"
@inject KeukenStateService State

<PageTitle>Stap 5 — Zaagplan</PageTitle>

<StapIndicator HuidigeStap="zaagplan" />

<section class="stap-pagina-kop mb-4">
    <div class="stap-pagina-kop__top">
        <div class="stap-pagina-kop__intro">
            <h2 class="page-header">Stap 5: Zaagplan</h2>
            <p class="stap-pagina-kop__lead">Kies plaatmaat en controleer daarna de indeling. Open geavanceerde instellingen alleen als panelen niet passen of de materiaalrichting daarom vraagt.</p>
        </div>
        <div class="stap-ondersteuning stap-pagina-kop__acties" data-testid="zaagplan-stap-ondersteuning">
            <StapHulpDrawer StapId="zaagplan" KnopLabel="Hulp bij stap" />
            <TerminologieUitleg Compact="true"
                                CompactLabel="Leg termen uit"
                                Sleutels="zaagbreedte"
                                Beschrijving="Deze woordenlijst licht de zaagterm op deze pagina in gewone taal toe." />
        </div>
    </div>
</section>

@{
    var pagina = MaakPaginaModel();
}

@if (pagina.RouteGate is not null)
{
    <StapRouteMelding Gate="@pagina.RouteGate" />
}
else if (pagina.Items.Count == 0)
{
    <div class="alert alert-warning">
        Er is nog geen zaagplan beschikbaar. Controleer eerst of er panelen klaarstaan in de bestellijst.
    </div>
}
else
{
    var resultaat = pagina.Resultaat!;

    <div class="zaagplan-toolbar card border-0 shadow-sm mb-4">
        <div class="card-body d-flex flex-column gap-3">
            <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-start gap-3">
                <div>
                    <div class="small fw-semibold text-uppercase text-primary-emphasis">Plaatinstellingen</div>
                    <div class="fw-semibold">Start met plaatmaat en controleer daarna de indeling</div>
                    <div class="small text-muted">Pas zaagverlies of draaien alleen aan als panelen niet passen of een vaste materiaalrichting dat vereist.</div>
                </div>
                <div class="zaagplan-kerncijfers">
                    <div class="zaagplan-kerncijfer">
                        <span class="zaagplan-kerncijfer-label">Platen in gebruik</span>
                        <strong>@resultaat.Platen.Count</strong>
                    </div>
                    <div class="zaagplan-kerncijfer">
                        <span class="zaagplan-kerncijfer-label">Panelen geplaatst</span>
                        <strong>@pagina.TotaalGeplaatst / @pagina.TotaalPanelen</strong>
                    </div>
                </div>
            </div>

            <div class="row g-3 align-items-end">
                <div class="col-sm-6 col-xl-3">
                    <label class="form-label fw-semibold">Plaatbreedte (mm)</label>
                    <input class="form-control" type="number" step="1" min="100"
                           data-testid="zaagplan-plaatbreedte-input"
                           @bind="_plaatBreedte" @bind:event="oninput" inputmode="decimal" />
                </div>
                <div class="col-sm-6 col-xl-3">
                    <label class="form-label fw-semibold">Plaathoogte (mm)</label>
                    <input class="form-control" type="number" step="1" min="100"
                           data-testid="zaagplan-plaathoogte-input"
                           @bind="_plaatHoogte" @bind:event="oninput" inputmode="decimal" />
                </div>
                <div class="col-xl-6">
                    <div class="fw-semibold mb-2">Weergave</div>
                    <div class="zaagplan-weergave-toggle" data-testid="zaagplan-weergave-toggle">
                        <button type="button"
                                class="btn @(_weergave is ZaagplanWeergave.AllePlaten ? "btn-primary" : "btn-outline-secondary")"
                                @onclick="ToonAllePlaten"
                                data-testid="zaagplan-alle-platen-button">
                            Alle platen
                        </button>
                        <button type="button"
                                class="btn @(pagina.IsPlaatFocus ? "btn-primary" : "btn-outline-secondary")"
                                @onclick="@(() => ToonEenPlaat(resultaat.Platen.Count))"
                                disabled="@(!pagina.KanPlaatFocus)"
                                data-testid="zaagplan-een-plaat-button">
                            Eén plaat tegelijk
                        </button>
                    </div>
                    <div class="form-text hulp-hint">Gebruik <strong>Eén plaat tegelijk</strong> om de indeling plaat voor plaat te controleren.</div>
                </div>
            </div>

            <details class="zaagplan-geavanceerd" data-testid="zaagplan-geavanceerde-instellingen">
                <summary>Geavanceerd · zaagverlies @FormatMm(_zaagbreedte) mm · draaien @(_draaiToe ? "aan" : "uit")</summary>
                <div class="row g-3 mt-2">
                    <div class="col-lg-6">
                        <div class="border rounded p-3 h-100 bg-body-tertiary">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <label class="form-label fw-semibold mb-0">Zaagverlies per snede (zaagbreedte, mm)</label>
                                <HulpInfoKnop Titel="Zaagverlies per snede"
                                              Tekst="Elke zaagsnede kost materiaal doordat het zaagblad een bepaalde breedte heeft. Dat verlies telt mee tussen twee panelen."
                                              Voorbeeld="Een veelgebruikte startwaarde is 4 mm."
                                              WatNuDoen="Gebruik de waarde van het zaagblad of de zaagstraat die u werkelijk inzet." />
                            </div>
                            <input class="form-control" type="number" step="0.5" min="0" max="20"
                                   data-testid="zaagplan-zaagbreedte-input"
                                   @bind="_zaagbreedte" @bind:event="oninput" inputmode="decimal" />
                            <div class="form-text hulp-hint mb-0">Dit is de breedte van het zaagblad die als verlies meetelt tussen twee panelen.</div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="border rounded p-3 h-100 bg-body-tertiary">
                            <div class="d-flex align-items-start gap-2">
                                <label class="form-label mb-0">
                                    <input type="checkbox" class="form-check-input me-1" @bind="_draaiToe" />
                                    Draaien toestaan
                                </label>
                                <HulpInfoKnop Titel="Panelen draaien toestaan"
                                              Tekst="Als draaien mag, probeert het zaagplan panelen ook 90 graden gedraaid te plaatsen om beter op de plaat te passen."
                                              Voorbeeld="Laat dit aan als richting, nerf of zichtzijde niet vastligt."
                                              WatNuDoen="Zet dit uit als het materiaal of de zichtzijde maar in één richting verwerkt mag worden." />
                            </div>
                            <div class="form-text hulp-hint mb-0">Gebruik dit alleen als materiaalrichting of zichtzijde geen vaste oriëntatie afdwingt.</div>
                        </div>
                    </div>
                </div>
            </details>
        </div>
    </div>

    if (resultaat.NietGeplaatst.Count > 0)
    {
        <section class="zaagplan-waarschuwing card border-warning-subtle shadow-sm mb-4"
                 data-testid="zaagplan-niet-geplaatst-waarschuwing">
            <div class="card-body d-grid gap-3">
                <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-start gap-3">
                    <div>
                        <div class="zaagplan-waarschuwing-kicker">Actie nodig</div>
                        <h5 class="mb-1">@pagina.NietGeplaatstAantal paneel(en) passen nog niet op deze plaat</h5>
                        <p class="text-muted mb-0">Begin met een grotere plaat. Zet draaien alleen aan als het materiaal of de zichtzijde dat toelaat.</p>
                    </div>
                    @if (pagina.GrootsteNietGeplaatst is not null)
                    {
                        <div class="zaagplan-waarschuwing-kern">
                            <div class="zaagplan-waarschuwing-kicker text-muted">Grootste ontbrekende paneel</div>
                            <div class="fw-semibold">@pagina.GrootsteNietGeplaatst.Naam</div>
                            <div class="small text-muted">@FormatMm(pagina.GrootsteNietGeplaatst.Breedte) × @FormatMm(pagina.GrootsteNietGeplaatst.Hoogte) mm</div>
                            <div class="small text-muted">Minimale plaat nu: @FormatMm(pagina.MinimalePlaatLangeZijde) × @FormatMm(pagina.MinimalePlaatKorteZijde) mm.</div>
                        </div>
                    }
                </div>

                <div class="zaagplan-waarschuwing-strip">
                    <span>Minimale plaat: @FormatMm(pagina.MinimalePlaatLangeZijde) × @FormatMm(pagina.MinimalePlaatKorteZijde) mm</span>
                    <span>@pagina.NietGeplaatstAantal paneel(en) nog niet geplaatst</span>
                    @if (pagina.RotatieKanHelpen)
                    {
                        <span>Draaien kan minstens één paneel laten passen</span>
                    }
                </div>

                <div class="zaagplan-waarschuwing-acties">
                    <section class="zaagplan-waarschuwing-actie zaagplan-waarschuwing-actie--aanbevolen">
                        <div class="zaagplan-waarschuwing-actie-label">Aanbevolen</div>
                        <div class="fw-semibold">Kies een grotere plaat</div>
                        <div class="small text-muted">Vergroot vooral de langste zijde tot minstens @FormatMm(pagina.MinimalePlaatLangeZijde) × @FormatMm(pagina.MinimalePlaatKorteZijde) mm.</div>
                    </section>

                    @if (pagina.RotatieKanHelpen)
                    {
                        <section class="zaagplan-waarschuwing-actie">
                            <div class="zaagplan-waarschuwing-actie-label">Alternatief</div>
                            <div class="fw-semibold">Zet draaien aan als dat technisch mag</div>
                            <div class="small text-muted">Minstens één ontbrekend paneel past zodra de plaat 90 graden gedraaid gebruikt mag worden.</div>
                            <button type="button"
                                    class="btn btn-outline-primary btn-sm mt-2"
                                    @onclick="SchakelDraaienIn"
                                    data-testid="zaagplan-draaien-aanzetten">
                                Zet draaien aan
                            </button>
                        </section>
                    }

                    <section class="zaagplan-waarschuwing-actie">
                        <div class="zaagplan-waarschuwing-actie-label">Controle</div>
                        <div class="fw-semibold">Terug naar bestellijst</div>
                        <div class="small text-muted">Ga terug als een paneel bewust uit een andere plaatsoort moet komen of eerst gesplitst moet worden.</div>
                        <a href="bestellijst" class="btn btn-outline-secondary btn-sm mt-2">Terug naar bestellijst</a>
                    </section>
                </div>

                <details class="zaagplan-waarschuwing-details">
                    <summary>Betrokken panelen</summary>
                    <ul class="zaagplan-waarschuwing-lijst mb-0 mt-3">
                        @foreach (var p in resultaat.NietGeplaatst)
                        {
                            <li>@p.Naam — @FormatMm(p.Breedte) × @FormatMm(p.Hoogte) mm (@p.Aantal×)</li>
                        }
                    </ul>
                </details>
            </div>
        </section>
    }

    @if (resultaat.Platen.Count == 0)
    {
        <div class="card border-0 bg-body-tertiary">
            <div class="card-body py-4">
                <h5 class="mb-1">Nog geen plaatindeling beschikbaar</h5>
                <p class="text-muted mb-0">Pas het plaatformaat of de geavanceerde instellingen aan totdat minstens één paneel geplaatst kan worden.</p>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-3">
            <div>
                <h5 class="mb-1">Plaatindeling</h5>
                <p class="text-muted mb-0">
                    @(pagina.IsPlaatFocus
                        ? "U bekijkt nu één plaat tegelijk. Gebruik de pijlen om de indeling plaat voor plaat na te lopen."
                        : "Vergelijk alle platen tegelijk of schakel over naar de weergave per plaat als u de indeling rustiger wilt beoordelen.")
                </p>
            </div>
            <div class="small text-muted text-lg-end">
                <div class="fw-semibold text-uppercase">Actief</div>
                <div>@(pagina.IsPlaatFocus ? FormatPlaatTeller(pagina.ActievePlaatIndex, resultaat.Platen.Count) : $"{resultaat.Platen.Count} platen in beeld")</div>
            </div>
        </div>

        @if (pagina.IsPlaatFocus && pagina.ActievePlaat is not null)
        {
            <div class="zaagplan-focus-toolbar card border-0 shadow-sm mb-3" data-testid="zaagplan-focus-toolbar">
                <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <div>
                        <div class="small fw-semibold text-uppercase text-muted mb-1">Één plaat tegelijk</div>
                        <h6 class="mb-1">Plaat @pagina.ActievePlaat.Nummer</h6>
                        <div class="small text-muted">@pagina.ActievePlaat.Plaatsingen.Count paneel(en) op deze plaat</div>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                @onclick="VorigePlaat"
                                disabled="@(pagina.ActievePlaatIndex == 0)"
                                data-testid="zaagplan-vorige-plaat">
                            Vorige plaat
                        </button>
                        <button type="button"
                                class="btn btn-primary"
                                @onclick="@(() => VolgendePlaat(resultaat.Platen.Count))"
                                disabled="@(pagina.ActievePlaatIndex >= resultaat.Platen.Count - 1)"
                                data-testid="zaagplan-volgende-plaat">
                            Volgende plaat
                        </button>
                    </div>
                </div>
            </div>
        }

        <div class="zaagplan-platen @(pagina.IsPlaatFocus ? "zaagplan-platen--focus" : null)"
             data-testid="@(pagina.IsPlaatFocus ? "zaagplan-een-plaat-weergave" : "zaagplan-alle-platen-weergave")">
            @foreach (var plaat in pagina.PlatenVoorWeergave)
            {
                <div class="zaagplan-plaat-card @(pagina.IsPlaatFocus ? "zaagplan-plaat-card--focus" : null) card border-0 shadow-sm mb-4"
                     data-testid="zaagplan-plaat-card"
                     data-plaat-nummer="@plaat.Nummer">
                    <div class="card-body text-center">
                        <ZaagplanVisueel Plaat="plaat" />
                        <div class="zaagplan-plaat-meta mt-2 small text-muted">
                            @plaat.Plaatsingen.Count paneel(en) op deze plaat
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

<StapNavigatie HuidigeStap="zaagplan"
               VorigeHref="bestellijst" />
