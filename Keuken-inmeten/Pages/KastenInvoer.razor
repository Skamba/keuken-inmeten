@page "/kasten"
@inject KeukenStateService State
@inject ActieFeedbackService Feedback
@implements IDisposable

<PageTitle>Stap 1 — Indeling</PageTitle>

<StapIndicator HuidigeStap="kasten" />

<div class="d-flex justify-content-between align-items-center mb-2">
    <h2 class="page-header mb-0">Stap 1: Indeling</h2>
    @if (State.Kasten.Count > 0)
    {
        @if (bevestigVerwijderAlleKasten)
        {
            <div class="d-flex align-items-center gap-2">
                <span class="text-danger small fw-semibold">Alle @State.Kasten.Count kast(en) verwijderen?</span>
                <button class="btn btn-sm btn-danger" @onclick="VerwijderAlleKasten">Ja, verwijder alles</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => bevestigVerwijderAlleKasten = false">Annuleren</button>
            </div>
        }
        else
        {
            <button class="btn btn-sm btn-outline-danger" @onclick="() => bevestigVerwijderAlleKasten = true">
                Verwijder alle kasten
            </button>
        }
    }
</div>
<p class="text-muted">Maak wandindelingen aan en plaats kasten naast elkaar om uw keuken na te bouwen.</p>
<div class="hulp-toolbar mb-3">
    <StapHulpDrawer StapId="kasten" />
</div>

<TerminologieUitleg Sleutels="plinthoogte,wanddikte,gaatjesrij,eerstegat"
                    Beschrijving="Deze woordenlijst helpt bij de technische maten die u in stap 1 invult." />

@* ──── Wand toevoegen ──── *@
<div class="card mb-4">
    <div class="card-body d-flex align-items-end gap-3">
        <div class="flex-grow-1">
            <label class="form-label fw-semibold">Nieuwe wand</label>
            <input type="text" class="form-control" @bind="nieuweWandNaam" @bind:event="oninput"
                   placeholder="bv. Linkerwand, Achterwand, Rechts bij raam" @onkeydown="WandToevoegenBijEnter"
                   data-testid="nieuwe-wand-naam-input" />
        </div>
        <button class="btn btn-primary" @onclick="WandToevoegen"
                disabled="@string.IsNullOrWhiteSpace(nieuweWandNaam)"
                data-testid="wand-toevoegen-button">
            Wand toevoegen
        </button>
    </div>
</div>

@if (State.Wanden.Count == 0)
{
    <div class="alert alert-info">
        Begin door een wand toe te voegen. Elke wand stelt een rij kasten voor die naast elkaar staan.
    </div>
}
else
{
    var actieveWand = State.Wanden.Find(wand => wand.Id == actieveWandId);

    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
        <div>
            <h5 class="mb-1">Wandenoverzicht</h5>
            <p class="text-muted mb-0">Bekijk eerst rustige samenvattingskaarten per wand. Open daarna precies één wand om maten, objecten en de visualisatie te bewerken.</p>
        </div>
        <div class="small text-muted">
            <div class="fw-semibold text-uppercase">Werkmodus</div>
            <div>@(actieveWand is null ? "Nog geen wand geopend" : $"{actieveWand.Naam} is nu actief")</div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        @foreach (var wand in State.Wanden)
        {
            var wandKasten = State.KastenVoorWand(wand.Id);
            var wandApparaten = State.ApparatenVoorWand(wand.Id);
            var gevuldeBreedte = wand.TotaleBreedte(State.Kasten);
            var vrijeBreedte = Math.Max(0, wand.Breedte - gevuldeBreedte);
            var isActieveWerkruimte = actieveWandId == wand.Id;

            <div class="col-xl-6"
                 @key="wand.Id">
                <div class="card h-100 indeling-wand-samenvatting @(isActieveWerkruimte ? "actief" : "")"
                     data-testid="indeling-wand-card"
                     data-wand-id="@wand.Id"
                     data-wand-naam="@wand.Naam">
                    <div class="card-body d-flex flex-column gap-3">
                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                            <div>
                                <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                    <h5 class="mb-0">@wand.Naam</h5>
                                    @if (isActieveWerkruimte)
                                    {
                                        <span class="badge text-bg-primary">Nu open</span>
                                    }
                                </div>
                                <div class="small text-muted">
                                    @gevuldeBreedte mm ingevuld · @vrijeBreedte mm vrije wandruimte
                                </div>
                            </div>
                            <div class="small text-muted text-lg-end">
                                <div class="fw-semibold text-uppercase">Status</div>
                                <div>@(isActieveWerkruimte ? "Nu actief" : wandKasten.Count == 0 ? "Startklaar" : "Samengevat")</div>
                            </div>
                        </div>

                        <div class="row g-2">
                            <div class="col-sm-4">
                                <div class="indeling-wand-metric">
                                    <div class="small text-muted">Kasten</div>
                                    <div class="fw-semibold">@wandKasten.Count</div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="indeling-wand-metric">
                                    <div class="small text-muted">Apparaten</div>
                                    <div class="fw-semibold">@wandApparaten.Count</div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="indeling-wand-metric">
                                    <div class="small text-muted">Breedte</div>
                                    <div class="fw-semibold">@wand.Breedte mm</div>
                                </div>
                            </div>
                        </div>

                        <div class="small text-muted">
                            <div class="fw-semibold text-uppercase mb-1">Volgende stap</div>
                            <div>
                                @(wandKasten.Count == 0
                                    ? "Open deze wand om uw eerste kast toe te voegen en de basismaat in te voeren."
                                    : "Open deze wand om maten, objecten en de wandopstelling op één plek te controleren.")
                            </div>
                        </div>

                        <div class="mt-auto">
                            <button class="btn btn-primary"
                                    @onclick="() => OpenWandWerkruimte(wand.Id)"
                                    disabled="@isActieveWerkruimte"
                                    data-testid="open-wand-workspace-button"
                                    data-wand-id="@wand.Id">
                                @(isActieveWerkruimte ? "Werkruimte geopend" : "Open wand")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (actieveWand is null)
    {
        <div class="card mb-4 border-0 bg-body-tertiary indeling-wand-leeg">
            <div class="card-body py-4">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                    <div>
                        <h5 class="mb-1">Kies één wand om aan te werken</h5>
                        <p class="text-muted mb-0">De kaarten hierboven geven alleen de hoofdlijnen. Open een wand zodra u maten wilt aanpassen, objecten wilt beheren of de visualisatie wilt controleren.</p>
                    </div>
                    <span class="badge text-bg-light indeling-workspace-hint">@State.Wanden.Count wand(en) klaar om te openen</span>
                </div>
            </div>
        </div>
    }
    else
    {
        var wandKasten = State.KastenVoorWand(actieveWand.Id);
        var wandApparaten = State.ApparatenVoorWand(actieveWand.Id);
        var gevuldeBreedte = actieveWand.TotaleBreedte(State.Kasten);
        var vrijeBreedte = Math.Max(0, actieveWand.Breedte - gevuldeBreedte);
        var toonPrimaireActies = !toonKastFormulier && !toonApparaatFormulier;

        <div class="card mb-4 border-primary shadow-sm indeling-actieve-werkruimte"
             data-testid="actieve-wand-werkruimte"
             data-wand-id="@actieveWand.Id"
             data-wand-naam="@actieveWand.Naam">
            <div class="card-header bg-primary bg-opacity-10">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                    <div>
                        <div class="small fw-semibold text-uppercase text-primary-emphasis">Actieve wand</div>
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                            <h5 class="mb-0">@actieveWand.Naam</h5>
                            <span class="badge text-bg-light">@wandKasten.Count kast(en)</span>
                            @if (wandApparaten.Count > 0)
                            {
                                <span class="badge text-bg-light">@wandApparaten.Count apparaat(en)</span>
                            }
                        </div>
                        <div class="small text-muted">
                            @gevuldeBreedte mm ingevuld · @vrijeBreedte mm vrije wandruimte
                        </div>
                    </div>
                    <div class="d-flex flex-column align-items-start align-items-sm-end gap-2">
                        <div class="small text-muted text-sm-end">
                            <div class="fw-semibold text-uppercase">Werklaag</div>
                            <div>Maten, objecten en visualisatie staan nu alleen voor deze wand open.</div>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="SluitWandWerkruimte">
                            Werkruimte sluiten
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body">
                @if (toonPrimaireActies)
                {
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4 pb-3 border-bottom">
                        <div>
                            <h6 class="mb-1">Werk nu alleen op deze wand</h6>
                            <p class="text-muted small mb-0"><strong>+ Kast toevoegen</strong> blijft de hoofdactie. Voeg alleen een apparaat toe als het echt ruimte op deze wand inneemt.</p>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-primary"
                                    @onclick="() => OpenKastFormulier(actieveWand.Id)"
                                    data-testid="open-kast-form-button"
                                    data-wand-id="@actieveWand.Id">
                                + Kast toevoegen
                            </button>
                            <button class="btn btn-outline-secondary"
                                    @onclick="() => OpenApparaatFormulier(actieveWand.Id)"
                                    data-testid="open-apparaat-form-button"
                                    data-wand-id="@actieveWand.Id">
                                + Apparaat toevoegen
                            </button>
                        </div>
                    </div>
                }

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">Afmetingen van deze wand</h6>
                        <span class="text-muted small">Context voor de opstelling</span>
                    </div>
                    <div class="row g-3">
                        <div class="col-sm-4">
                            <label class="form-label small mb-0">Wandbreedte (mm)</label>
                            <input type="number" class="form-control form-control-sm"
                                   value="@actieveWand.Breedte" @onchange="e => WijzigWandAfmeting(actieveWand, nameof(KeukenWand.Breedte), e)" />
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label small mb-0">Wandhoogte (mm)</label>
                            <input type="number" class="form-control form-control-sm"
                                   value="@actieveWand.Hoogte" @onchange="e => WijzigWandAfmeting(actieveWand, nameof(KeukenWand.Hoogte), e)" />
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label small mb-0">Hoogte van de plint (mm)</label>
                            <input type="number" class="form-control form-control-sm" min="0" step="10"
                                   value="@actieveWand.PlintHoogte" @onchange="e => WijzigWandAfmeting(actieveWand, nameof(KeukenWand.PlintHoogte), e)" />
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">Kasten op deze wand</h6>
                        <span class="text-muted small">@(wandKasten.Count == 0 ? "Nog geen kasten" : $"{wandKasten.Count} toegevoegd")</span>
                    </div>
                    @if (wandKasten.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var kast in wandKasten)
                            {
                                <div class="d-flex align-items-center gap-1 border rounded px-2 py-1 small @(bewerkKastId == kast.Id && actieveWandId == actieveWand.Id ? "border-primary bg-primary bg-opacity-10" : "")">
                                    <span class="badge @TypeBadge(kast.Type)">@kast.Type</span>
                                    <span class="fw-semibold">@kast.Naam</span>
                                    <span class="text-muted">@kast.Breedte×@kast.Hoogte</span>
                                    <button class="btn btn-outline-primary btn-sm px-1 ms-1" style="font-size: 0.75rem; line-height: 1.2;"
                                            @onclick="() => BewerkKast(kast, actieveWand.Id)" title="Kast bewerken">✎</button>
                                    <button class="btn btn-outline-secondary btn-sm px-1" style="font-size: 0.75rem; line-height: 1.2;"
                                            @onclick="() => KopieerKast(kast, actieveWand.Id)" title="Kast kopiëren">⧉</button>
                                    @if (bevestigVerwijderKastId == kast.Id)
                                    {
                                        <span class="text-danger small ms-1 fw-semibold">Verwijderen?</span>
                                        <button class="btn btn-danger btn-sm px-1" style="font-size: 0.75rem; line-height: 1.2;"
                                                @onclick="() => { VerwijderKast(kast.Id); bevestigVerwijderKastId = null; }" title="Bevestig verwijderen">Ja</button>
                                        <button class="btn btn-outline-secondary btn-sm px-1" style="font-size: 0.75rem; line-height: 1.2;"
                                                @onclick="() => bevestigVerwijderKastId = null" title="Annuleren">Nee</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-danger btn-sm px-1" style="font-size: 0.75rem; line-height: 1.2;"
                                                @onclick="() => bevestigVerwijderKastId = kast.Id" title="Kast verwijderen">×</button>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="border rounded p-3 small text-muted bg-body-tertiary">
                            Begin met <strong>+ Kast toevoegen</strong> om deze wand op te bouwen.
                        </div>
                    }
                </div>

                @if (wandApparaten.Count > 0)
                {
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0">Apparaten op deze wand</h6>
                            <span class="text-muted small">@wandApparaten.Count toegevoegd</span>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var apparaat in wandApparaten)
                            {
                                <div class="d-flex align-items-center gap-1 border rounded px-2 py-1 small @(bewerkApparaatId == apparaat.Id && actieveWandId == actieveWand.Id ? "border-danger bg-danger bg-opacity-10" : "")">
                                    <span class="badge bg-secondary">@ApparaatTypeLabel(apparaat.Type)</span>
                                    <span class="fw-semibold">@apparaat.Naam</span>
                                    <span class="text-muted">@apparaat.Breedte×@apparaat.Hoogte</span>
                                    <button class="btn btn-outline-primary btn-sm px-1 ms-1" style="font-size: 0.8rem; line-height: 1.2;"
                                            @onclick="() => BewerkApparaat(apparaat, actieveWand.Id)" title="Bewerken">✎</button>
                                    @if (bevestigVerwijderApparaatId == apparaat.Id)
                                    {
                                        <span class="text-danger small ms-1">Weg?</span>
                                        <button class="btn btn-danger btn-sm px-1" style="font-size: 0.8rem; line-height: 1.2;"
                                                @onclick="() => { VerwijderApparaat(apparaat.Id); bevestigVerwijderApparaatId = null; }">✓</button>
                                        <button class="btn btn-outline-secondary btn-sm px-1" style="font-size: 0.8rem; line-height: 1.2;"
                                                @onclick="() => bevestigVerwijderApparaatId = null">✗</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-danger btn-sm px-1" style="font-size: 0.8rem; line-height: 1.2;"
                                                @onclick="() => bevestigVerwijderApparaatId = apparaat.Id" title="Verwijderen">×</button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (wandKasten.Count > 0 || wandApparaten.Count > 0)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0">Wandopstelling</h6>
                            <span class="text-muted small">Controleer hier of alles goed staat</span>
                        </div>
                        <WandOpstelling Kasten="@wandKasten"
                                        Apparaten="@wandApparaten"
                                        WandHoogte="@actieveWand.Hoogte"
                                        WandBreedte="@actieveWand.Breedte"
                                        PlintHoogte="@actieveWand.PlintHoogte"
                                         GeselecteerdeKastId="@(actieveWandId == actieveWand.Id ? bewerkKastId : null)"
                                         OnKastGeselecteerd="(id) => SelecteerKast(id, actieveWand.Id)"
                                          OnKastVerplaatst="VerplaatsKastOpWand"
                                          OnKastKopieren="KopieerNaarKlembord"
                                          OnKastPlakken="() => PlakUitKlembord(actieveWand.Id)"
                                          OnApparaatVerplaatst="VerplaatsApparaatOpWand"
                                          OnPlankActie="VerwerkPlankActie" />
                    </div>
                }

                <details class="mt-3" open="@(bewerkWandId == actieveWand.Id || bevestigVerwijderWandId == actieveWand.Id)">
                    <summary class="small fw-semibold text-secondary">Meer acties voor deze wand</summary>
                    <div class="border rounded p-3 mt-2 bg-body-tertiary">
                        <p class="text-muted small mb-3">Zelden gebruikte of destructieve acties staan hier zodat de hoofdtaak op deze wand rustig blijft.</p>

                        @if (bewerkWandId == actieveWand.Id)
                        {
                            <div class="d-flex flex-wrap gap-2">
                                <input type="text" class="form-control form-control-sm" style="max-width: 280px;" @bind="bewerkWandNaam" @bind:event="oninput" />
                                <button class="btn btn-sm btn-outline-primary" @onclick="WandNaamOpslaan">Opslaan</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => bewerkWandId = null">Annuleren</button>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-wrap gap-2">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => { bewerkWandId = actieveWand.Id; bewerkWandNaam = actieveWand.Naam; }">
                                    Wand hernoemen
                                </button>
                                @if (bevestigVerwijderWandId == actieveWand.Id)
                                {
                                    <span class="text-danger small fw-semibold align-self-center">Wand verwijderen?</span>
                                    <button class="btn btn-sm btn-danger" @onclick="() => BevestigVerwijderWand(actieveWand.Id)">Ja, verwijder</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => bevestigVerwijderWandId = null">Annuleren</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => bevestigVerwijderWandId = actieveWand.Id">
                                        Wand verwijderen
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </details>
            </div>
        </div>
    }
}

@* ──── Kast formulier (overlay) ──── *@
@if (toonKastFormulier && actieveWandId is not null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-start"
         style="z-index: 1050; background: rgba(0,0,0,0.4); overflow-y: auto; padding: 2rem 1rem;"
         @onclick="SluitKastFormulier" @onclick:stopPropagation="false">
        <div class="card border-success shadow-lg"
             style="max-width: 900px; width: 100%;"
             data-testid="kast-form"
             @onclick:stopPropagation="true">
            <div class="card-header bg-success bg-opacity-10 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@(isBewerken ? "Kast bewerken" : "Kast toevoegen")</h5>
                <button type="button" class="btn-close" @onclick="SluitKastFormulier"></button>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="small fw-semibold text-uppercase text-success-emphasis">Mini-stepper</div>
                        <div class="h6 mb-1" data-testid="kast-form-stap-label">Stap @kastFormStap van @LaatsteKastFormStap: @KastFormStapLabel(kastFormStap)</div>
                        <p class="text-muted small mb-0">
                            @(kastFormStap switch
                            {
                                1 => "Begin met de basis: kies de wand, geef de kast een naam en start eventueel vanuit een eerder gebruikt voorbeeld.",
                                2 => "Voer daarna alleen de hoofdmaten in. Het afgeleide kasttype ziet u meteen terug.",
                                3 => "Technische velden verschijnen pas hier en alleen als deze kast afwijkt van de standaard.",
                                _ => "Controleer de samenvatting en preview voordat u de kast opslaat."
                            })
                        </p>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <StapHulpDrawer StapId="kasten" KnopLabel="Meer hulp" />
                        <span class="badge text-bg-light">Stap @kastFormStap/@LaatsteKastFormStap</span>
                    </div>
                </div>

                <div class="progress mb-3" style="height: 0.5rem;" data-testid="kast-form-progress">
                    <div class="progress-bar bg-success" style="width: @(StapVoortgang(kastFormStap, LaatsteKastFormStap))%"></div>
                </div>

                <div class="d-flex flex-wrap gap-2 mb-4">
                    @for (var index = 0; index < KastFormStappen.Length; index++)
                    {
                        var stapNummer = index + 1;
                        var stapClass = kastFormStap > stapNummer
                            ? "text-bg-success"
                            : kastFormStap == stapNummer
                                ? "text-bg-primary"
                                : "text-bg-light";

                        <span class="badge @stapClass">@($"{stapNummer}. {KastFormStappen[index]}")</span>
                    }
                </div>

                @if (kastFormStap == 1)
                {
                    @if (!isBewerken && State.KastTemplates.Count > 0)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-muted small">Eerder gebruikte kasten</label>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var template in State.KastTemplates.OrderByDescending(t => t.LaatstGebruikt))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary"
                                            @onclick="() => VulFormulierVanTemplate(template)"
                                            title="@template.Naam · @template.Breedte×@template.Hoogte×@template.Diepte mm">
                                        <span class="badge @TypeBadge(template.Type) me-1">@template.Type</span>
                                        @template.Naam
                                        <small class="text-muted ms-1">@template.Breedte×@template.Hoogte</small>
                                    </button>
                                }
                            </div>
                        </div>
                        <hr class="my-2" />
                    }

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Wand</label>
                            <select class="form-select"
                                    value="@actieveWandId"
                                    @onchange="OnWandGewijzigd"
                                    data-testid="kast-wand-select">
                                @foreach (var w in State.Wanden)
                                {
                                    <option value="@w.Id">@w.Naam</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Naam</label>
                            <input type="text" class="form-control" @bind="formKast.Naam" @bind:event="oninput"
                                   placeholder="bv. Onderkast spoelbak"
                                   data-testid="kast-naam-input" />
                        </div>
                    </div>
                }
                else if (kastFormStap == 2)
                {
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Breedte (mm)</label>
                            <input type="number" class="form-control" @bind="formKast.Breedte" min="100" step="10"
                                   data-testid="kast-breedte-input" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Hoogte (mm)</label>
                            <input type="number" class="form-control" @bind="formKast.Hoogte" @bind:after="AutoBerekenPosities" min="100" step="10"
                                   data-testid="kast-hoogte-input" />
                            <div class="form-text">Type: <span class="badge @TypeBadge(InferKastType(formKast.Hoogte))">@InferKastType(formKast.Hoogte)</span></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Diepte (mm)</label>
                            <input type="number" class="form-control" @bind="formKast.Diepte" min="100" step="10"
                                   data-testid="kast-diepte-input" />
                        </div>
                    </div>

                    <div class="alert alert-light border mb-0">
                        <div class="fw-semibold mb-1">Alleen de hoofdmaten nodig</div>
                        <div class="small text-muted">De technische gaatjesrij en afwijkende kastdetails bewaart u voor de volgende stap, zodat deze stap alleen over maatvoering gaat.</div>
                    </div>
                }
                else if (kastFormStap == 3)
                {
                    <div class="card border-0 bg-body-tertiary mb-3">
                        <div class="card-body">
                            <button type="button"
                                    class="btn btn-outline-secondary w-100 d-flex justify-content-between align-items-center gap-3"
                                    @onclick="ToggleTechnischeInstellingen">
                                <span class="text-start">
                                    <span class="d-block fw-semibold">Afwijkende gaatjesrij of kastdetails</span>
                                    <span class="small text-muted">Open alleen als deze kast afwijkt van de standaard voor wanddikte, systeemgaten of planken.</span>
                                </span>
                                <span class="fs-5" aria-hidden="true">@(toonTechnischeInstellingen ? "−" : "+")</span>
                            </button>

                            @if (toonTechnischeInstellingen)
                            {
                                    <div class="mt-3">
                                        <div class="row g-3 mb-3">
                                            <div class="col-md-4">
                                                <div class="d-flex align-items-center gap-2 mb-1">
                                                    <label class="form-label mb-0">Dikte van de kastwand (mm)</label>
                                                    <HulpInfoKnop Titel="Dikte van de kastwand"
                                                                  Tekst="Gebruik hier de werkelijke dikte van de zijplaten van deze kast. Die maat heeft invloed op systeemgaten en scharnieronderdelen."
                                                                  Voorbeeld="Standaard is dit meestal 18 mm."
                                                                  WatNuDoen="Laat de standaard staan tenzij deze kast met een andere plaatdikte wordt gebouwd." />
                                                </div>
                                                <input type="number" class="form-control" @bind="formKast.Wanddikte" @bind:after="AutoBerekenPosities" min="1" step="1" />
                                                <div class="form-text hulp-hint">Gebruik alleen een afwijkende waarde als het materiaal van deze kast echt dikker of dunner is.</div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="d-flex align-items-center gap-2 mb-1">
                                                    <label class="form-label mb-0">Afstand tussen systeemgaten (mm)</label>
                                                    <HulpInfoKnop Titel="Rij systeemgaten"
                                                                  Tekst="Dit is de vaste steek van de gatenrij in de kastzijwand. Die bepaalt waar de montageplaat en andere boringen uitkomen."
                                                                  Voorbeeld="Voor veel keukenkasten is 32 mm de standaard."
                                                                  WatNuDoen="Pas dit alleen aan als deze kast een andere gatensteek gebruikt dan de standaard." />
                                                </div>
                                                <input type="number" class="form-control" @bind="formKast.GaatjesAfstand" @bind:after="AutoBerekenPosities" min="1" step="1" />
                                                <div class="form-text hulp-hint">De standaard gatensteek is meestal 32 mm.</div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="d-flex align-items-center gap-2 mb-1">
                                                    <label class="form-label mb-0">Afstand onderkant bovenplank tot eerste gat (mm)</label>
                                                    <HulpInfoKnop Titel="Eerste gat vanaf de bovenste plank"
                                                                  Tekst="Deze maat bepaalt waar de eerste positie van de systeemgaten start ten opzichte van de bovenkant van de kastromp."
                                                                  Voorbeeld="Bij veel kasten is dit 19 mm vanaf de onderkant van de bovenste plank."
                                                                  WatNuDoen="Controleer deze maat alleen als uw leverancier of bestaand kasttype van de standaard afwijkt." />
                                                </div>
                                                <input type="number" class="form-control" @bind="formKast.EersteGaatVanBoven" @bind:after="AutoBerekenPosities" min="1" step="1" />
                                                <div class="form-text hulp-hint">Meet vanaf de onderkant van de bovenste plank naar het eerste gat.</div>
                                            </div>
                                        </div>

                                    <p class="text-muted small mb-0"><em>Tip: dubbelklik in de wandopstelling om een plank toe te voegen. Sleep planken of gebruik de pijltjestoetsen. Selecteer een plank en druk Delete om hem te verwijderen.</em></p>
                                </div>
                            }
                            else
                            {
                                <div class="small text-muted mt-3 mb-0">
                                    Deze kast gebruikt de standaard voor wanddikte, systeemgaten en eerste gat vanaf de bovenste plank. U kunt direct doorgaan naar de controle.
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="row g-4 align-items-start">
                        <div class="col-lg-6">
                            <div class="card border-0 bg-body-tertiary h-100">
                                <div class="card-body">
                                    <h6 class="mb-3">Controle voor opslaan</h6>
                                    <dl class="row mb-0 small">
                                        <dt class="col-sm-4">Wand</dt>
                                        <dd class="col-sm-8">@ActieveWandNaam()</dd>

                                        <dt class="col-sm-4">Naam</dt>
                                        <dd class="col-sm-8">@formKast.Naam</dd>

                                        <dt class="col-sm-4">Type</dt>
                                        <dd class="col-sm-8"><span class="badge @TypeBadge(InferKastType(formKast.Hoogte))">@InferKastType(formKast.Hoogte)</span></dd>

                                        <dt class="col-sm-4">Maten</dt>
                                        <dd class="col-sm-8">@formKast.Breedte × @formKast.Hoogte × @formKast.Diepte mm</dd>

                                        <dt class="col-sm-4">Techniek</dt>
                                        <dd class="col-sm-8">
                                            @if (toonTechnischeInstellingen)
                                            {
                                                <span>Afwijkend: @formKast.Wanddikte mm wanddikte, @formKast.GaatjesAfstand mm systeemgaten, @formKast.EersteGaatVanBoven mm eerste gat</span>
                                            }
                                            else
                                            {
                                                <span>Standaard gaatjesrij en kastdetails</span>
                                            }
                                        </dd>
                                    </dl>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="text-center">
                                <KastVisueel Kast="@formKast" MaxHoogte="180" />
                            </div>
                        </div>
                    </div>
                }

                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-4">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            @onclick="VorigeKastFormStap"
                            disabled="@(kastFormStap == 1)"
                            data-testid="kast-form-terug-button">
                        Terug
                    </button>
                    <div class="d-flex gap-2">
                        @if (kastFormStap < LaatsteKastFormStap)
                        {
                            <button type="button"
                                    class="btn btn-primary"
                                    @onclick="VolgendeKastFormStap"
                                    disabled="@(!KanNaarVolgendeKastStap())"
                                    data-testid="kast-form-volgende-button">
                                Volgende stap
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary" @onclick="KastOpslaan"
                                    disabled="@string.IsNullOrWhiteSpace(formKast.Naam)"
                                    data-testid="kast-opslaan-button">
                                @(isBewerken ? "Opslaan" : "Kast toevoegen")
                            </button>
                        }
                        <button type="button" class="btn btn-outline-secondary" @onclick="SluitKastFormulier">
                            Annuleren
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ──── Apparaat formulier (overlay) ──── *@
@if (toonApparaatFormulier && actieveWandId is not null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-start"
         style="z-index: 1050; background: rgba(0,0,0,0.4); overflow-y: auto; padding: 2rem 1rem;"
         @onclick="SluitApparaatFormulier" @onclick:stopPropagation="false">
        <div class="card border-secondary shadow-lg" style="max-width: 600px; width: 100%;"
             data-testid="apparaat-form"
             @onclick:stopPropagation="true">
            <div class="card-header bg-secondary bg-opacity-10 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@(isApparaatBewerken ? "Apparaat bewerken" : "Apparaat toevoegen")</h5>
                <button type="button" class="btn-close" @onclick="SluitApparaatFormulier"></button>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="small fw-semibold text-uppercase text-secondary-emphasis">Mini-stepper</div>
                        <div class="h6 mb-1" data-testid="apparaat-form-stap-label">Stap @apparaatFormStap van @LaatsteApparaatFormStap: @ApparaatFormStapLabel(apparaatFormStap)</div>
                        <p class="text-muted small mb-0">
                            @(apparaatFormStap switch
                            {
                                1 => "Begin met het type, de naam en de wandcontext van het apparaat.",
                                2 => "Vul daarna alleen de maatvoering in.",
                                _ => "Controleer de samenvatting en preview voordat u het apparaat opslaat."
                            })
                        </p>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <StapHulpDrawer StapId="kasten" KnopLabel="Meer hulp" />
                        <span class="badge text-bg-light">Stap @apparaatFormStap/@LaatsteApparaatFormStap</span>
                    </div>
                </div>

                <div class="progress mb-3" style="height: 0.5rem;" data-testid="apparaat-form-progress">
                    <div class="progress-bar bg-secondary" style="width: @(StapVoortgang(apparaatFormStap, LaatsteApparaatFormStap))%"></div>
                </div>

                <div class="d-flex flex-wrap gap-2 mb-4">
                    @for (var index = 0; index < ApparaatFormStappen.Length; index++)
                    {
                        var stapNummer = index + 1;
                        var stapClass = apparaatFormStap > stapNummer
                            ? "text-bg-success"
                            : apparaatFormStap == stapNummer
                                ? "text-bg-primary"
                                : "text-bg-light";

                        <span class="badge @stapClass">@($"{stapNummer}. {ApparaatFormStappen[index]}")</span>
                    }
                </div>

                @if (apparaatFormStap == 1)
                {
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Wand</label>
                            <div class="form-control bg-body-tertiary">@ActieveWandNaam()</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Type</label>
                            <select class="form-select" value="@formApparaat.Type" @onchange="OnApparaatTypeGewijzigd">
                                @foreach (var t in Enum.GetValues<ApparaatType>())
                                {
                                    <option value="@t">@ApparaatTypeLabel(t)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Naam</label>
                            <input type="text" class="form-control" @bind="formApparaat.Naam" @bind:event="oninput"
                                   placeholder="bv. Oven Bosch" />
                        </div>
                    </div>
                }
                else if (apparaatFormStap == 2)
                {
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Breedte (mm)</label>
                            <input type="number" class="form-control" @bind="formApparaat.Breedte" min="100" step="10" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Hoogte (mm)</label>
                            <input type="number" class="form-control" @bind="formApparaat.Hoogte" min="10" step="10" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Diepte (mm)</label>
                            <input type="number" class="form-control" @bind="formApparaat.Diepte" min="100" step="10" />
                        </div>
                    </div>

                    <div class="alert alert-light border mb-0">
                        <div class="fw-semibold mb-1">Alleen de maatvoering</div>
                        <div class="small text-muted">De controle met preview komt in de laatste stap, zodat u nu alleen nog over de hoofdafmetingen beslist.</div>
                    </div>
                }
                else
                {
                    <div class="row g-4 align-items-start">
                        <div class="col-md-6">
                            <div class="card border-0 bg-body-tertiary h-100">
                                <div class="card-body">
                                    <h6 class="mb-3">Controle voor opslaan</h6>
                                    <dl class="row mb-0 small">
                                        <dt class="col-sm-4">Wand</dt>
                                        <dd class="col-sm-8">@ActieveWandNaam()</dd>

                                        <dt class="col-sm-4">Type</dt>
                                        <dd class="col-sm-8">@ApparaatTypeLabel(formApparaat.Type)</dd>

                                        <dt class="col-sm-4">Naam</dt>
                                        <dd class="col-sm-8">@formApparaat.Naam</dd>

                                        <dt class="col-sm-4">Maten</dt>
                                        <dd class="col-sm-8">@formApparaat.Breedte × @formApparaat.Hoogte × @formApparaat.Diepte mm</dd>
                                    </dl>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-center mb-3">
                                <svg width="120" height="80" class="border rounded bg-light">
                                    <text x="60" y="20" font-size="24" text-anchor="middle">@ApparaatIcoon(formApparaat.Type)</text>
                                    <text x="60" y="45" font-size="10" text-anchor="middle" fill="#333">@ApparaatTypeLabel(formApparaat.Type)</text>
                                    <text x="60" y="60" font-size="9" text-anchor="middle" fill="#888">@formApparaat.Breedte×@formApparaat.Hoogte mm</text>
                                </svg>
                            </div>
                        </div>
                    </div>
                }

                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-4">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            @onclick="VorigeApparaatFormStap"
                            disabled="@(apparaatFormStap == 1)"
                            data-testid="apparaat-form-terug-button">
                        Terug
                    </button>
                    <div class="d-flex gap-2">
                        @if (apparaatFormStap < LaatsteApparaatFormStap)
                        {
                            <button type="button"
                                    class="btn btn-primary"
                                    @onclick="VolgendeApparaatFormStap"
                                    disabled="@(!KanNaarVolgendeApparaatStap())"
                                    data-testid="apparaat-form-volgende-button">
                                Volgende stap
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary" @onclick="ApparaatOpslaan"
                                    disabled="@string.IsNullOrWhiteSpace(formApparaat.Naam)">
                                @(isApparaatBewerken ? "Opslaan" : "Apparaat toevoegen")
                            </button>
                        }
                        <button type="button" class="btn btn-outline-secondary" @onclick="SluitApparaatFormulier">
                            Annuleren
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<StapNavigatie HuidigeStap="kasten"
               VolgendeHref="panelen"
               VolgendeDisabled="@(State.Kasten.Count == 0)" />
