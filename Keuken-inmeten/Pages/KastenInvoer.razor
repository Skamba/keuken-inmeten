@page "/kasten"
@inject KeukenStateService State
@inject ActieFeedbackService Feedback
@implements IDisposable

<PageTitle>Stap 1 — Indeling</PageTitle>

<StapIndicator HuidigeStap="kasten" />

<div class="d-flex justify-content-between align-items-center mb-2">
    <h2 class="page-header mb-0">Stap 1: Indeling</h2>
    @if (State.Kasten.Count > 0)
    {
        @if (bevestigVerwijderAlleKasten)
        {
            <div class="d-flex align-items-center gap-2">
                <span class="text-danger small fw-semibold">Alle @State.Kasten.Count kast(en) verwijderen?</span>
                <button class="btn btn-sm btn-danger" @onclick="VerwijderAlleKasten">Ja, verwijder alles</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => bevestigVerwijderAlleKasten = false">Annuleren</button>
            </div>
        }
        else
        {
            <button class="btn btn-sm btn-outline-danger" @onclick="() => bevestigVerwijderAlleKasten = true">
                Verwijder alle kasten
            </button>
        }
    }
</div>
<p class="text-muted">Maak wandindelingen aan en plaats kasten naast elkaar om uw keuken na te bouwen.</p>

<TerminologieUitleg Sleutels="plinthoogte,wanddikte,gaatjesrij"
                    Beschrijving="Deze woordenlijst helpt bij de technische maten die u in stap 1 invult." />

@* ──── Wand toevoegen ──── *@
<div class="card mb-4">
    <div class="card-body d-flex align-items-end gap-3">
        <div class="flex-grow-1">
            <label class="form-label fw-semibold">Nieuwe wand</label>
            <input type="text" class="form-control" @bind="nieuweWandNaam" @bind:event="oninput"
                   placeholder="bv. Linkerwand, Achterwand, Rechts bij raam" @onkeydown="WandToevoegenBijEnter"
                   data-testid="nieuwe-wand-naam-input" />
        </div>
        <button class="btn btn-primary" @onclick="WandToevoegen"
                disabled="@string.IsNullOrWhiteSpace(nieuweWandNaam)"
                data-testid="wand-toevoegen-button">
            Wand toevoegen
        </button>
    </div>
</div>

@if (State.Wanden.Count == 0)
{
    <div class="alert alert-info">
        Begin door een wand toe te voegen. Elke wand stelt een rij kasten voor die naast elkaar staan.
    </div>
}

@* ──── Per wand ──── *@
@foreach (var wand in State.Wanden)
{
    var wandKasten = State.KastenVoorWand(wand.Id);
    var wandApparaten = State.ApparatenVoorWand(wand.Id);
    var gevuldeBreedte = wand.TotaleBreedte(State.Kasten);
    var vrijeBreedte = Math.Max(0, wand.Breedte - gevuldeBreedte);
    var toonPrimaireActies = actieveWandId != wand.Id || (!toonKastFormulier && !toonApparaatFormulier);

    <div class="card mb-4 border-primary"
         @key="wand.Id"
         data-testid="indeling-wand-card"
         data-wand-id="@wand.Id"
         data-wand-naam="@wand.Naam">
        <div class="card-header bg-primary bg-opacity-10">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                        <h5 class="mb-0">@wand.Naam</h5>
                        <span class="badge text-bg-light">@wandKasten.Count kast(en)</span>
                        @if (wandApparaten.Count > 0)
                        {
                            <span class="badge text-bg-light">@wandApparaten.Count apparaat(en)</span>
                        }
                    </div>
                    <div class="small text-muted">
                        @gevuldeBreedte mm ingevuld · @vrijeBreedte mm vrije wandruimte
                    </div>
                </div>
                <div class="small text-muted">
                    <div class="fw-semibold text-uppercase">Volgende stap</div>
                    <div>Voeg kasten toe en controleer daarna de wandopstelling.</div>
                </div>
            </div>
        </div>
        <div class="card-body">
            @if (toonPrimaireActies)
            {
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4 pb-3 border-bottom">
                    <div>
                        <h6 class="mb-1">Begin met de kasten op deze wand</h6>
                        <p class="text-muted small mb-0"><strong>+ Kast toevoegen</strong> is de hoofdactie. Voeg alleen een apparaat toe als het echt ruimte op deze wand inneemt.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-primary"
                                @onclick="() => OpenKastFormulier(wand.Id)"
                                data-testid="open-kast-form-button"
                                data-wand-id="@wand.Id">
                            + Kast toevoegen
                        </button>
                        <button class="btn btn-outline-secondary"
                                @onclick="() => OpenApparaatFormulier(wand.Id)"
                                data-testid="open-apparaat-form-button"
                                data-wand-id="@wand.Id">
                            + Apparaat toevoegen
                        </button>
                    </div>
                </div>
            }

            @* ── Wandafmetingen ── *@
            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">Afmetingen van deze wand</h6>
                    <span class="text-muted small">Context voor de opstelling</span>
                </div>
                <div class="row g-3">
                    <div class="col-sm-4">
                        <label class="form-label small mb-0">Wandbreedte (mm)</label>
                        <input type="number" class="form-control form-control-sm"
                               value="@wand.Breedte" @onchange="e => WijzigWandAfmeting(wand, nameof(KeukenWand.Breedte), e)" />
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label small mb-0">Wandhoogte (mm)</label>
                        <input type="number" class="form-control form-control-sm"
                               value="@wand.Hoogte" @onchange="e => WijzigWandAfmeting(wand, nameof(KeukenWand.Hoogte), e)" />
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label small mb-0">Hoogte van de plint (mm)</label>
                        <input type="number" class="form-control form-control-sm" min="0" step="10"
                               value="@wand.PlintHoogte" @onchange="e => WijzigWandAfmeting(wand, nameof(KeukenWand.PlintHoogte), e)" />
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">Kasten op deze wand</h6>
                    <span class="text-muted small">@(wandKasten.Count == 0 ? "Nog geen kasten" : $"{wandKasten.Count} toegevoegd")</span>
                </div>
                @if (wandKasten.Count > 0)
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var kast in wandKasten)
                        {
                            <div class="d-flex align-items-center gap-1 border rounded px-2 py-1 small @(bewerkKastId == kast.Id && actieveWandId == wand.Id ? "border-primary bg-primary bg-opacity-10" : "")">
                                <span class="badge @TypeBadge(kast.Type)">@kast.Type</span>
                                <span class="fw-semibold">@kast.Naam</span>
                                <span class="text-muted">@kast.Breedte×@kast.Hoogte</span>
                                <button class="btn btn-outline-primary btn-sm px-1 ms-1" style="font-size: 0.75rem; line-height: 1.2;"
                                        @onclick="() => BewerkKast(kast, wand.Id)" title="Kast bewerken">✎</button>
                                <button class="btn btn-outline-secondary btn-sm px-1" style="font-size: 0.75rem; line-height: 1.2;"
                                        @onclick="() => KopieerKast(kast, wand.Id)" title="Kast kopiëren">⧉</button>
                                @if (bevestigVerwijderKastId == kast.Id)
                                {
                                    <span class="text-danger small ms-1 fw-semibold">Verwijderen?</span>
                                    <button class="btn btn-danger btn-sm px-1" style="font-size: 0.75rem; line-height: 1.2;"
                                            @onclick="() => { VerwijderKast(kast.Id); bevestigVerwijderKastId = null; }" title="Bevestig verwijderen">Ja</button>
                                    <button class="btn btn-outline-secondary btn-sm px-1" style="font-size: 0.75rem; line-height: 1.2;"
                                            @onclick="() => bevestigVerwijderKastId = null" title="Annuleren">Nee</button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-danger btn-sm px-1" style="font-size: 0.75rem; line-height: 1.2;"
                                            @onclick="() => bevestigVerwijderKastId = kast.Id" title="Kast verwijderen">×</button>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="border rounded p-3 small text-muted bg-body-tertiary">
                        Begin met <strong>+ Kast toevoegen</strong> om deze wand op te bouwen.
                    </div>
                }
            </div>

            @if (wandApparaten.Count > 0)
            {
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">Apparaten op deze wand</h6>
                        <span class="text-muted small">@wandApparaten.Count toegevoegd</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var apparaat in wandApparaten)
                        {
                            <div class="d-flex align-items-center gap-1 border rounded px-2 py-1 small @(bewerkApparaatId == apparaat.Id && actieveWandId == wand.Id ? "border-danger bg-danger bg-opacity-10" : "")">
                                <span class="badge bg-secondary">@ApparaatTypeLabel(apparaat.Type)</span>
                                <span class="fw-semibold">@apparaat.Naam</span>
                                <span class="text-muted">@apparaat.Breedte×@apparaat.Hoogte</span>
                                <button class="btn btn-outline-primary btn-sm px-1 ms-1" style="font-size: 0.8rem; line-height: 1.2;"
                                        @onclick="() => BewerkApparaat(apparaat, wand.Id)" title="Bewerken">✎</button>
                                @if (bevestigVerwijderApparaatId == apparaat.Id)
                                {
                                    <span class="text-danger small ms-1">Weg?</span>
                                    <button class="btn btn-danger btn-sm px-1" style="font-size: 0.8rem; line-height: 1.2;"
                                            @onclick="() => { VerwijderApparaat(apparaat.Id); bevestigVerwijderApparaatId = null; }">✓</button>
                                    <button class="btn btn-outline-secondary btn-sm px-1" style="font-size: 0.8rem; line-height: 1.2;"
                                            @onclick="() => bevestigVerwijderApparaatId = null">✗</button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-danger btn-sm px-1" style="font-size: 0.8rem; line-height: 1.2;"
                                            @onclick="() => bevestigVerwijderApparaatId = apparaat.Id" title="Verwijderen">×</button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @* ── Wandopstelling ── *@
            @if (wandKasten.Count > 0 || wandApparaten.Count > 0)
            {
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">Wandopstelling</h6>
                        <span class="text-muted small">Controleer hier of alles goed staat</span>
                    </div>
                    <WandOpstelling Kasten="@wandKasten"
                                    Apparaten="@wandApparaten"
                                    WandHoogte="@wand.Hoogte"
                                    WandBreedte="@wand.Breedte"
                                    PlintHoogte="@wand.PlintHoogte"
                                     GeselecteerdeKastId="@(actieveWandId == wand.Id ? bewerkKastId : null)"
                                     OnKastGeselecteerd="(id) => SelecteerKast(id, wand.Id)"
                                      OnKastVerplaatst="VerplaatsKastOpWand"
                                      OnKastKopieren="KopieerNaarKlembord"
                                      OnKastPlakken="() => PlakUitKlembord(wand.Id)"
                                      OnApparaatVerplaatst="VerplaatsApparaatOpWand"
                                      OnPlankActie="VerwerkPlankActie" />
                </div>
            }

            <details class="mt-3" open="@(bewerkWandId == wand.Id || bevestigVerwijderWandId == wand.Id)">
                <summary class="small fw-semibold text-secondary">Meer acties voor deze wand</summary>
                <div class="border rounded p-3 mt-2 bg-body-tertiary">
                    <p class="text-muted small mb-3">Zelden gebruikte of destructieve acties staan hier zodat de hoofdtaak op deze wand rustig blijft.</p>

                    @if (bewerkWandId == wand.Id)
                    {
                        <div class="d-flex flex-wrap gap-2">
                            <input type="text" class="form-control form-control-sm" style="max-width: 280px;" @bind="bewerkWandNaam" @bind:event="oninput" />
                            <button class="btn btn-sm btn-outline-primary" @onclick="WandNaamOpslaan">Opslaan</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => bewerkWandId = null">Annuleren</button>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => { bewerkWandId = wand.Id; bewerkWandNaam = wand.Naam; }">
                                Wand hernoemen
                            </button>
                            @if (bevestigVerwijderWandId == wand.Id)
                            {
                                <span class="text-danger small fw-semibold align-self-center">Wand verwijderen?</span>
                                <button class="btn btn-sm btn-danger" @onclick="() => BevestigVerwijderWand(wand.Id)">Ja, verwijder</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => bevestigVerwijderWandId = null">Annuleren</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => bevestigVerwijderWandId = wand.Id">
                                    Wand verwijderen
                                </button>
                            }
                        </div>
                    }
                </div>
            </details>
        </div>
    </div>
}

@* ──── Kast formulier (overlay) ──── *@
@if (toonKastFormulier && actieveWandId is not null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-start"
         style="z-index: 1050; background: rgba(0,0,0,0.4); overflow-y: auto; padding: 2rem 1rem;"
         @onclick="SluitKastFormulier" @onclick:stopPropagation="false">
        <div class="card border-success shadow-lg"
             style="max-width: 900px; width: 100%;"
             data-testid="kast-form"
             @onclick:stopPropagation="true">
            <div class="card-header bg-success bg-opacity-10 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@(isBewerken ? "Kast bewerken" : "Kast toevoegen")</h5>
                <button type="button" class="btn-close" @onclick="SluitKastFormulier"></button>
            </div>
            <div class="card-body">

            @* ── Eerder gebruikte kasten ── *@
            @if (!isBewerken && State.KastTemplates.Count > 0)
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted small">Eerder gebruikte kasten</label>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var template in State.KastTemplates.OrderByDescending(t => t.LaatstGebruikt))
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => VulFormulierVanTemplate(template)"
                                    title="@template.Naam · @template.Breedte×@template.Hoogte×@template.Diepte mm">
                                <span class="badge @TypeBadge(template.Type) me-1">@template.Type</span>
                                @template.Naam
                                <small class="text-muted ms-1">@template.Breedte×@template.Hoogte</small>
                            </button>
                        }
                    </div>
                </div>
                <hr class="my-2" />
            }

            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">Basisgegevens</h6>
                <span class="text-muted small">Voldoende voor een standaardkast</span>
            </div>
            <p class="text-muted small mb-3">Vul eerst alleen de kerngegevens in. Technische kastdetails zijn alleen nodig als deze kast afwijkt van de standaard.</p>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Wand</label>
                    <select class="form-select"
                            value="@actieveWandId"
                            @onchange="OnWandGewijzigd"
                            data-testid="kast-wand-select">
                        @foreach (var w in State.Wanden)
                        {
                            <option value="@w.Id">@w.Naam</option>
                        }
                    </select>
                </div>
                <div class="col-md-8">
                    <label class="form-label">Naam</label>
                    <input type="text" class="form-control" @bind="formKast.Naam" @bind:event="oninput"
                           placeholder="bv. Onderkast spoelbak"
                           data-testid="kast-naam-input" />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Breedte (mm)</label>
                    <input type="number" class="form-control" @bind="formKast.Breedte" min="100" step="10"
                           data-testid="kast-breedte-input" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Hoogte (mm)</label>
                    <input type="number" class="form-control" @bind="formKast.Hoogte" @bind:after="AutoBerekenPosities" min="100" step="10"
                           data-testid="kast-hoogte-input" />
                    <div class="form-text">Type: <span class="badge @TypeBadge(InferKastType(formKast.Hoogte))">@InferKastType(formKast.Hoogte)</span></div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Diepte (mm)</label>
                    <input type="number" class="form-control" @bind="formKast.Diepte" min="100" step="10"
                           data-testid="kast-diepte-input" />
                </div>
            </div>

            <div class="card border-0 bg-body-tertiary mb-3">
                <div class="card-body">
                    <button type="button"
                            class="btn btn-outline-secondary w-100 d-flex justify-content-between align-items-center gap-3"
                            @onclick="ToggleTechnischeInstellingen">
                        <span class="text-start">
                            <span class="d-block fw-semibold">Afwijkende gaatjesrij of kastdetails</span>
                            <span class="small text-muted">Open alleen als deze kast afwijkt van de standaard voor wanddikte, systeemgaten of planken.</span>
                        </span>
                        <span class="fs-5" aria-hidden="true">@(toonTechnischeInstellingen ? "−" : "+")</span>
                    </button>

                    @if (toonTechnischeInstellingen)
                    {
                        <div class="mt-3">
                            <div class="row g-3 mb-3">
                                <div class="col-md-4">
                                    <label class="form-label">Dikte van de kastwand (mm)</label>
                                    <input type="number" class="form-control" @bind="formKast.Wanddikte" @bind:after="AutoBerekenPosities" min="1" step="1" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Afstand tussen systeemgaten (mm)</label>
                                    <input type="number" class="form-control" @bind="formKast.GaatjesAfstand" @bind:after="AutoBerekenPosities" min="1" step="1" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Afstand onderkant bovenplank tot eerste gat (mm)</label>
                                    <input type="number" class="form-control" @bind="formKast.EersteGaatVanBoven" @bind:after="AutoBerekenPosities" min="1" step="1" />
                                    <div class="form-text">Meet vanaf de onderkant van de bovenste plank naar het eerste gat.</div>
                                </div>
                            </div>

                            <div class="text-center mb-3">
                                <KastVisueel Kast="@formKast" MaxHoogte="160" />
                            </div>

                            <p class="text-muted small mb-0"><em>Tip: dubbelklik in de wandopstelling om een plank toe te voegen. Sleep planken of gebruik de pijltjestoetsen. Selecteer een plank en druk Delete om hem te verwijderen.</em></p>
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary" @onclick="KastOpslaan"
                        disabled="@string.IsNullOrWhiteSpace(formKast.Naam)"
                        data-testid="kast-opslaan-button">
                    @(isBewerken ? "Opslaan" : "Kast toevoegen")
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="SluitKastFormulier">
                    Annuleren
                </button>
            </div>
            </div>
        </div>
    </div>
}

@* ──── Apparaat formulier (overlay) ──── *@
@if (toonApparaatFormulier && actieveWandId is not null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-start"
         style="z-index: 1050; background: rgba(0,0,0,0.4); overflow-y: auto; padding: 2rem 1rem;"
         @onclick="SluitApparaatFormulier" @onclick:stopPropagation="false">
        <div class="card border-secondary shadow-lg" style="max-width: 600px; width: 100%;"
             @onclick:stopPropagation="true">
            <div class="card-header bg-secondary bg-opacity-10 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@(isApparaatBewerken ? "Apparaat bewerken" : "Apparaat toevoegen")</h5>
                <button type="button" class="btn-close" @onclick="SluitApparaatFormulier"></button>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Type</label>
                        <select class="form-select" value="@formApparaat.Type" @onchange="OnApparaatTypeGewijzigd">
                            @foreach (var t in Enum.GetValues<ApparaatType>())
                            {
                                <option value="@t">@ApparaatTypeLabel(t)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Naam</label>
                        <input type="text" class="form-control" @bind="formApparaat.Naam" @bind:event="oninput"
                               placeholder="bv. Oven Bosch" />
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Breedte (mm)</label>
                        <input type="number" class="form-control" @bind="formApparaat.Breedte" min="100" step="10" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Hoogte (mm)</label>
                        <input type="number" class="form-control" @bind="formApparaat.Hoogte" min="10" step="10" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Diepte (mm)</label>
                        <input type="number" class="form-control" @bind="formApparaat.Diepte" min="100" step="10" />
                    </div>
                </div>

                <div class="text-center mb-3">
                    <svg width="120" height="80" class="border rounded bg-light">
                        <text x="60" y="20" font-size="24" text-anchor="middle">@ApparaatIcoon(formApparaat.Type)</text>
                        <text x="60" y="45" font-size="10" text-anchor="middle" fill="#333">@ApparaatTypeLabel(formApparaat.Type)</text>
                        <text x="60" y="60" font-size="9" text-anchor="middle" fill="#888">@formApparaat.Breedte×@formApparaat.Hoogte mm</text>
                    </svg>
                </div>

                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-primary" @onclick="ApparaatOpslaan"
                            disabled="@string.IsNullOrWhiteSpace(formApparaat.Naam)">
                        @(isApparaatBewerken ? "Opslaan" : "Apparaat toevoegen")
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="SluitApparaatFormulier">
                        Annuleren
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<StapNavigatie HuidigeStap="kasten"
               VolgendeHref="panelen"
               VolgendeDisabled="@(State.Kasten.Count == 0)" />
