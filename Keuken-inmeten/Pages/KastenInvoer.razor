@page "/kasten"
@inject KeukenStateService State
@inject ActieFeedbackService Feedback
@inject ProjectBeheerService Projectbeheer
@implements IDisposable

<PageTitle>Stap 1 — Indeling</PageTitle>

<StapIndicator HuidigeStap="kasten" />

@{
    var actieveWand = State.Wanden.Find(wand => wand.Id == actieveWandId);
}

<h2 class="page-header mb-0">Stap 1: Indeling</h2>
@if (actieveWand is null)
{
    <p class="text-muted mb-3">Maak wandindelingen aan en open daarna steeds één wand om maten, kasten en objecten rustig per werkruimte uit te werken.</p>
}
<div class="stap-ondersteuning mb-3" data-testid="kasten-stap-ondersteuning">
    <StapHulpDrawer StapId="kasten" KnopLabel="Hulp bij stap" />
    <TerminologieUitleg Compact="true"
                        CompactLabel="Leg termen uit"
                        Sleutels="plinthoogte,wanddikte,gaatjesrij,eerstegat"
                        Beschrijving="Open alleen bij twijfel over de technische maten die u in stap 1 invult." />
</div>

@* ──── Wand toevoegen ──── *@
@if (State.Wanden.Count == 0)
{
    <div class="card mb-4">
        <div class="card-body d-flex flex-column flex-lg-row align-items-lg-end gap-3">
            <div class="flex-grow-1">
                <div class="form-label fw-semibold mb-1">Nieuwe wand</div>
                <div class="small text-muted mb-0">Begin met uw eerste werkruimte en geef daarna de wandnaam op in een korte pop-up.</div>
            </div>
            <button type="button"
                    class="btn btn-primary"
                    @onclick="OpenWandToevoegenModal"
                    data-testid="open-wand-toevoegen-modal-button">
                Wand toevoegen
            </button>
        </div>
    </div>
}
else
{
    @if (actieveWand is null)
    {
        <div class="indeling-nieuwe-wand-strip mb-4">
            <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-end gap-3">
                <div>
                    <div class="small fw-semibold text-uppercase text-muted mb-1">Extra wand</div>
                    <div class="small text-muted mb-0">Alleen nodig als deze keuken nog een extra zijde krijgt.</div>
                </div>
                <div class="d-flex justify-content-xl-end">
                    <button type="button"
                            class="btn btn-primary"
                            @onclick="OpenWandToevoegenModal"
                            data-testid="open-wand-toevoegen-modal-button">
                        Wand toevoegen
                    </button>
                </div>
            </div>
        </div>
    }
}

@if (State.Wanden.Count == 0)
{
    <div class="alert alert-info">
        Begin door een wand toe te voegen. Elke wand stelt een rij kasten voor die naast elkaar staan.
    </div>
}
else
{
    var overzichtWanden = actieveWand is null
        ? State.Wanden
        : State.Wanden.Where(wand => wand.Id != actieveWand.Id).ToList();

    @if (actieveWand is null)
    {
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
            <div>
                <h5 class="mb-1">Wandenoverzicht</h5>
            </div>
        </div>

        <div class="row g-3 mb-4">
            @foreach (var wand in overzichtWanden)
            {
                var wandKasten = State.KastenVoorWand(wand.Id);
                var wandApparaten = State.ApparatenVoorWand(wand.Id);
                var gevuldeBreedte = wand.TotaleBreedte(State.Kasten);
                var vrijeBreedte = Math.Max(0, wand.Breedte - gevuldeBreedte);

                <div class="col-xl-6"
                     @key="wand.Id">
                    <div class="card h-100 indeling-wand-samenvatting"
                         data-testid="indeling-wand-card"
                         data-wand-id="@wand.Id"
                         data-wand-naam="@wand.Naam">
                        <div class="card-body indeling-wand-samenvatting-body">
                            <div class="indeling-wand-samenvatting-inhoud">
                                <div class="d-flex flex-wrap align-items-center gap-2 indeling-wand-samenvatting-kop">
                                    <h5 class="mb-0">@wand.Naam</h5>
                                    @if (wandKasten.Count > 0)
                                    {
                                        <span class="badge text-bg-light">@wandKasten.Count kast(en)</span>
                                    }
                                    @if (wandApparaten.Count > 0)
                                    {
                                        <span class="badge text-bg-light">@wandApparaten.Count apparaat(en)</span>
                                    }
                                    <span class="badge text-bg-light">@wand.Breedte mm</span>
                                </div>
                                <div class="small text-muted">
                                    @gevuldeBreedte mm ingevuld · @vrijeBreedte mm vrije wandruimte
                                </div>
                            </div>

                            <div class="indeling-wand-samenvatting-acties">
                                <button class="btn btn-primary btn-sm"
                                        @onclick="() => OpenWandWerkruimte(wand.Id)"
                                        data-testid="open-wand-workspace-button"
                                        data-wand-id="@wand.Id">
                                    Open wand
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (State.HeeftProjectInhoud())
        {
            <details class="indeling-overige-wanden mb-4" data-testid="indeling-project-acties-details">
                <summary class="indeling-overige-wanden-summary" data-testid="indeling-project-acties-summary">
                    <div>
                        <h5 class="mb-0">Projectacties</h5>
                        <div class="small text-muted">Verborgen zodat wissen niet concurreert met het kiezen of bewerken van een wand.</div>
                    </div>
                </summary>
                <div class="indeling-overige-wanden-body">
                    @if (bevestigWisAlles)
                    {
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <span class="text-danger small fw-semibold">Hele keuken wissen? Alle wanden, kasten, panelen en apparaten worden teruggezet.</span>
                            <button class="btn btn-sm btn-danger" @onclick="WisAllesAsync">Ja, wis alles</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => bevestigWisAlles = false">Annuleren</button>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                            <p class="small text-muted mb-0">Gebruik dit alleen als u de hele keuken opnieuw wilt beginnen.</p>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => bevestigWisAlles = true">
                                Wis hele keuken
                            </button>
                        </div>
                    }
                </div>
            </details>
        }
    }

    @if (actieveWand is not null)
    {
        var wandKasten = State.KastenVoorWand(actieveWand.Id);
        var wandApparaten = State.ApparatenVoorWand(actieveWand.Id);
        var gevuldeBreedte = actieveWand.TotaleBreedte(State.Kasten);
        var vrijeBreedte = Math.Max(0, actieveWand.Breedte - gevuldeBreedte);
        var toonPrimaireActies = !toonKastFormulier && !toonApparaatFormulier;
        var toonWandOpstelling = wandKasten.Count > 0 || wandApparaten.Count > 0;

        <div class="card border-0 shadow-sm mb-4 indeling-actieve-werkruimte"
             data-testid="actieve-wand-werkruimte"
             data-wand-id="@actieveWand.Id"
             data-wand-naam="@actieveWand.Naam">
            <div class="card-body">
                <div class="indeling-workspace-header mb-3">
                    <div>
                        <div class="indeling-workspace-kicker">Actieve wand</div>
                        <h5 class="mb-1">@actieveWand.Naam</h5>
                        <div class="stap-meta-list">
                            <span>@wandKasten.Count kast(en)</span>
                            @if (wandApparaten.Count > 0)
                            {
                                <span>@wandApparaten.Count apparaat(en)</span>
                            }
                            <span>@gevuldeBreedte mm ingevuld</span>
                            <span>@vrijeBreedte mm vrij</span>
                        </div>
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="SluitWandWerkruimte">
                            Werkruimte sluiten
                        </button>
                    </div>
                </div>

                @if (toonPrimaireActies)
                {
                    <div class="indeling-werkstap mb-4">
                        <div>
                            <div class="small fw-semibold text-uppercase text-muted mb-1">Nu doen</div>
                            <div class="fw-semibold">@(wandKasten.Count == 0 ? "Voeg eerst de eerste kast toe." : "Werk alleen bij wat op deze wand nu nog ontbreekt.")</div>
                            <div class="small text-muted">@(wandKasten.Count == 0 ? "Gebruik een apparaat pas zodra het echt wandruimte of de vrije opening verandert." : "Laat secundaire acties dicht en open alleen het formulier dat u nu nodig hebt.")</div>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-primary"
                                    @onclick="() => OpenKastFormulier(actieveWand.Id)"
                                    data-testid="open-kast-form-button"
                                    data-wand-id="@actieveWand.Id">
                                Kast toevoegen
                            </button>
                            <button class="btn btn-outline-secondary btn-sm"
                                    @onclick="() => OpenApparaatFormulier(actieveWand.Id)"
                                    data-testid="open-apparaat-form-button"
                                    data-wand-id="@actieveWand.Id">
                                Apparaat toevoegen
                            </button>
                        </div>
                    </div>
                }

                <div class="indeling-workspace-grid mb-4">
                    <div class="indeling-workspace-main">
                        <div class="indeling-maten-kaart">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3 flex-wrap">
                                <div>
                                    <h6 class="mb-1">Wandmaten</h6>
                                    <div class="small text-muted">Pas dit alleen aan als de basismaten van deze wand wijzigen.</div>
                                </div>
                                <div class="small text-muted">@actieveWand.Breedte × @actieveWand.Hoogte mm · plint @actieveWand.PlintHoogte mm</div>
                            </div>
                            <div class="row g-3">
                                <div class="col-sm-4">
                                    <label class="form-label small mb-0">Wandbreedte (mm)</label>
                                    <input type="number" class="form-control form-control-sm"
                                           data-testid="wand-breedte-input"
                                           value="@actieveWand.Breedte" @onchange="e => WijzigWandAfmeting(actieveWand, nameof(KeukenWand.Breedte), e)" />
                                    <div class="form-text hulp-hint mb-0" data-testid="wand-breedte-hint">Totaal van deze wand, bijvoorbeeld 3000.</div>
                                </div>
                                <div class="col-sm-4">
                                    <label class="form-label small mb-0">Wandhoogte (mm)</label>
                                    <input type="number" class="form-control form-control-sm"
                                           data-testid="wand-hoogte-input"
                                           value="@actieveWand.Hoogte" @onchange="e => WijzigWandAfmeting(actieveWand, nameof(KeukenWand.Hoogte), e)" />
                                    <div class="form-text hulp-hint mb-0" data-testid="wand-hoogte-hint">Vrije hoogte van vloer tot plafond, bijvoorbeeld 2600.</div>
                                </div>
                                <div class="col-sm-4">
                                    <label class="form-label small mb-0">Plinthoogte (mm)</label>
                                    <input type="number" class="form-control form-control-sm" min="0" step="10"
                                           data-testid="wand-plint-input"
                                           value="@actieveWand.PlintHoogte" @onchange="e => WijzigWandAfmeting(actieveWand, nameof(KeukenWand.PlintHoogte), e)" />
                                    <div class="form-text hulp-hint mb-0" data-testid="wand-plint-hint">Meestal 100; gebruik 0 alleen zonder plint.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (toonWandOpstelling)
                    {
                        <div class="indeling-visualisatie-kaart">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    <h6 class="mb-0">Wandopstelling</h6>
                                    <div class="small text-muted">Live controle van maat, volgorde en vrije ruimte.</div>
                                </div>
                            </div>
                            <WandOpstelling Kasten="@wandKasten"
                                            Apparaten="@wandApparaten"
                                            WandHoogte="@actieveWand.Hoogte"
                                            WandBreedte="@actieveWand.Breedte"
                                            PlintHoogte="@actieveWand.PlintHoogte"
                                             GeselecteerdeKastId="@(actieveWandId == actieveWand.Id ? bewerkKastId : null)"
                                             OnKastGeselecteerd="(id) => SelecteerKast(id, actieveWand.Id)"
                                              OnKastVerplaatst="VerplaatsKastOpWand"
                                              OnKastKopieren="KopieerNaarKlembord"
                                              OnKastPlakken="() => PlakUitKlembord(actieveWand.Id)"
                                              OnApparaatVerplaatst="VerplaatsApparaatOpWand"
                                              OnPlankActie="VerwerkPlankActie" />
                        </div>
                    }
                </div>

                <section class="indeling-lijst-sectie mb-4">
                    <div class="indeling-lijst-kop">
                        <div>
                            <h6 class="mb-1">Kasten op deze wand</h6>
                            <div class="small text-muted">Gebruik deze lijst vooral voor bewerken, dupliceren of verwijderen.</div>
                        </div>
                        <span class="text-muted small">@(wandKasten.Count == 0 ? "Nog geen kasten" : $"{wandKasten.Count} toegevoegd")</span>
                    </div>
                    @if (wandKasten.Count > 0)
                    {
                        <div class="indeling-object-lijst">
                            @foreach (var kast in wandKasten)
                            {
                                <div class="indeling-object-rij @(bewerkKastId == kast.Id && actieveWandId == actieveWand.Id ? "is-active" : null)">
                                    <div class="indeling-object-meta">
                                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                            <span class="badge @TypeBadge(kast.Type)">@kast.Type</span>
                                            <span class="fw-semibold">@kast.Naam</span>
                                        </div>
                                        <div class="small text-muted">@kast.Breedte × @kast.Hoogte mm</div>
                                    </div>
                                    @if (bevestigVerwijderKastId == kast.Id)
                                    {
                                        <div class="indeling-object-confirmatie">
                                            <span class="text-danger small fw-semibold">Verwijderen?</span>
                                            <button class="btn btn-danger btn-sm"
                                                    @onclick="() => { VerwijderKast(kast.Id); bevestigVerwijderKastId = null; }">Ja</button>
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    @onclick="() => bevestigVerwijderKastId = null">Annuleer</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="indeling-object-acties">
                                            <button class="btn btn-outline-primary btn-sm"
                                                    @onclick="() => BewerkKast(kast, actieveWand.Id)">
                                                Bewerk
                                            </button>
                                            <details class="indeling-row-details">
                                                <summary class="small fw-semibold text-secondary">Meer acties</summary>
                                                <div class="indeling-row-details-body">
                                                    <button class="btn btn-outline-secondary btn-sm"
                                                            @onclick="() => KopieerKast(kast, actieveWand.Id)">
                                                        Kopieer
                                                    </button>
                                                    <button class="btn btn-outline-danger btn-sm"
                                                            @onclick="() => bevestigVerwijderKastId = kast.Id">
                                                        Verwijder
                                                    </button>
                                                </div>
                                            </details>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="border rounded p-3 small text-muted bg-body-tertiary">
                            Nog geen kasten. Begin met <strong>Kast toevoegen</strong>.
                        </div>
                    }
                </section>

                @if (wandApparaten.Count > 0)
                {
                    <details class="indeling-overige-wanden mb-4"
                             open="@((bewerkApparaatId is not null && actieveWandId == actieveWand.Id) || bevestigVerwijderApparaatId is not null)">
                        <summary class="indeling-overige-wanden-summary">
                            <div>
                                <h5 class="mb-0">Apparaten op deze wand</h5>
                                <div class="small text-muted">Open dit alleen als een apparaat de indeling van deze wand echt raakt.</div>
                            </div>
                            <span class="badge text-bg-light indeling-workspace-hint">@wandApparaten.Count toegevoegd</span>
                        </summary>
                        <div class="indeling-overige-wanden-body">
                            <div class="indeling-object-lijst">
                                @foreach (var apparaat in wandApparaten)
                                {
                                    <div class="indeling-object-rij @(bewerkApparaatId == apparaat.Id && actieveWandId == actieveWand.Id ? "is-active" : null)">
                                        <div class="indeling-object-meta">
                                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                                <span class="badge bg-secondary">@ApparaatTypeLabel(apparaat.Type)</span>
                                                <span class="fw-semibold">@apparaat.Naam</span>
                                            </div>
                                            <div class="small text-muted">@apparaat.Breedte × @apparaat.Hoogte mm</div>
                                        </div>
                                        @if (bevestigVerwijderApparaatId == apparaat.Id)
                                        {
                                            <div class="indeling-object-confirmatie">
                                                <span class="text-danger small fw-semibold">Verwijderen?</span>
                                                <button class="btn btn-danger btn-sm"
                                                        @onclick="() => { VerwijderApparaat(apparaat.Id); bevestigVerwijderApparaatId = null; }">Ja</button>
                                                <button class="btn btn-outline-secondary btn-sm"
                                                        @onclick="() => bevestigVerwijderApparaatId = null">Annuleer</button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="indeling-object-acties">
                                                <button class="btn btn-outline-primary btn-sm"
                                                        @onclick="() => BewerkApparaat(apparaat, actieveWand.Id)">
                                                    Bewerk
                                                </button>
                                                <details class="indeling-row-details">
                                                    <summary class="small fw-semibold text-secondary">Meer acties</summary>
                                                    <div class="indeling-row-details-body">
                                                        <button class="btn btn-outline-danger btn-sm"
                                                                @onclick="() => bevestigVerwijderApparaatId = apparaat.Id">
                                                            Verwijder
                                                        </button>
                                                    </div>
                                                </details>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </details>
                }

                <details class="indeling-overige-wanden mb-4 indeling-workspace-actions"
                         open="@(bewerkWandId == actieveWand.Id || bevestigVerwijderWandId == actieveWand.Id)">
                    <summary class="indeling-overige-wanden-summary">
                        <div>
                            <h5 class="mb-0">Meer acties voor deze wand</h5>
                            <div class="small text-muted">Open dit alleen voor hernoemen of verwijderen buiten de hoofdtaak.</div>
                        </div>
                    </summary>
                    <div class="indeling-overige-wanden-body">
                        <p class="text-muted small mb-3">Zelden gebruikte of destructieve acties staan hier zodat de hoofdtaak op deze wand rustig blijft.</p>

                        @if (bewerkWandId == actieveWand.Id)
                        {
                            <div class="d-flex flex-wrap gap-2">
                                <input type="text" class="form-control form-control-sm" style="max-width: 280px;" @bind="bewerkWandNaam" @bind:event="oninput" />
                                <button class="btn btn-sm btn-outline-primary" @onclick="WandNaamOpslaan">Opslaan</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => bewerkWandId = null">Annuleren</button>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-wrap gap-2">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => { bewerkWandId = actieveWand.Id; bewerkWandNaam = actieveWand.Naam; }">
                                    Wand hernoemen
                                </button>
                                @if (bevestigVerwijderWandId == actieveWand.Id)
                                {
                                    <span class="text-danger small fw-semibold align-self-center">Wand verwijderen?</span>
                                    <button class="btn btn-sm btn-danger" @onclick="() => BevestigVerwijderWand(actieveWand.Id)">Ja, verwijder</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => bevestigVerwijderWandId = null">Annuleren</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => bevestigVerwijderWandId = actieveWand.Id">
                                        Wand verwijderen
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </details>
            </div>
        </div>

        <div class="indeling-workspace-secondary">
            @if (overzichtWanden.Count > 0)
            {
                <details class="indeling-overige-wanden mb-4"
                         data-testid="indeling-overige-wanden-details">
                    <summary class="indeling-overige-wanden-summary"
                             data-testid="indeling-overige-wanden-summary">
                        <div>
                            <h5 class="mb-0">Andere wanden</h5>
                            <div class="small text-muted">Open alleen als u bewust naar een andere wand wilt wisselen.</div>
                        </div>
                        <span class="badge text-bg-light indeling-workspace-hint">@overzichtWanden.Count wand(en) beschikbaar</span>
                    </summary>
                    <div class="indeling-overige-wanden-body">
                        <div class="indeling-overige-wanden-lijst">
                            @foreach (var wand in overzichtWanden)
                            {
                                var overigeWandKasten = State.KastenVoorWand(wand.Id);
                                var overigeWandApparaten = State.ApparatenVoorWand(wand.Id);
                                var overigeGevuldeBreedte = wand.TotaleBreedte(State.Kasten);
                                var overigeVrijeBreedte = Math.Max(0, wand.Breedte - overigeGevuldeBreedte);

                                <div class="indeling-overige-wand-schakelaar"
                                     data-testid="indeling-wand-card"
                                     data-wand-id="@wand.Id"
                                     data-wand-naam="@wand.Naam"
                                     @key="wand.Id">
                                    <div class="indeling-overige-wand-inhoud">
                                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                            <h6 class="mb-0">@wand.Naam</h6>
                                            <span class="badge text-bg-light">@overigeWandKasten.Count kast(en)</span>
                                            @if (overigeWandApparaten.Count > 0)
                                            {
                                                <span class="badge text-bg-light">@overigeWandApparaten.Count apparaat(en)</span>
                                            }
                                        </div>
                                        <div class="small text-muted">
                                            @overigeGevuldeBreedte mm ingevuld · @overigeVrijeBreedte mm vrij · @wand.Breedte mm wandbreedte
                                        </div>
                                    </div>
                                    <button class="btn btn-outline-primary btn-sm"
                                            @onclick="() => OpenWandWerkruimte(wand.Id)"
                                            data-testid="open-wand-workspace-button"
                                            data-wand-id="@wand.Id">
                                        Open wand
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </details>
            }

            <details class="indeling-overige-wanden mb-4" data-testid="indeling-extra-wand-details">
                <summary class="indeling-overige-wanden-summary" data-testid="indeling-extra-wand-summary">
                    <div>
                        <h5 class="mb-0">Nog een wand toevoegen</h5>
                        <div class="small text-muted">Open dit pas als deze werkruimte voorlopig klopt.</div>
                    </div>
                </summary>
                <div class="indeling-overige-wanden-body">
                    <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
                        <div class="small text-muted">Gebruik de pop-up om een extra wandnaam toe te voegen zonder de werkruimte onrustig te maken.</div>
                        <div class="d-flex justify-content-xl-end">
                            <button type="button"
                                    class="btn btn-primary"
                                    @onclick="OpenWandToevoegenModal"
                                    data-testid="open-wand-toevoegen-modal-button">
                                Wand toevoegen
                            </button>
                        </div>
                    </div>
                </div>
            </details>

            <details class="indeling-overige-wanden mb-4" data-testid="indeling-project-acties-details">
                <summary class="indeling-overige-wanden-summary" data-testid="indeling-project-acties-summary">
                    <div>
                        <h5 class="mb-0">Projectacties</h5>
                        <div class="small text-muted">Open dit alleen voor zeldzame of destructieve acties buiten deze wand.</div>
                    </div>
                </summary>
                <div class="indeling-overige-wanden-body">
                    @if (bevestigWisAlles)
                    {
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <span class="text-danger small fw-semibold">Hele keuken wissen? Alle wanden, kasten, panelen en apparaten worden teruggezet.</span>
                            <button class="btn btn-sm btn-danger" @onclick="WisAllesAsync">Ja, wis alles</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => bevestigWisAlles = false">Annuleren</button>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                            <p class="small text-muted mb-0">Gebruik dit alleen als u de hele keuken opnieuw wilt beginnen.</p>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => bevestigWisAlles = true">
                                Wis hele keuken
                            </button>
                        </div>
                    }
                </div>
            </details>
        </div>
    }
}

@if (toonWandToevoegenModal)
{
    <div class="wand-toevoegen-modal-overlay"
         @onclick="SluitWandToevoegenModal"
         data-testid="wand-toevoegen-modal-overlay">
        <div class="wand-toevoegen-modal card border-0 shadow-lg"
             role="dialog"
             aria-modal="true"
             aria-labelledby="wand-toevoegen-modal-title"
             data-testid="wand-toevoegen-modal"
             @onclick:stopPropagation="true">
            <div class="card-header bg-primary bg-opacity-10 border-bottom">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <div class="text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Werkruimte toevoegen</div>
                        <h5 class="mb-1" id="wand-toevoegen-modal-title">Wand toevoegen</h5>
                        <p class="text-muted mb-0">Geef de nieuwe wand een herkenbare naam. Die naam blijft zichtbaar in overzichten en vervolgstappen.</p>
                    </div>
                    <button type="button" class="btn-close" @onclick="SluitWandToevoegenModal" aria-label="Sluit wand toevoegen"></button>
                </div>
            </div>
            <div class="card-body">
                <label class="form-label fw-semibold" for="wand-toevoegen-modal-input">Wandnaam</label>
                <input id="wand-toevoegen-modal-input"
                       type="text"
                       class="form-control"
                       @bind="nieuweWandNaam"
                       @bind:event="oninput"
                       @onkeydown="WandToevoegenBijEnter"
                       data-testid="nieuwe-wand-naam-input"
                       autofocus />
                <div class="form-text hulp-hint" data-testid="nieuwe-wand-naam-hint">Bijvoorbeeld Achterwand, Linkerwand of Eilandzijde.</div>
            </div>
            <div class="card-footer bg-body d-flex justify-content-end gap-2">
                <button type="button"
                        class="btn btn-outline-secondary"
                        @onclick="SluitWandToevoegenModal"
                        data-testid="wand-toevoegen-annuleren-button">
                    Annuleren
                </button>
                <button type="button"
                        class="btn btn-primary"
                        @onclick="WandToevoegen"
                        disabled="@string.IsNullOrWhiteSpace(nieuweWandNaam)"
                        data-testid="wand-toevoegen-button">
                    Wand toevoegen
                </button>
            </div>
        </div>
    </div>
}

@* ──── Kast formulier (overlay) ──── *@
@if (toonKastFormulier && actieveWandId is not null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-start"
         style="z-index: 1050; background: rgba(0,0,0,0.4); overflow-y: auto; padding: 2rem 1rem;"
         @onclick="SluitKastFormulier" @onclick:stopPropagation="false">
        <div class="card border-success shadow-lg"
             style="max-width: 900px; width: 100%;"
             data-testid="kast-form"
             @onclick:stopPropagation="true">
            <div class="card-header bg-success bg-opacity-10 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@(isBewerken ? "Kast bewerken" : "Kast toevoegen")</h5>
                <button type="button" class="btn-close" @onclick="SluitKastFormulier"></button>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="small fw-semibold text-uppercase text-success-emphasis">Huidige stap</div>
                        <div class="h6 mb-1" data-testid="kast-form-stap-label">Stap @kastFormStap van @LaatsteKastFormStap: @KastFormStapLabel(kastFormStap)</div>
                        <p class="text-muted small mb-0">@KastFormStapIntro(kastFormStap)</p>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge text-bg-light" data-testid="kast-form-progress">Stap @kastFormStap/@LaatsteKastFormStap</span>
                        <StapHulpDrawer StapId="kasten" KnopLabel="Meer hulp" />
                    </div>
                </div>

                @if (kastFormStap == 1)
                {
                    @if (!isBewerken && State.KastTemplates.Count > 0)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-muted small">Eerder gebruikte kasten</label>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var template in State.KastTemplates.OrderByDescending(t => t.LaatstGebruikt))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary"
                                            @onclick="() => VulFormulierVanTemplate(template)"
                                            title="@template.Naam · @template.Breedte×@template.Hoogte×@template.Diepte mm">
                                        <span class="badge @TypeBadge(template.Type) me-1">@template.Type</span>
                                        @template.Naam
                                        <small class="text-muted ms-1">@template.Breedte×@template.Hoogte</small>
                                    </button>
                                }
                            </div>
                        </div>
                        <hr class="my-2" />
                    }

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Wand</label>
                            <select class="form-select"
                                    value="@actieveWandId"
                                    @onchange="OnWandGewijzigd"
                                    data-testid="kast-wand-select">
                                @foreach (var w in State.Wanden)
                                {
                                    <option value="@w.Id">@w.Naam</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Naam</label>
                            <input type="text" class="form-control" @bind="formKast.Naam" @bind:event="oninput"
                                   data-testid="kast-naam-input" />
                            <div class="form-text hulp-hint" data-testid="kast-naam-hint">Bijvoorbeeld Onderkast spoelbak. Kies een naam die u later in panelen en bestellijst snel herkent.</div>
                        </div>
                    </div>
                }
                else if (kastFormStap == 2)
                {
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Breedte (mm)</label>
                            <input type="number" class="form-control" @bind="formKast.Breedte" min="100" step="10"
                                    data-testid="kast-breedte-input" />
                            <div class="form-text hulp-hint" data-testid="kast-breedte-hint">Bijvoorbeeld 600. Gebruik de buitenmaat van de kastbreedte.</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Hoogte (mm)</label>
                            <input type="number" class="form-control" @bind="formKast.Hoogte" @bind:after="AutoBerekenPosities" min="100" step="10"
                                    data-testid="kast-hoogte-input" />
                            <div class="form-text hulp-hint" data-testid="kast-hoogte-hint">Bijvoorbeeld 720 voor een onderkast of rond 2000 voor een hoge kast.</div>
                            <div class="form-text">Type: <span class="badge @TypeBadge(InferKastType(formKast.Hoogte))">@InferKastType(formKast.Hoogte)</span></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Diepte (mm)</label>
                            <input type="number" class="form-control" @bind="formKast.Diepte" min="100" step="10"
                                    data-testid="kast-diepte-input" />
                            <div class="form-text hulp-hint" data-testid="kast-diepte-hint">Bijvoorbeeld 560. Gebruik de buitendiepte van de kastromp.</div>
                        </div>
                    </div>

                    <div class="small text-muted mb-0">
                        U vult hier alleen de hoofdmaten in. Technische gaatjesrij en afwijkende kastdetails komen pas in de volgende stap in beeld.
                    </div>
                }
                else if (kastFormStap == 3)
                {
                    <div class="card border-0 bg-body-tertiary mb-3">
                        <div class="card-body">
                            <button type="button"
                                    class="btn btn-outline-secondary w-100 d-flex justify-content-between align-items-center gap-3"
                                    @onclick="ToggleTechnischeInstellingen">
                                <span class="text-start">
                                    <span class="d-block fw-semibold">Afwijkende gaatjesrij of kastdetails</span>
                                    <span class="small text-muted">Open alleen als deze kast afwijkt van de standaard voor wanddikte, systeemgaten of planken.</span>
                                </span>
                                <span class="fs-5" aria-hidden="true">@(toonTechnischeInstellingen ? "−" : "+")</span>
                            </button>

                            @if (toonTechnischeInstellingen)
                            {
                                    <div class="mt-3">
                                        <div class="row g-3 mb-3">
                                            <div class="col-md-4">
                                                <div class="d-flex align-items-center gap-2 mb-1">
                                                    <label class="form-label mb-0">Dikte van de kastwand (mm)</label>
                                                    <HulpInfoKnop Titel="Dikte van de kastwand"
                                                                  Tekst="Gebruik hier de werkelijke dikte van de zijplaten van deze kast. Die maat heeft invloed op systeemgaten en scharnieronderdelen."
                                                                  Voorbeeld="Standaard is dit meestal 18 mm."
                                                                  WatNuDoen="Laat de standaard staan tenzij deze kast met een andere plaatdikte wordt gebouwd." />
                                                </div>
                                                <input type="number" class="form-control" @bind="formKast.Wanddikte" @bind:after="AutoBerekenPosities" min="1" step="1" />
                                                <div class="form-text hulp-hint">Gebruik alleen een afwijkende waarde als het materiaal van deze kast echt dikker of dunner is.</div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="d-flex align-items-center gap-2 mb-1">
                                                    <label class="form-label mb-0">Afstand tussen systeemgaten (mm)</label>
                                                    <HulpInfoKnop Titel="Rij systeemgaten"
                                                                  Tekst="Dit is de vaste steek van de gatenrij in de kastzijwand. Die bepaalt waar de montageplaat en andere boringen uitkomen."
                                                                  Voorbeeld="Voor veel keukenkasten is 32 mm de standaard."
                                                                  WatNuDoen="Pas dit alleen aan als deze kast een andere gatensteek gebruikt dan de standaard." />
                                                </div>
                                                <input type="number" class="form-control" @bind="formKast.GaatjesAfstand" @bind:after="AutoBerekenPosities" min="1" step="1" />
                                                <div class="form-text hulp-hint">De standaard gatensteek is meestal 32 mm.</div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="d-flex align-items-center gap-2 mb-1">
                                                    <label class="form-label mb-0">Afstand onderkant bovenplank tot eerste gat (mm)</label>
                                                    <HulpInfoKnop Titel="Eerste gat vanaf de bovenste plank"
                                                                  Tekst="Deze maat bepaalt waar de eerste positie van de systeemgaten start ten opzichte van de bovenkant van de kastromp."
                                                                  Voorbeeld="Bij veel kasten is dit 19 mm vanaf de onderkant van de bovenste plank."
                                                                  WatNuDoen="Controleer deze maat alleen als uw leverancier of bestaand kasttype van de standaard afwijkt." />
                                                </div>
                                                <input type="number" class="form-control" @bind="formKast.EersteGaatVanBoven" @bind:after="AutoBerekenPosities" min="1" step="1" />
                                                <div class="form-text hulp-hint">Meet vanaf de onderkant van de bovenste plank naar het eerste gat.</div>
                                            </div>
                                        </div>

                                    <p class="text-muted small mb-0"><em>Tip: dubbelklik in de wandopstelling om een plank toe te voegen. Sleep planken of gebruik de pijltjestoetsen. Selecteer een plank en druk Delete om hem te verwijderen.</em></p>
                                </div>
                            }
                            else
                            {
                                <div class="small text-muted mt-3 mb-0">
                                    Deze kast gebruikt de standaard voor wanddikte, systeemgaten en eerste gat vanaf de bovenste plank. U kunt direct doorgaan naar de controle.
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="row g-4 align-items-start">
                        <div class="col-lg-6">
                            <div class="card border-0 bg-body-tertiary h-100">
                                <div class="card-body">
                                    <h6 class="mb-3">Controle voor opslaan</h6>
                                    <dl class="row mb-0 small">
                                        <dt class="col-sm-4">Wand</dt>
                                        <dd class="col-sm-8">@ActieveWandNaam()</dd>

                                        <dt class="col-sm-4">Naam</dt>
                                        <dd class="col-sm-8">@formKast.Naam</dd>

                                        <dt class="col-sm-4">Type</dt>
                                        <dd class="col-sm-8"><span class="badge @TypeBadge(InferKastType(formKast.Hoogte))">@InferKastType(formKast.Hoogte)</span></dd>

                                        <dt class="col-sm-4">Maten</dt>
                                        <dd class="col-sm-8">@formKast.Breedte × @formKast.Hoogte × @formKast.Diepte mm</dd>

                                        <dt class="col-sm-4">Techniek</dt>
                                        <dd class="col-sm-8">
                                            @if (toonTechnischeInstellingen)
                                            {
                                                <span>Afwijkend: @formKast.Wanddikte mm wanddikte, @formKast.GaatjesAfstand mm systeemgaten, @formKast.EersteGaatVanBoven mm eerste gat</span>
                                            }
                                            else
                                            {
                                                <span>Standaard gaatjesrij en kastdetails</span>
                                            }
                                        </dd>
                                    </dl>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="text-center">
                                <KastVisueel Kast="@formKast" MaxHoogte="180" />
                            </div>
                        </div>
                    </div>
                }

                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-4">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            @onclick="VorigeKastFormStap"
                            disabled="@(kastFormStap == 1)"
                            data-testid="kast-form-terug-button">
                        Terug
                    </button>
                    <div class="d-flex gap-2">
                        @if (kastFormStap < LaatsteKastFormStap)
                        {
                            <button type="button"
                                    class="btn btn-primary"
                                    @onclick="VolgendeKastFormStap"
                                    disabled="@(!KanNaarVolgendeKastStap())"
                                    data-testid="kast-form-volgende-button">
                                Volgende stap
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary" @onclick="KastOpslaan"
                                    disabled="@string.IsNullOrWhiteSpace(formKast.Naam)"
                                    data-testid="kast-opslaan-button">
                                @(isBewerken ? "Opslaan" : "Kast toevoegen")
                            </button>
                        }
                        <button type="button" class="btn btn-outline-secondary" @onclick="SluitKastFormulier">
                            Annuleren
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ──── Apparaat formulier (overlay) ──── *@
@if (toonApparaatFormulier && actieveWandId is not null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-start"
         style="z-index: 1050; background: rgba(0,0,0,0.4); overflow-y: auto; padding: 2rem 1rem;"
         @onclick="SluitApparaatFormulier" @onclick:stopPropagation="false">
        <div class="card border-secondary shadow-lg" style="max-width: 600px; width: 100%;"
             data-testid="apparaat-form"
             @onclick:stopPropagation="true">
            <div class="card-header bg-secondary bg-opacity-10 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@(isApparaatBewerken ? "Apparaat bewerken" : "Apparaat toevoegen")</h5>
                <button type="button" class="btn-close" @onclick="SluitApparaatFormulier"></button>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="small fw-semibold text-uppercase text-secondary-emphasis">Huidige stap</div>
                        <div class="h6 mb-1" data-testid="apparaat-form-stap-label">Stap @apparaatFormStap van @LaatsteApparaatFormStap: @ApparaatFormStapLabel(apparaatFormStap)</div>
                        <p class="text-muted small mb-0">@ApparaatFormStapIntro(apparaatFormStap)</p>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge text-bg-light" data-testid="apparaat-form-progress">Stap @apparaatFormStap/@LaatsteApparaatFormStap</span>
                        <StapHulpDrawer StapId="kasten" KnopLabel="Meer hulp" />
                    </div>
                </div>

                @if (apparaatFormStap == 1)
                {
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Wand</label>
                            <div class="form-control bg-body-tertiary">@ActieveWandNaam()</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Type</label>
                            <select class="form-select" value="@formApparaat.Type" @onchange="OnApparaatTypeGewijzigd">
                                @foreach (var t in Enum.GetValues<ApparaatType>())
                                {
                                    <option value="@t">@ApparaatTypeLabel(t)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Naam</label>
                            <input type="text" class="form-control" @bind="formApparaat.Naam" @bind:event="oninput"
                                   data-testid="apparaat-naam-input" />
                            <div class="form-text hulp-hint" data-testid="apparaat-naam-hint">Bijvoorbeeld Oven Bosch. Noem merk of functie zodat u het apparaat later in de wand en bestellijst herkent.</div>
                        </div>
                    </div>
                }
                else if (apparaatFormStap == 2)
                {
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Breedte (mm)</label>
                            <input type="number" class="form-control" @bind="formApparaat.Breedte" min="100" step="10"
                                   data-testid="apparaat-breedte-input" />
                            <div class="form-text hulp-hint" data-testid="apparaat-breedte-hint">Bijvoorbeeld 600. Gebruik de maat die echt wandruimte inneemt.</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Hoogte (mm)</label>
                            <input type="number" class="form-control" @bind="formApparaat.Hoogte" min="10" step="10"
                                   data-testid="apparaat-hoogte-input" />
                            <div class="form-text hulp-hint" data-testid="apparaat-hoogte-hint">Bijvoorbeeld 590 voor een inbouwoven of hoger voor een koelkastkastmodule.</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Diepte (mm)</label>
                            <input type="number" class="form-control" @bind="formApparaat.Diepte" min="100" step="10"
                                   data-testid="apparaat-diepte-input" />
                            <div class="form-text hulp-hint" data-testid="apparaat-diepte-hint">Bijvoorbeeld 560. Gebruik de werkelijke diepte van het apparaat of de nis die het vraagt.</div>
                        </div>
                    </div>

                    <div class="small text-muted mb-0">
                        U beslist hier alleen over de hoofdafmetingen. De controle met voorvertoning volgt in de laatste stap.
                    </div>
                }
                else
                {
                    <div class="row g-4 align-items-start">
                        <div class="col-md-6">
                            <div class="card border-0 bg-body-tertiary h-100">
                                <div class="card-body">
                                    <h6 class="mb-3">Controle voor opslaan</h6>
                                    <dl class="row mb-0 small">
                                        <dt class="col-sm-4">Wand</dt>
                                        <dd class="col-sm-8">@ActieveWandNaam()</dd>

                                        <dt class="col-sm-4">Type</dt>
                                        <dd class="col-sm-8">@ApparaatTypeLabel(formApparaat.Type)</dd>

                                        <dt class="col-sm-4">Naam</dt>
                                        <dd class="col-sm-8">@formApparaat.Naam</dd>

                                        <dt class="col-sm-4">Maten</dt>
                                        <dd class="col-sm-8">@formApparaat.Breedte × @formApparaat.Hoogte × @formApparaat.Diepte mm</dd>
                                    </dl>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-center mb-3">
                                <svg width="120" height="80" class="border rounded bg-light">
                                    <text x="60" y="20" font-size="24" text-anchor="middle">@ApparaatIcoon(formApparaat.Type)</text>
                                    <text x="60" y="45" font-size="10" text-anchor="middle" fill="#333">@ApparaatTypeLabel(formApparaat.Type)</text>
                                    <text x="60" y="60" font-size="9" text-anchor="middle" fill="#888">@formApparaat.Breedte×@formApparaat.Hoogte mm</text>
                                </svg>
                            </div>
                        </div>
                    </div>
                }

                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-4">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            @onclick="VorigeApparaatFormStap"
                            disabled="@(apparaatFormStap == 1)"
                            data-testid="apparaat-form-terug-button">
                        Terug
                    </button>
                    <div class="d-flex gap-2">
                        @if (apparaatFormStap < LaatsteApparaatFormStap)
                        {
                            <button type="button"
                                    class="btn btn-primary"
                                    @onclick="VolgendeApparaatFormStap"
                                    disabled="@(!KanNaarVolgendeApparaatStap())"
                                    data-testid="apparaat-form-volgende-button">
                                Volgende stap
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary" @onclick="ApparaatOpslaan"
                                    disabled="@string.IsNullOrWhiteSpace(formApparaat.Naam)">
                                @(isApparaatBewerken ? "Opslaan" : "Apparaat toevoegen")
                            </button>
                        }
                        <button type="button" class="btn btn-outline-secondary" @onclick="SluitApparaatFormulier">
                            Annuleren
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<StapNavigatie HuidigeStap="kasten"
               VolgendeHref="panelen"
               VolgendeDisabled="@(State.Kasten.Count == 0)" />
