@page "/"
@inject KeukenStateService State

<PageTitle>Keuken Inmeten</PageTitle>

@{
    var pagina = MaakPaginaModel();
}

<div class="container py-4 home-startflow">
    <section class="card border-0 shadow-sm mb-4 home-hero-card">
        <div class="card-body p-4 p-lg-5">
            <div class="row g-4 align-items-start">
                <div class="col-lg-7">
                    <span class="badge rounded-pill text-bg-primary mb-3">@(pagina.HeeftProjectData ? "Project in uitvoering" : "Start hier")</span>
                    <h1 class="@(pagina.HeeftProjectData ? "display-6" : "display-5") fw-bold mb-3">
                        @(pagina.HeeftProjectData
                            ? "Ga verder met uw keukenproject"
                            : "Van keukenmaat naar paneel, 35 mm potscharniergaten en zaagplan")
                    </h1>
                    <p class="lead text-muted mb-4">
                        @(pagina.HeeftProjectData
                            ? pagina.DashboardLead
                            : "Begin met wanden en kasten. Panelen, controle en uitvoer volgen daarna stap voor stap.")
                    </p>

                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <a href="@pagina.VervolgStap.Route" class="btn btn-primary btn-lg px-4">@StappenFlowHelper.MaakVolgendeLabel(pagina.VervolgStap.Id)</a>
                        @if (pagina.HeeftProjectData)
                        {
                            <a href="#project-overzicht" class="btn btn-link px-0 home-secondary-link">Projectdetails</a>
                        }
                        else
                        {
                            <a href="#startflow-stappen" class="btn btn-outline-secondary btn-lg px-4">Bekijk stappen</a>
                        }
                    </div>
                </div>

                <div class="col-lg-5">
                    @if (pagina.HeeftProjectData)
                    {
                        <div class="home-summary-card home-dashboard-card home-resume-card h-100" data-testid="home-project-dashboard">
                            <div class="small fw-semibold text-uppercase text-primary-emphasis mb-1">Volgende stap</div>
                            <h2 class="h5 mb-1">@pagina.VervolgStap.Label</h2>
                            <p class="text-muted small mb-3">@pagina.VervolgStap.Beschrijving</p>

                            <div class="home-resume-priority">
                                <div class="fw-semibold">@pagina.AandachtBlok.Titel</div>
                                <div class="text-muted small">@pagina.AandachtBlok.Tekst</div>
                            </div>

                            <div class="stap-meta-list home-resume-meta mt-3">
                                <span>@pagina.AantalWanden wanden</span>
                                <span>@pagina.AantalKasten kasten</span>
                                <span>@pagina.AantalPanelen panelen</span>
                                @if (pagina.AantalBestellijstItems > 0)
                                {
                                    <span>@pagina.AantalBestellijstItems orderregels</span>
                                }
                                else if (pagina.TotaalBoorgaten > 0)
                                {
                                    <span>@FormatPotscharnierGatTelling(pagina.TotaalBoorgaten)</span>
                                }
                            </div>

                            <div class="small text-muted mt-3">@pagina.BoorgatBlok.Tekst</div>
                        </div>
                    }
                    else
                    {
                        <div class="home-summary-card h-100">
                            <h2 class="h5 mb-3">Voor u start</h2>
                            <ul class="home-summary-list home-summary-list--compact">
                                <li class="home-summary-item">
                                    <span class="home-summary-icon">📐</span>
                                    <div>
                                        <strong>Meet wanden en kasten per wand</strong>
                                        <div class="text-muted small">Breedte, hoogte en positie vormen de basis van alle volgende stappen.</div>
                                    </div>
                                </li>
                                <li class="home-summary-item">
                                    <span class="home-summary-icon">🧩</span>
                                    <div>
                                        <strong>Voeg apparaten of planken alleen toe als ze echt iets veranderen</strong>
                                        <div class="text-muted small">Gebruik ze alleen als ze wandruimte, vrije opening of gatenrij beïnvloeden.</div>
                                    </div>
                                </li>
                                <li class="home-summary-item">
                                    <span class="home-summary-icon">🧾</span>
                                    <div>
                                        <strong>Daarna volgen controle en uitvoer</strong>
                                        <div class="text-muted small">Na paneeltoewijzing ziet u maten, 35 mm potscharniergaten, orderregels en plaatindeling terug.</div>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    @if (pagina.HeeftProjectData)
    {
        <section class="mb-4" id="project-overzicht">
            <details class="home-section-details">
                <summary class="home-section-summary">
                    <div class="home-section-summary-body">
                        <h2 class="h3 mb-1">Projectoverzicht</h2>
                        <p class="text-muted mb-0">Open dit alleen als u totalen of uitvoer nog even wilt dubbelchecken.</p>
                    </div>
                    <div class="home-section-summary-meta">@pagina.OutputSamenvatting</div>
                </summary>

                <div class="home-section-details-body">
                    <div class="row g-3">
                        <div class="col-sm-6 col-xl-3">
                            <div class="home-metric-card h-100">
                                <div class="home-example-label">Wanden</div>
                                <div class="home-metric-value">@pagina.AantalWanden</div>
                                <div class="text-muted small">Opstelling(en) die nu in het project staan.</div>
                            </div>
                        </div>
                        <div class="col-sm-6 col-xl-3">
                            <div class="home-metric-card h-100">
                                <div class="home-example-label">Kasten</div>
                                <div class="home-metric-value">@pagina.AantalKasten</div>
                                <div class="text-muted small">De basis voor panelen, openingen en scharnieren.</div>
                            </div>
                        </div>
                        <div class="col-sm-6 col-xl-3">
                            <div class="home-metric-card h-100">
                                <div class="home-example-label">Panelen</div>
                                <div class="home-metric-value">@pagina.AantalPanelen</div>
                                <div class="text-muted small">Toegewezen deuren, ladefronten of blindpanelen.</div>
                            </div>
                        </div>
                        <div class="col-sm-6 col-xl-3">
                            <div class="home-metric-card h-100">
                                <div class="home-example-label">Uitvoer klaar</div>
                                <div class="home-metric-value">@(pagina.AantalBestellijstItems > 0 ? pagina.AantalBestellijstItems : pagina.TotaalBoorgaten)</div>
                                <div class="text-muted small">@(pagina.AantalBestellijstItems > 0 ? "Orderregel(s) klaar voor export of zaagplan." : pagina.TotaalBoorgaten > 0 ? $"{FormatPotscharnierGatTelling(pagina.TotaalBoorgaten)} al berekend voor controle en bestelling." : "Nog geen exportdata; rond eerst panelen af.")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </details>
        </section>
    }

    <section class="mb-5" id="startflow-stappen">
        @if (pagina.HeeftProjectData)
        {
            <details class="home-section-details">
                <summary class="home-section-summary">
                    <div class="home-section-summary-body">
                        <h2 class="h3 mb-1">Andere projectroutes</h2>
                        <p class="text-muted mb-0">De hoofdactie hierboven is de snelste route. Open deze kaarten alleen als u bewust van stap wilt wisselen.</p>
                    </div>
                    <div class="home-section-summary-meta">Aanbevolen: @pagina.VervolgStap.Label</div>
                </summary>

                <div class="home-section-details-body">
                    <div class="row g-2">
                        @foreach (var stap in pagina.Stappen)
                        {
                            <div class="col-sm-6 col-xl" @key="stap.Href">
                                <a href="@stap.Href" class="home-card-link text-decoration-none text-reset d-block h-100">
                                    <article class="home-route-card h-100 @(stap.IsBeschikbaar ? null : "home-route-card--vergrendeld")">
                                        <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                                            <span class="home-step-number">@stap.Nummer</span>
                                            <span class="badge rounded-pill @stap.BadgeClass">@stap.BadgeLabel</span>
                                        </div>
                                        <div>
                                            <h3 class="h6 mb-1">@stap.Titel</h3>
                                            <div class="small text-muted">@stap.Samenvatting</div>
                                        </div>
                                    </article>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </details>
        }
        else
        {
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-2 mb-3">
                <div>
                    <h2 class="h3 mb-1">Zo verloopt de start</h2>
                    <p class="text-muted mb-0">De volgorde en labels hieronder zijn gelijk aan de rest van de applicatie.</p>
                </div>
                <div class="text-muted small">Vaste volgorde: @string.Join(" → ", StappenFlowHelper.AlleStappen.Select(stap => stap.Label))</div>
            </div>

            <div class="row g-3">
                @foreach (var stap in pagina.Stappen)
                {
                    <div class="col-md-6 col-xl">
                        <a href="@stap.Href" class="home-card-link text-decoration-none text-reset d-block h-100">
                            <article class="card h-100 border-0 shadow-sm home-stap-card home-flow-step @(stap.IsBeschikbaar ? null : "home-flow-step--vergrendeld")">
                                <div class="card-body d-flex flex-column gap-3">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <span class="home-step-number">@stap.Nummer</span>
                                        <span class="badge rounded-pill @stap.BadgeClass">@stap.BadgeLabel</span>
                                    </div>
                                    <div>
                                        <h3 class="h5 mb-1">@stap.Titel</h3>
                                        <p class="text-muted mb-0">@stap.Beschrijving</p>
                                    </div>
                                    <div class="small text-muted mt-auto">@stap.Samenvatting</div>
                                </div>
                            </article>
                        </a>
                    </div>
                }
            </div>
        }
    </section>

    @if (!pagina.HeeftProjectData)
    {
        <section class="home-optional-help" data-testid="home-extra-help">
            <details class="home-help-panel">
                <summary class="home-help-panel-summary">
                    <div>
                        <h2 class="h5 mb-1">Meer uitleg (optioneel)</h2>
                        <p class="text-muted mb-0">Open dit alleen als u drie korte aandachtspunten wilt checken voordat u begint.</p>
                    </div>
                </summary>

                <ul class="home-help-list mt-3 mb-0">
                    <li><strong>Apparaten:</strong> voeg een apparaat alleen toe als het echt wandruimte inneemt of de vrije opening voor een paneel verandert.</li>
                    <li><strong>Planken:</strong> ze tellen vooral mee als referentie voor de gatenrij en de eerste gatpositie.</li>
                    <li><strong>Zaagplan:</strong> de bestellijst maakt orderregels; het zaagplan verdeelt die panelen daarna over standaard platen.</li>
                </ul>
            </details>
        </section>
    }
    else
    {
        <section class="home-optional-help" data-testid="home-onboarding-help">
            <details class="home-help-panel">
                <summary class="home-help-panel-summary">
                    <div>
                        <h2 class="h5 mb-1">Extra hulp (optioneel)</h2>
                        <p class="text-muted mb-0">Open dit alleen als u de basis of uitzonderingen nog even wilt nalopen.</p>
                    </div>
                </summary>

                <ul class="home-help-list mt-3 mb-0">
                    <li><strong>Eerst invoeren:</strong> wanden en kasten vormen altijd de basis; apparaten en planken voegt u alleen toe als ze de maatvoering echt beïnvloeden.</li>
                    <li><strong>Uitvoer:</strong> daarna ziet u paneelmaten, 35 mm potscharniergaten, een bestellijst en een zaagplan terug.</li>
                    <li><strong>Let extra op:</strong> gebruik apparaten alleen als ze echt wandruimte innemen en gebruik planken vooral als referentie voor de gatenrij.</li>
                </ul>
            </details>
        </section>
    }
</div>
