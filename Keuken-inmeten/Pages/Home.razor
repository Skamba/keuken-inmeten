@page "/"
@inject KeukenStateService State

<PageTitle>Keuken Inmeten</PageTitle>

@{
    var aantalWanden = State.Wanden.Count;
    var aantalKasten = State.Kasten.Count;
    var aantalPanelen = State.Toewijzingen.Count;
    var aantalResultaten = State.BerekenResultaten().Count;
    var bestellijstItems = BestellijstService.BerekenItems(State);
    var aantalBestellijstItems = bestellijstItems.Count;
    var totaalBoorgaten = bestellijstItems.Sum(item => item.Aantal * item.Boorgaten.Count);
    var heeftProjectData = aantalWanden > 0 || aantalKasten > 0 || aantalPanelen > 0;
    var flowStatus = StappenFlowHelper.BepaalStatus(State);
    var vervolgStap = StappenFlowHelper.BepaalVervolgStap(flowStatus);
    var stappen = BouwStappen(flowStatus, aantalWanden, aantalKasten, aantalPanelen, aantalResultaten, aantalBestellijstItems);
    var dashboardLead = MaakDashboardLead(aantalWanden, aantalKasten, aantalPanelen, aantalBestellijstItems);
    var aandachtBlok = MaakAandachtBlok(aantalPanelen, aantalBestellijstItems);
    var boorgatBlok = MaakBoorgatBlok(totaalBoorgaten);
    var outputSamenvatting = MaakOutputSamenvatting(aantalResultaten, aantalBestellijstItems, totaalBoorgaten);
}

<div class="container py-4 home-startflow">
    <section class="card border-0 shadow-sm mb-5">
        <div class="card-body p-4 p-lg-5">
            <div class="row g-4 align-items-start">
                <div class="col-lg-7">
                    <span class="badge rounded-pill text-bg-primary mb-3">@(heeftProjectData ? "Project in uitvoering" : "Start hier")</span>
                    <h1 class="@(heeftProjectData ? "display-6" : "display-5") fw-bold mb-3">
                        @(heeftProjectData
                            ? "Ga verder met uw keukenproject"
                            : "Van keukenmaat naar paneel, boorgat en zaagplan")
                    </h1>
                    <p class="lead text-muted mb-4">
                        @(heeftProjectData
                            ? dashboardLead
                            : "De app leidt u in vijf vaste stappen van indeling naar panelen, verificatie, bestellijst en zaagplan. Zo ziet u vooraf wat u moet verzamelen en wat u straks kunt bestellen of zagen.")
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        <a href="@vervolgStap.Route" class="btn btn-primary btn-lg px-4">@StappenFlowHelper.MaakVolgendeLabel(vervolgStap.Id)</a>
                        <a href="@(heeftProjectData ? "#project-overzicht" : "#startflow-stappen")" class="btn btn-outline-secondary btn-lg px-4">
                            @(heeftProjectData ? "Bekijk projectoverzicht" : "Bekijk alle stappen")
                        </a>
                    </div>

                    @if (heeftProjectData)
                    {
                        <div class="home-status-strip mt-4">
                            <strong>Huidige projectstatus:</strong>
                            <span>@aantalWanden wand(en)</span>
                            <span>@aantalKasten kast(en)</span>
                            <span>@aantalPanelen paneel/panelen</span>
                            @if (aantalBestellijstItems > 0)
                            {
                                <span>@aantalBestellijstItems orderregel(s)</span>
                            }
                        </div>
                    }
                </div>

                <div class="col-lg-5">
                    @if (heeftProjectData)
                    {
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="home-summary-card home-dashboard-card h-100" data-testid="home-project-dashboard">
                                    <h2 class="h5 mb-3">Wat nu aandacht vraagt</h2>
                                    <ul class="home-dashboard-list">
                                        <li>
                                            <strong>Volgende stap: @vervolgStap.Label</strong>
                                            <div class="text-muted small">@vervolgStap.Beschrijving</div>
                                        </li>
                                        <li>
                                            <strong>@aandachtBlok.Titel</strong>
                                            <div class="text-muted small">@aandachtBlok.Tekst</div>
                                        </li>
                                        <li>
                                            <strong>@boorgatBlok.Titel</strong>
                                            <div class="text-muted small">@boorgatBlok.Tekst</div>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="home-summary-card h-100">
                                    <h2 class="h5 mb-3">Snelle ingangen</h2>
                                    <div class="d-grid gap-2">
                                        <a href="kasten" class="btn btn-outline-secondary home-quick-link">Open indeling</a>
                                        @if (aantalKasten > 0)
                                        {
                                            <a href="panelen" class="btn btn-outline-secondary home-quick-link">Open panelen</a>
                                        }
                                        else
                                        {
                                            <div class="home-quick-link-disabled">Panelen opent zodra er minstens een kast is toegevoegd.</div>
                                        }
                                        @if (aantalBestellijstItems > 0)
                                        {
                                            <a href="zaagplan" class="btn btn-outline-secondary home-quick-link">Open zaagplan</a>
                                        }
                                        else if (aantalPanelen > 0)
                                        {
                                            <a href="verificatie" class="btn btn-outline-secondary home-quick-link">Open verificatie</a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="home-summary-card h-100">
                                    <h2 class="h5 mb-3">Dit hebt u nodig</h2>
                                    <ul class="home-summary-list">
                                        <li class="home-summary-item">
                                            <span class="home-summary-icon">📐</span>
                                            <div>
                                                <strong>Wanden en kasten per wand</strong>
                                                <div class="text-muted small">Breedte, hoogte en positie vormen de basis van alle volgende stappen.</div>
                                            </div>
                                        </li>
                                        <li class="home-summary-item">
                                            <span class="home-summary-icon">📏</span>
                                            <div>
                                                <strong>Kastmaten en gatenrij</strong>
                                                <div class="text-muted small">Voor deuren en ladefronten gebruikt de app deze maten om openingen, werkmaten en boorgaten te berekenen.</div>
                                            </div>
                                        </li>
                                        <li class="home-summary-item">
                                            <span class="home-summary-icon">🧩</span>
                                            <div>
                                                <strong>Apparaten en planken waar relevant</strong>
                                                <div class="text-muted small">Voeg ze alleen toe als ze de indeling, vrije ruimte of referentie voor de gatenrij beïnvloeden.</div>
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="home-summary-card h-100">
                                    <h2 class="h5 mb-3">Dit krijgt u eruit</h2>
                                    <ul class="home-summary-list">
                                        <li class="home-summary-item">
                                            <span class="home-summary-icon">🪟</span>
                                            <div>
                                                <strong>Paneelmaten per opening</strong>
                                                <div class="text-muted small">Inclusief draairichting van de deur (scharnierzijde), randspeling en paneeltype.</div>
                                            </div>
                                        </li>
                                        <li class="home-summary-item">
                                            <span class="home-summary-icon">🛠️</span>
                                            <div>
                                                <strong>Boorgaten en scharnierinfo</strong>
                                                <div class="text-muted small">@(totaalBoorgaten > 0 ? $"{totaalBoorgaten} boorgat(en) zijn al berekend in uw huidige project." : "De verificatiestap laat zien waar de gaten en controlepunten horen.")</div>
                                            </div>
                                        </li>
                                        <li class="home-summary-item">
                                            <span class="home-summary-icon">🧾</span>
                                            <div>
                                                <strong>Bestellijst en zaagplan</strong>
                                                <div class="text-muted small">@(aantalBestellijstItems > 0 ? $"{aantalBestellijstItems} orderregel(s) staan al klaar voor export of zaagoptimalisatie." : "Na verificatie rolt er een bestellijst uit, gevolgd door een zaagplan op plaatformaat.")</div>
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    @if (!heeftProjectData)
    {
        <TerminologieUitleg Sleutels="openingsmaat,werkmaat,randspeling,scharnierzijde"
                            Beschrijving="Gebruik deze korte woordenlijst als u voor het eerst met de meettermen op de startpagina werkt." />
    }

    @if (heeftProjectData)
    {
        <section class="mb-5" id="project-overzicht">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-2 mb-3">
                <div>
                    <h2 class="h3 mb-1">Projectoverzicht</h2>
                    <p class="text-muted mb-0">Gebruik dit overzicht om snel te zien waar u staat en welke uitvoer al klaarstaat.</p>
                </div>
                <div class="text-muted small">@outputSamenvatting</div>
            </div>

            <div class="row g-3">
                <div class="col-sm-6 col-xl-3">
                    <div class="home-metric-card h-100">
                        <div class="home-example-label">Wanden</div>
                        <div class="home-metric-value">@aantalWanden</div>
                        <div class="text-muted small">Opstelling(en) die nu in het project staan.</div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="home-metric-card h-100">
                        <div class="home-example-label">Kasten</div>
                        <div class="home-metric-value">@aantalKasten</div>
                        <div class="text-muted small">De basis voor panelen, openingen en scharnieren.</div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="home-metric-card h-100">
                        <div class="home-example-label">Panelen</div>
                        <div class="home-metric-value">@aantalPanelen</div>
                        <div class="text-muted small">Toegewezen deuren, ladefronten of blindpanelen.</div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="home-metric-card h-100">
                        <div class="home-example-label">Uitvoer klaar</div>
                        <div class="home-metric-value">@(aantalBestellijstItems > 0 ? aantalBestellijstItems : totaalBoorgaten)</div>
                        <div class="text-muted small">@(aantalBestellijstItems > 0 ? "Orderregel(s) klaar voor export of zaagplan." : totaalBoorgaten > 0 ? "Boorgat(en) al berekend voor controle en bestelling." : "Nog geen exportdata; rond eerst panelen af.")</div>
                    </div>
                </div>
            </div>
        </section>
    }

    <section class="mb-5" id="startflow-stappen">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-2 mb-3">
            <div>
                <h2 class="h3 mb-1">@(heeftProjectData ? "Projectstappen" : "Zo loopt de startflow")</h2>
                <p class="text-muted mb-0">
                    @(heeftProjectData
                        ? "Open direct de stap waar u verder wilt werken. De labels hieronder blijven gelijk aan de rest van de applicatie."
                        : "De volgorde en labels hieronder zijn gelijk aan de rest van de applicatie.")
                </p>
            </div>
            <div class="text-muted small">Vaste volgorde: @string.Join(" → ", StappenFlowHelper.AlleStappen.Select(stap => stap.Label))</div>
        </div>

        <div class="row g-3">
            @foreach (var stap in stappen)
            {
                <div class="col-md-6 col-xl">
                    <a href="@stap.Href" class="text-decoration-none text-reset d-block h-100">
                        <article class="card h-100 border-0 shadow-sm home-stap-card home-flow-step @(stap.IsBeschikbaar ? null : "home-flow-step--vergrendeld")">
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <span class="home-step-number">@stap.Nummer</span>
                                    <span class="badge rounded-pill @stap.BadgeClass">@stap.BadgeLabel</span>
                                </div>
                                <div>
                                    <h3 class="h5 mb-1">@stap.Titel</h3>
                                    <p class="text-muted mb-0">@stap.Beschrijving</p>
                                </div>
                                <div class="small text-muted mt-auto">@stap.Samenvatting</div>
                            </div>
                        </article>
                    </a>
                </div>
            }
        </div>
    </section>

    @if (!heeftProjectData)
    {
        <section class="mb-5">
            <div class="d-flex justify-content-between align-items-end mb-3">
                <div>
                    <h2 class="h3 mb-1">Wat beïnvloedt de berekening?</h2>
                    <p class="text-muted mb-0">Deze drie onderdelen veroorzaken vaak vragen bij een eerste project.</p>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h3 class="h5">Apparaten</h3>
                            <p class="text-muted mb-0">Voeg een apparaat toe in stap 1 als het ruimte inneemt in de wandopstelling, tussen kasten staat of de vrije plaats voor een paneel beïnvloedt.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h3 class="h5">Planken</h3>
                            <p class="text-muted mb-0">Planken zijn vooral relevant als referentie voor de gatenrij. De afstand naar het eerste gat wordt gemeten vanaf de onderkant van de bovenste plank.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h3 class="h5">Zaagplan</h3>
                            <p class="text-muted mb-0">Het zaagplan gebruikt de panelen uit de bestellijst om te laten zien hoeveel standaard platen u nodig hebt en hoe de panelen daarop passen.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-2 mb-4">
                    <div>
                        <h2 class="h3 mb-1">Mini-voorbeeld: van invoer naar output</h2>
                        <p class="text-muted mb-0">Een compact voorbeeld van wat u invult en wat u daarna terugziet.</p>
                    </div>
                    <div class="text-muted small">Voorbeeld, niet uw echte projectdata</div>
                </div>

                <div class="row g-3 align-items-stretch">
                    <div class="col-lg-6 col-xl">
                        <div class="home-example-step h-100">
                            <div class="home-example-label">Invoer</div>
                            <h3 class="h5">1. @StappenFlowHelper.Stap("kasten").Label</h3>
                            <ul class="mb-0 text-muted small">
                                <li>Achterwand toevoegen en 3 kasten plaatsen</li>
                                <li>Een oven toevoegen waar hij echt ruimte inneemt</li>
                                <li>Controleer of de wandopstelling logisch staat</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-6 col-xl">
                        <div class="home-example-step h-100">
                            <div class="home-example-label">Toewijzen</div>
                            <h3 class="h5">2. @StappenFlowHelper.Stap("panelen").Label</h3>
                            <ul class="mb-0 text-muted small">
                                <li>2 deuren en 1 ladefront selecteren</li>
                                <li>Paneelmaten en scharnierzijde instellen</li>
                                <li>Plank gebruiken als referentie voor de gatenrij</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-6 col-xl">
                        <div class="home-example-step h-100">
                            <div class="home-example-label">Controle</div>
                            <h3 class="h5">3. @StappenFlowHelper.Stap("verificatie").Label</h3>
                            <ul class="mb-0 text-muted small">
                                <li>Vrije opening en netto paneelmaat naast elkaar controleren</li>
                                <li>Scharnierzijde en boorgatposities nalopen</li>
                                <li>U ziet meteen welke panelen nog controle nodig hebben</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-6 col-xl">
                        <div class="home-example-step h-100">
                            <div class="home-example-label">Bestellen</div>
                            <h3 class="h5">4. @StappenFlowHelper.Stap("bestellijst").Label</h3>
                            <ul class="mb-0 text-muted small">
                                <li>Bestellijst met aantallen, maten en boorgaten</li>
                                <li>Export naar Excel of printklare PDF</li>
                                <li>Per wand en paneeltype compact gegroepeerd</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-6 col-xl">
                        <div class="home-example-step h-100">
                            <div class="home-example-label">Zagen</div>
                            <h3 class="h5">5. @StappenFlowHelper.Stap("zaagplan").Label</h3>
                            <ul class="mb-0 text-muted small">
                                <li>Panelen verdelen over standaard plaatformaat</li>
                                <li>Zaagverlies meenemen in de berekening</li>
                                <li>Snel zien hoeveel platen u nodig hebt</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }
    else
    {
        <section class="card border-0 shadow-sm" data-testid="home-onboarding-help">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-2">
                    <div>
                        <h2 class="h4 mb-1">Eerste keer of project overdragen?</h2>
                        <p class="text-muted mb-0">Open deze compacte hulp alleen als u nog even de basis, uitzonderingen of de taal van de app wilt nalopen.</p>
                    </div>
                </div>

                <details class="home-help-details mt-3">
                    <summary>Toon compacte basisuitleg</summary>
                    <div class="row g-3 mt-2">
                        <div class="col-lg-4">
                            <div class="home-example-step h-100">
                                <div class="home-example-label">Invoer</div>
                                <h3 class="h5">Wat vult u eerst in?</h3>
                                <ul class="mb-0 text-muted small">
                                    <li>Wanden en kasten vormen altijd de basis.</li>
                                    <li>Apparaten en planken voegt u alleen toe als ze de maatvoering echt beinvloeden.</li>
                                    <li>Controleer per wand of de opstelling logisch staat voordat u doorgaat.</li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="home-example-step h-100">
                                <div class="home-example-label">Uitvoer</div>
                                <h3 class="h5">Wat krijgt u eruit?</h3>
                                <ul class="mb-0 text-muted small">
                                    <li>Paneelmaten per opening, inclusief scharnierzijde en randspeling.</li>
                                    <li>Boorgaten en controlepunten zodra deuren of fronten zijn toegewezen.</li>
                                    <li>Daarna een bestellijst en zaagplan voor bestellen en zagen.</li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="home-example-step h-100">
                                <div class="home-example-label">Let extra op</div>
                                <h3 class="h5">Drie veelgestelde punten</h3>
                                <ul class="mb-0 text-muted small">
                                    <li>Gebruik apparaten alleen als ze echt wandruimte innemen.</li>
                                    <li>Planken tellen vooral mee als referentie voor de gatenrij.</li>
                                    <li>Het zaagplan gebruikt de panelen uit de bestellijst op standaard plaatformaat.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </details>
            </div>
        </section>
    }
</div>

@code {
    private static StartStap[] BouwStappen(StappenFlowStatus flowStatus, int aantalWanden, int aantalKasten, int aantalPanelen, int aantalResultaten, int aantalBestellijstItems)
    {
        var aanbevolenStap = StappenFlowHelper.BepaalVervolgStap(flowStatus);

        return StappenFlowHelper.AlleStappen
            .Select(stap =>
            {
                var heeftData = stap.Id switch
                {
                    "kasten" => aantalWanden > 0 || aantalKasten > 0,
                    "panelen" => aantalPanelen > 0,
                    "verificatie" => aantalResultaten > 0,
                    "bestellijst" => aantalBestellijstItems > 0,
                    "zaagplan" => aantalBestellijstItems > 0,
                    _ => false
                };

                var samenvatting = stap.Id switch
                {
                    "kasten" => aantalWanden > 0 ? $"{aantalWanden} wand(en) · {aantalKasten} kast(en)" : "Start met wanden en kasten",
                    "panelen" => aantalPanelen > 0 ? $"{aantalPanelen} paneel/panelen toegewezen" : "Nog geen panelen toegewezen",
                    "verificatie" => aantalResultaten > 0 ? $"{aantalResultaten} paneel/panelen klaar om te controleren" : "Beschikbaar zodra panelen zijn geplaatst",
                    "bestellijst" => aantalBestellijstItems > 0 ? $"{aantalBestellijstItems} orderregel(s) beschikbaar" : "Verschijnt zodra er panelen klaarstaan",
                    "zaagplan" => aantalBestellijstItems > 0 ? "Gebruik de orderregels om platen slim te vullen" : "Bouwt voort op de panelen uit uw bestellijst",
                    _ => string.Empty
                };

                return MaakStap(
                    stap,
                    samenvatting,
                    heeftData,
                    stap.Id == aanbevolenStap.Id,
                    StappenFlowHelper.BepaalRouteGate(stap.Id, flowStatus));
            })
            .ToArray();
    }

    private static StartStap MaakStap(
        AppStap stap,
        string samenvatting,
        bool heeftData,
        bool isAanbevolen,
        StapRouteGate? routeGate)
    {
        var badgeLabel = isAanbevolen
            ? "Volgende stap"
            : routeGate is not null
                ? $"Eerst {routeGate.VereisteStap.Label}"
                : heeftData
                    ? "Beschikbaar"
                    : "Klaar om te starten";
        var badgeClass = isAanbevolen
            ? "bg-primary-subtle text-primary-emphasis border border-primary-subtle"
            : routeGate is not null
                ? "bg-body-tertiary text-body-secondary border"
                : heeftData
                    ? "bg-success-subtle text-success-emphasis border border-success-subtle"
                    : "bg-body-tertiary text-body-secondary border";

        return new StartStap(
            routeGate?.VereisteStap.Route ?? stap.Route,
            stap.Nummer,
            stap.Label,
            stap.Beschrijving,
            routeGate?.Reden ?? samenvatting,
            badgeLabel,
            badgeClass,
            routeGate is null);
    }

    private static string MaakDashboardLead(int aantalWanden, int aantalKasten, int aantalPanelen, int aantalBestellijstItems)
        => aantalBestellijstItems > 0
            ? $"Uw project bevat al {aantalWanden} wand(en), {aantalKasten} kast(en), {aantalPanelen} paneel/panelen en {aantalBestellijstItems} orderregel(s). Gebruik deze startpagina vooral om snel te hervatten en de juiste uitvoerstap te openen."
            : aantalPanelen > 0
                ? $"Uw indeling en paneeltoewijzing staan al klaar. Rond nu verificatie, bestellijst en zaagplan af zonder opnieuw door de hele basisuitleg te hoeven bladeren."
                : $"U hebt al {aantalWanden} wand(en) en {aantalKasten} kast(en) ingevoerd. Ga nu direct verder met panelen toewijzen zodat de rest van de workflow beschikbaar wordt.";

    private static InfoBlok MaakAandachtBlok(int aantalPanelen, int aantalBestellijstItems)
        => aantalPanelen == 0
            ? new(
                "Panelen ontbreken nog",
                "Zonder paneeltoewijzing blijven verificatie, bestellijst en zaagplan vergrendeld.")
            : aantalBestellijstItems == 0
                ? new(
                    "Controleer voordat u bestelt",
                    "Loop eerst verificatie door zodat maten, scharnierzijde en boorgaten nog een laatste controle krijgen.")
                : new(
                    "Bestellijst en zaagplan zijn klaar",
                    "U kunt nu exporteren, orderregels nalopen en beoordelen of alle panelen op uw standaard plaatformaat passen.");

    private static InfoBlok MaakBoorgatBlok(int totaalBoorgaten)
        => totaalBoorgaten > 0
            ? new(
                $"{totaalBoorgaten} boorgat(en) al berekend",
                "Deze informatie zit ook in de verificatie en de bestellijst, zodat u niet opnieuw hoeft na te rekenen.")
            : new(
                "Boorgaten verschijnen later",
                "Zodra deuren of relevante fronten zijn toegewezen vult de app deze technische details automatisch aan.");

    private static string MaakOutputSamenvatting(int aantalResultaten, int aantalBestellijstItems, int totaalBoorgaten)
        => aantalBestellijstItems > 0
            ? $"{aantalBestellijstItems} orderregel(s) en {totaalBoorgaten} boorgat(en) klaar voor uitvoer"
            : aantalResultaten > 0
                ? $"{aantalResultaten} paneel/panelen klaar voor controle"
                : "Nog geen uitvoer; wijs eerst panelen toe";

    private sealed record StartStap(
        string Href,
        int Nummer,
        string Titel,
        string Beschrijving,
        string Samenvatting,
        string BadgeLabel,
        string BadgeClass,
        bool IsBeschikbaar);

    private sealed record InfoBlok(string Titel, string Tekst);
}
