@page "/bestellijst"
@using Keuken_inmeten.Services.Interop
@inject KeukenStateService State
@inject IJSRuntime JS
@inject ActieFeedbackService Feedback
@implements IAsyncDisposable

<PageTitle>Stap 4 — Bestellijst</PageTitle>

<StapIndicator HuidigeStap="bestellijst" />

<section class="stap-pagina-kop mb-4">
    <div class="stap-pagina-kop__top">
        <div class="stap-pagina-kop__intro">
            <h2 class="page-header">Stap 4: Bestellijst</h2>
            <p class="stap-pagina-kop__lead">Controleer eerst de lijst. Gebruik export pas als aantallen, maten en contextregels kloppen.</p>
        </div>
        <div class="stap-ondersteuning stap-pagina-kop__acties" data-testid="bestellijst-stap-ondersteuning">
            <StapHulpDrawer StapId="bestellijst" KnopLabel="Hulp bij stap" />
            <TerminologieUitleg Compact="true"
                                CompactLabel="Leg termen uit"
                                Sleutels="kantenband,cnc,scharnierpot"
                                Beschrijving="Deze woordenlijst helpt bij de technische termen in de bestellijst en export." />
        </div>
    </div>
</section>

@{
    var pagina = MaakPaginaModel();
}

@if (pagina.RouteGate is not null)
{
    <StapRouteMelding Gate="@pagina.RouteGate" />
}
else if (pagina.Items.Count == 0)
{
    <div class="alert alert-warning">
        Er is nog geen bestellijst beschikbaar. Controleer eerst of er in stap 2 panelen zijn toegewezen.
    </div>
}
else
{
    <div class="bestellijst-toolbar card border-0 shadow-sm mb-4">
        <div class="card-body d-flex flex-column gap-3">
            <div class="bestellijst-primary-strip">
                <div>
                    <div class="small fw-semibold text-uppercase text-muted mb-1">Volgende stap</div>
                    <h5 class="mb-1">Controleer eerst de orderregels. Gebruik export pas als de lijst klopt.</h5>
                    <div class="stap-meta-list bestellijst-primary-meta">
                        <span>@pagina.Items.Count orderregels</span>
                        <span>@pagina.TotaalAantal panelen</span>
                        <span>@pagina.WandGroepen.Count wanden</span>
                    </div>
                </div>
                <div class="bestellijst-export-entry">
                    <button type="button"
                            class="btn btn-primary"
                            @onclick="OpenExportFlow"
                            data-testid="bestellijst-open-exportflow-button">Export voorbereiden</button>
                </div>
            </div>

            <details class="bestellijst-overzicht-details bestellijst-techniek-details"
                     data-testid="bestellijst-techniek-details">
                <summary data-testid="bestellijst-tech-details-summary">
                    <div>
                        <div class="fw-semibold">Technische productiecontrole (optioneel)</div>
                        <div class="small text-muted">@(_toonTechnischeDetails
                            ? $"{FormatPotscharnierGatTelling(pagina.TotaalBoorgaten)} zichtbaar."
                            : "Standaard uit. Open alleen voor CNC of controle van 35 mm potscharniergaten.")</div>
                    </div>
                </summary>
                <div class="d-flex flex-column gap-3 mt-3">
                    <div class="form-check form-switch mb-0 flex-grow-1">
                        <input id="toon-technische-bestellijst"
                               class="form-check-input"
                               type="checkbox"
                               @bind="_toonTechnischeDetails" />
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <label class="form-check-label fw-semibold" for="toon-technische-bestellijst">
                                Toon technische kolommen
                             </label>
                             <HulpInfoKnop Titel="Technische details in de bestellijst"
                                          Tekst="Deze kolommen zijn vooral bedoeld voor overdracht naar productie of controle van de 35 mm potscharniergaten en CNC-bewerkingen."
                                          Voorbeeld="Laat de technische details uit zolang u vooral aantallen, typen en afmetingen wilt controleren."
                                          WatNuDoen="Schakel deze optie alleen in als u de lijst technisch wilt nalopen of exporteren voor nabewerking." />
                        </div>
                        <div class="form-text hulp-hint">Gebruik dit voor 35 mm potscharniergaten, CNC en productiecontrole.</div>
                    </div>

                    @if (_toonTechnischeDetails)
                    {
                        <div class="small text-muted bestellijst-toolbar-note">
                            <strong>Technische weergave:</strong> @BestellijstExportFormatter.FormatCncAssenSamenvatting() · @FormatPotscharnierGatTelling(pagina.TotaalBoorgaten) totaal
                        </div>
                    }
                </div>
            </details>
        </div>
    </div>

    @if (_exportFlow.ToonExportFlow)
    {
        <div class="hulp-drawer-overlay bestellijst-export-overlay" @onclick="SluitExportFlow">
            <aside class="bestellijst-export-drawer card border-0 shadow-lg"
                   role="dialog"
                   aria-modal="true"
                   aria-labelledby="bestellijst-export-drawer-title"
                   @onclick:stopPropagation="true"
                   data-testid="bestellijst-export-drawer">
                <div class="card-header bg-primary bg-opacity-10 border-bottom">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Export in stappen</div>
                            <h5 class="mb-1" id="bestellijst-export-drawer-title">Export voorbereiden</h5>
                            <p class="text-muted mb-0">Kies het formaat, controleer de voorvertoning en bevestig daarna pas de export.</p>
                        </div>
                        <button type="button" class="btn-close" @onclick="SluitExportFlow" aria-label="Sluit exportvenster"></button>
                    </div>
                </div>

                <div class="card-body bestellijst-export-drawer-body">
                    <div class="bestellijst-export-stappen mb-4" aria-label="Exportstappen">
                        <div class="@ExportStapClass(BestellijstExportFlowStap.Kiezen)">1. Keuze</div>
                        <div class="@ExportStapClass(BestellijstExportFlowStap.Preview)">2. Voorvertoning</div>
                        <div class="@ExportStapClass(BestellijstExportFlowStap.Bevestigen)">3. Bevestig</div>
                    </div>

                    @if (_exportFlow.Stap is BestellijstExportFlowStap.Kiezen)
                    {
                        <section data-testid="bestellijst-export-step-kies">
                            <div class="small text-muted mb-3">Kies eerst alleen het bestandsformaat.</div>

                            <div class="fw-semibold mb-2">Bestandsformaat</div>
                            <div class="row g-3">
                                @foreach (var optie in BestellijstExportFlowHelper.Opties)
                                {
                                    var isGeselecteerd = _exportFlow.ExportType == optie.Type;

                                    <div class="col-lg-4">
                                        <button type="button"
                                                class="bestellijst-export-keuze @(isGeselecteerd ? "is-selected" : null)"
                                                @onclick="@(() => KiesExportType(optie.Type))"
                                                data-testid="@ExportTypeTestId(optie.Type)">
                                            <div class="d-flex justify-content-between align-items-start gap-3">
                                                <div>
                                                    <div class="bestellijst-export-keuze-kicker">@ExportKicker(optie.Type)</div>
                                                    <div class="fw-semibold">@optie.Label</div>
                                                    <div class="small text-muted mt-1">@optie.KorteBeschrijving</div>
                                                </div>
                                                @if (isGeselecteerd)
                                                {
                                                    <span class="badge text-bg-primary">Gekozen</span>
                                                }
                                            </div>
                                            <div class="bestellijst-export-keuze-badges mt-3">
                                                <span class="bestellijst-export-keuze-badge">@ExportBadge1(optie.Type)</span>
                                                <span class="bestellijst-export-keuze-badge">@ExportBadge2(optie.Type)</span>
                                            </div>
                                            <div class="small text-muted mt-3">@optie.Voorbeeld</div>
                                        </button>
                                    </div>
                                }
                            </div>
                            <div class="small text-muted mt-3">Materiaal kunt u in de voorvertoning aanpassen als dit bestand van de standaard moet afwijken.</div>
                        </section>
                    }
                    else if (_exportFlow.Stap is BestellijstExportFlowStap.Preview)
                    {
                        <section data-testid="bestellijst-export-step-preview">
                            <div class="row g-3">
                                <div class="col-lg-7">
                                    <div class="border rounded p-3 h-100">
                                        <div class="small fw-semibold text-uppercase text-muted mb-1">Gekozen export</div>
                                        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-2">
                                            <h6 class="mb-0">@pagina.GekozenExport.Label</h6>
                                            <span class="badge text-bg-light border">Stap 2 van 3</span>
                                        </div>
                                        <p class="text-muted small mb-3">@pagina.GekozenExport.KorteBeschrijving</p>
                                        <div class="bestellijst-toolbar-meta">
                                            <span><strong>Materiaal:</strong> @pagina.ExportDocument.PaneelType</span>
                                            <span><strong>Dikte:</strong> @BestellijstExportFormatter.FormatDikteLabel(pagina.ExportDocument.DikteMm)</span>
                                            <span><strong>Orderregels:</strong> @pagina.ExportDocument.Orderregels</span>
                                            <span><strong>Panelen:</strong> @pagina.ExportDocument.TotaalAantal</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-5">
                                    <div class="border rounded p-3 h-100">
                                        <div class="small fw-semibold text-uppercase text-muted mb-1">Gebruik dit als</div>
                                        <div class="small text-muted mb-3">@pagina.GekozenExport.WanneerKiezen</div>
                                        <div class="small"><strong>Resultaat:</strong> @pagina.GekozenExport.ResultaatUitleg</div>
                                        <div class="small text-muted mt-3">Materiaal: @pagina.ExportDocument.PaneelType · @BestellijstExportFormatter.FormatDikteLabel(pagina.ExportDocument.DikteMm)</div>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3 mt-1">
                                <div class="col-12">
                                    <div class="border rounded p-3 h-100">
                                        <div class="small fw-semibold text-uppercase text-muted mb-2">Voorvertoning van het resultaat</div>
                                        <ul class="small mb-0 ps-3" data-testid="bestellijst-export-preview">
                                            @foreach (var punt in pagina.ExportPreviewPunten)
                                            {
                                                <li class="mb-1">@punt</li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <details class="bestellijst-overzicht-details bestellijst-export-instellingen mt-3"
                                     data-testid="bestellijst-export-instellingen">
                                <summary data-testid="bestellijst-export-instellingen-summary">
                                    <div>
                                        <div class="fw-semibold">Materiaal aanpassen (optioneel)</div>
                                        <div class="small text-muted">Standaard: @pagina.ExportDocument.PaneelType · @BestellijstExportFormatter.FormatDikteLabel(pagina.ExportDocument.DikteMm)</div>
                                    </div>
                                </summary>
                                <div class="row g-3 mt-2">
                                    <div class="col-md-7">
                                        <label class="form-label fw-semibold">Paneeltype</label>
                                        <input class="form-control"
                                               list="paneeltype-opties"
                                               @bind="PaneelTypeInput"
                                               data-testid="bestellijst-paneeltype-input" />
                                        <div class="form-text hulp-hint" data-testid="bestellijst-paneeltype-hint">Bijvoorbeeld MDF wit of berken multiplex.</div>
                                        <datalist id="paneeltype-opties">
                                            @foreach (var optie in PaneelTypeOpties)
                                            {
                                                <option value="@optie"></option>
                                            }
                                        </datalist>
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label fw-semibold">Dikte (mm)</label>
                                        <input class="form-control"
                                               @bind="DikteInput"
                                               inputmode="decimal"
                                               data-testid="bestellijst-dikte-input" />
                                        <div class="form-text hulp-hint" data-testid="bestellijst-dikte-hint">Gebruik hier de werkelijke plaatdikte, bijvoorbeeld 19 of 18,4.</div>
                                    </div>
                                </div>
                            </details>
                        </section>
                    }
                    else
                    {
                        <section data-testid="bestellijst-export-step-bevestig">
                            <div class="alert alert-light border">
                                <div class="fw-semibold mb-1">Klaar om te exporteren</div>
                                <div class="small text-muted mb-0">U hebt formaat, materiaal en de voorvertoning gecontroleerd. Bevestig nu het bestand dat u wilt openen of downloaden.</div>
                            </div>

                            <div class="row g-3">
                                <div class="col-lg-6">
                                    <div class="border rounded p-3 h-100">
                                        <div class="small fw-semibold text-uppercase text-muted mb-2">Uw keuzes</div>
                                        <ul class="list-unstyled small mb-0 d-grid gap-2">
                                            <li><strong>Formaat:</strong> @pagina.GekozenExport.Label</li>
                                            <li><strong>Materiaal:</strong> @pagina.ExportDocument.PaneelType</li>
                                            <li><strong>Dikte:</strong> @BestellijstExportFormatter.FormatDikteLabel(pagina.ExportDocument.DikteMm)</li>
                                            <li><strong>Resultaat:</strong> @pagina.GekozenExport.ResultaatUitleg</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="border rounded p-3 h-100">
                                        <div class="small fw-semibold text-uppercase text-muted mb-2">Wat gebeurt hierna?</div>
                                        <ul class="small mb-0 ps-3">
                                            @if (_exportFlow.ExportType is BestellijstExportType.Pdf)
                                            {
                                                <li class="mb-1">Uw browser downloadt direct een PDF-bestand met visualisaties en boorbeeld.</li>
                                                <li class="mb-1">Controleer daarna de Downloads-map of open het bestand meteen.</li>
                                            }
                                            else if (_exportFlow.ExportType is BestellijstExportType.AdZaagtExcel)
                                            {
                                                <li class="mb-1">Uw browser downloadt direct een spreadsheetbestand in het AdZaagt-formaat.</li>
                                                <li class="mb-1">Controleer daarna de Downloads-map of stuur het bestand in bij AdZaagt.</li>
                                            }
                                            else
                                            {
                                                <li class="mb-1">Uw browser downloadt direct een spreadsheetbestand.</li>
                                                <li class="mb-1">Controleer daarna de Downloads-map of open het bestand meteen.</li>
                                            }
                                            <li class="mb-1">De ordercontrole op de pagina blijft daarna beschikbaar.</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                </div>

                <div class="card-footer bg-transparent border-top d-flex justify-content-between flex-wrap gap-2">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                @onclick="AnnuleerOfGaTerugInExportFlow"
                                data-testid="bestellijst-export-back-button">
                        @(_exportFlow.Stap is BestellijstExportFlowStap.Kiezen ? "Annuleren" : "Terug")
                    </button>

                    @if (_exportFlow.Stap is BestellijstExportFlowStap.Kiezen)
                    {
                        <button type="button"
                                class="btn btn-primary"
                                @onclick="GaNaarExportPreview"
                                data-testid="bestellijst-export-next-button">
                            Bekijk voorvertoning
                        </button>
                    }
                    else if (_exportFlow.Stap is BestellijstExportFlowStap.Preview)
                    {
                        <button type="button"
                                class="btn btn-primary"
                                @onclick="GaNaarExportBevestiging"
                                data-testid="bestellijst-export-next-button">
                            Ga naar bevestigen
                        </button>
                    }
                    else
                    {
                        <button type="button"
                                class="btn btn-primary"
                                @onclick="BevestigExport"
                                data-testid="bestellijst-export-confirm-button">
                            @pagina.GekozenExport.BevestigLabel
                        </button>
                    }
                </div>
            </aside>
        </div>
    }

    <details class="bestellijst-overzicht-details mb-4">
        <summary class="fw-semibold">
            <span>Bekijk verdeling per wand en paneeltype</span>
            <span class="small text-muted">@pagina.WandGroepen.Count wand(en) · @pagina.PaneelTypeTellingen.Count type(n)</span>
        </summary>
        <div class="row g-3 mt-2">
            <div class="col-xl-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-uppercase text-muted fw-semibold mb-2" style="font-size: 0.72rem; letter-spacing: .04em;">Per wand</div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var groep in pagina.WandGroepen)
                        {
                            <span class="badge text-bg-light border">@groep.WandNaam · @groep.PanelenTotaal panelen</span>
                        }
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-uppercase text-muted fw-semibold mb-2" style="font-size: 0.72rem; letter-spacing: .04em;">Per paneeltype</div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var telling in pagina.PaneelTypeTellingen)
                        {
                            <span class="badge text-bg-light border">@telling.Label @telling.Aantal</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </details>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="table-responsive bestellijst-table-wrap">
                <table class="table table-hover align-middle bestellijst-table @(_toonTechnischeDetails ? "bestellijst-table--technisch" : null)"
                       data-testid="bestellijst-tabel">
                    <caption class="visually-hidden">Bestellijst — @pagina.Items.Count orderregels en @pagina.TotaalAantal panelen</caption>
                    <thead class="table-light">
                        <tr>
                            <th>Orderregel</th>
                            <th class="text-center">Aantal</th>
                            <th>Eindmaat na kantenband</th>
                            <th>Afwerking</th>
                            <th>Kast(en)</th>
                            @if (_toonTechnischeDetails)
                            {
                                <th>Technische details</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in pagina.Items)
                        {
                            var technischeDetails = TechnischeDetailLijnen(item);
                            <tr>
                                <th scope="row" class="bestellijst-name">
                                    <div class="fw-semibold">@item.Naam</div>
                                    <div class="small text-muted">@item.PaneelRolLabel</div>
                                </th>
                                <td class="text-center fw-semibold">@item.Aantal</td>
                                <td>
                                    <div>@MaatLabel(item)</div>
                                </td>
                                <td>@item.KantenbandLabel</td>
                                <td class="small text-muted">@ContextSamenvatting(item)</td>
                                @if (_toonTechnischeDetails)
                                {
                                    <td class="small">
                                        <ul class="list-unstyled mb-0 d-grid gap-1">
                                            @foreach (var detail in technischeDetails)
                                            {
                                                <li>@detail</li>
                                            }
                                        </ul>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<StapNavigatie HuidigeStap="bestellijst"
               VorigeHref="verificatie"
               VolgendeHref="zaagplan" />
