@page "/verificatie"
@using Keuken_inmeten.Services.Interop
@inject KeukenStateService State
@inject DeelLinkService Delen
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Stap 3 — Verificatie</PageTitle>

<StapIndicator HuidigeStap="verificatie" />

<section class="stap-pagina-kop mb-4">
    <div class="stap-pagina-kop__top">
        <div class="stap-pagina-kop__intro">
            <h2 class="page-header">Stap 3: Verificatie</h2>
            @if (_fase == VerificatieFase.Overzicht)
            {
                <p class="stap-pagina-kop__lead">Controleer per paneel eerst de maat in de opening. Controleer systeemgaten alleen bij deuren.</p>
            }
        </div>
        @if (_fase == VerificatieFase.Overzicht)
        {
            <div class="stap-ondersteuning stap-pagina-kop__acties" data-testid="verificatie-stap-ondersteuning">
                <StapHulpDrawer StapId="verificatie" KnopLabel="Hulp bij stap" />
                <TerminologieUitleg Compact="true"
                                    CompactLabel="Leg termen uit"
                                    Sleutels="openingsmaat,werkmaat,gaatjesrij,montageplaat,pothart"
                                    Beschrijving="Deze woordenlijst helpt bij de controletermen die u in de verificatiestap ziet." />
            </div>
        }
    </div>
</section>

@{
    var pagina = MaakPaginaModel();
    var uitlijnWaarschuwingen = WandUitlijnControleService.BepaalWaarschuwingen(State.Wanden, State.Kasten);
}

@if (pagina.RouteGate is not null)
{
    <StapRouteMelding Gate="@pagina.RouteGate" />
}
else if (_fase == VerificatieFase.Overzicht && pagina.Overzicht is not null)
{
    var overzicht = pagina.Overzicht;

    @if (uitlijnWaarschuwingen.Count > 0)
    {
        <section class="alert alert-warning shadow-sm mb-4"
                 role="alert"
                 data-testid="verificatie-uitlijn-waarschuwing">
            <div class="fw-semibold mb-1">Let op: er lijken kasten bijna, maar niet helemaal, uitgelijnd.</div>
            <div class="small mb-3">Afwijkingen kleiner dan 25 mm geven vaak onverwachte verschillen in paneelmaten en bestellijstregels.</div>
            <div class="d-flex flex-column gap-2" data-testid="verificatie-uitlijn-waarschuwing-lijst">
                @foreach (var wandWaarschuwing in uitlijnWaarschuwingen)
                {
                    <div data-testid="verificatie-uitlijn-waarschuwing-item"
                         data-wand-naam="@wandWaarschuwing.WandNaam">
                        <div class="fw-semibold">@wandWaarschuwing.WandNaam</div>
                        @foreach (var waarschuwing in wandWaarschuwing.Waarschuwingen.Take(4))
                        {
                            <div class="small">
                                <strong>@waarschuwing.EersteKastNaam</strong> en <strong>@waarschuwing.TweedeKastNaam</strong>:
                                @FormatUitlijnAfwijkingen(waarschuwing.Afwijkingen)
                            </div>
                        }
                        @if (wandWaarschuwing.Waarschuwingen.Count > 4)
                        {
                            <div class="small text-muted">+@(wandWaarschuwing.Waarschuwingen.Count - 4) extra aandachtspunt(en)</div>
                        }
                    </div>
                }
            </div>
        </section>
    }

    <div class="card border-0 shadow-sm mb-4 verificatie-overzicht-card">
        <div class="card-body">
            <div class="verificatie-overview-header mb-3">
                <div>
                    <h5 class="mb-1">Taken per wand</h5>
                    <p class="text-muted small mb-0">Open steeds alleen de volgende controle. Technische uitleg blijft verborgen tot u die in de detailstap nodig hebt.</p>
                </div>
                <div class="verificatie-overview-action">
                    <div class="verificatie-samenvatting-label">Volgende taak</div>
                    <div class="fw-semibold">@(overzicht.AantalAfgerond == pagina.Resultaten.Count ? "Alle controles zijn klaar" : overzicht.SamenvattingTaak.VolgendeControle)</div>
                    <div class="small text-muted mb-3">@((overzicht.AantalAfgerond == pagina.Resultaten.Count) ? "U kunt afronden of een taak opnieuw openen." : $"Paneel {overzicht.SamenvattingTaak.Index + 1} · {overzicht.SamenvattingTaak.Resultaat.KastNaam}")</div>
                    <button class="btn btn-success btn-lg"
                            @onclick="() => GaNaarPaneel(overzicht.EersteOngecontroleerdIndex)"
                            data-testid="verificatie-start-button">
                        @(overzicht.AlGestart ? "Open volgende taak" : "Start taaklijst") &#8594;
                    </button>
                </div>
            </div>

            <div class="verificatie-overview-strip mb-3">
                <span>@overzicht.AantalAfgerond van @pagina.Resultaten.Count taken klaar</span>
                <span>@overzicht.TotaalOpenChecks open controles</span>
                <span>@overzicht.TaakGroepen.Count wand(en)</span>
            </div>

            <div class="verificatie-taaklijst mb-3" data-testid="verificatie-taaklijst">
                @foreach (var groep in overzicht.TaakGroepen)
                {
                    <div class="card shadow-sm mb-3"
                          data-testid="verificatie-taakgroep"
                         data-wand-id="@groep.WandId"
                         data-wand-naam="@groep.WandNaam">
                        <div class="card-header bg-body-tertiary d-flex justify-content-between align-items-start gap-3 flex-wrap">
                            <div>
                                <h6 class="mb-1">@groep.WandNaam</h6>
                                <div class="small text-muted">@groep.Taken.Count panelen · @groep.AfgerondeTaken klaar · @groep.OpenTaken open</div>
                            </div>
                        </div>
                        <div class="list-group list-group-flush">
                            @foreach (var taak in groep.Taken)
                            {
                                <div class="list-group-item"
                                     data-testid="verificatie-taak-item"
                                     data-wand-naam="@groep.WandNaam"
                                     data-paneel-index="@taak.Index">
                                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                        <div class="verificatie-taak-meta">
                                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                                <span class="small text-muted">Paneel @(taak.Index + 1)</span>
                                                <span class="fw-semibold">@taak.Resultaat.KastNaam</span>
                                                @if (taak.Geverifieerd)
                                                {
                                                    <span class="small text-success fw-semibold">Klaar</span>
                                                }
                                            </div>
                                            <div class="small text-muted">@TypeNaam(taak.Resultaat.Type) · maat in opening @FormatMm(taak.OpeningB) &#215; @FormatMm(taak.OpeningH)</div>
                                            <div class="small mt-1">@taak.VolgendeControle</div>
                                        </div>
                                        <div class="verificatie-taak-acties">
                                            <div class="small text-muted text-sm-end">@($"{taak.OpenChecks} {(taak.OpenChecks == 1 ? "open controle" : "open controles")}")</div>
                                            <button class="btn btn-outline-primary btn-sm"
                                                    @onclick="() => GaNaarPaneel(taak.Index)"
                                                    data-testid="verificatie-open-controle-button">
                                                Open controle
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
else if (_fase == VerificatieFase.PaneelVerificatie && pagina.ActiefPaneel is not null)
{
    var paneel = pagina.ActiefPaneel;
    var r = paneel.Resultaat;
    var checks = paneel.Checks;

    <div class="verificatie-focus-strip mb-3">
        <div>
            <div class="verificatie-samenvatting-label mb-1">Actief paneel</div>
            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                <span class="badge @TypeBadgeClass(r.Type)">@TypeNaam(r.Type)</span>
                <span class="fw-semibold">@r.KastNaam</span>
            </div>
            <div class="small text-muted">Paneel @(_paneelIndex + 1) van @pagina.Resultaten.Count · @paneel.WandNaam</div>
        </div>
        <div class="text-sm-end">
            <div class="fw-semibold">@paneel.AfgerondePanelen van @pagina.Resultaten.Count panelen klaar</div>
            <div class="small text-muted">@paneel.OpenPaneelControles open controles in deze stap</div>
        </div>
    </div>

    <div class="mb-4">
        <div class="verificatie-detail-strip mb-4">
            <div class="verificatie-detail-strip-main">
                <div class="verificatie-samenvatting-label">Nu controleren</div>
                <div class="fw-semibold">@paneel.VolgendeControle</div>
                <div class="small text-muted">@paneel.HuidigeControleHint</div>
            </div>
            <div class="verificatie-detail-strip-meta">
                <div>
                    <div class="verificatie-samenvatting-label">@PaneelMaatUitlegHelper.MaatOmTeBestellenLabel</div>
                    <div class="fw-semibold">@FormatMm(r.Breedte) &#215; @FormatMm(r.Hoogte)</div>
                    <div class="small text-muted">Vergelijk deze maat hieronder met de vrije opening op de kast.</div>
                </div>
                <div>
                    <div class="verificatie-samenvatting-label">Status</div>
                    <div class="fw-semibold">@paneel.AantalAfgevinkt van @paneel.TotaalChecks controles afgevinkt</div>
                    <div class="small text-muted">@paneel.OpenChecksLabel</div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">

                    @* ── Controle 1: Meet de kastopening na ── *@
                    <div class="verificatie-check @(checks.MatenOk ? "verificatie-check-ok" : "") mb-4">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <button class="verificatie-check-cirkel @(checks.MatenOk ? "ok" : "")"
                                    @onclick="() => ToggleMatenCheck(r)"
                                    title="@(checks.MatenOk ? "Vink af" : "Markeer als gecontroleerd")"
                                    data-testid="verificatie-check-toggle-maten">
                                @if (checks.MatenOk) { <span>&#10003;</span> } else { <span>1</span> }
                            </button>
                            <div>
                                <h6 class="mb-1 fw-bold">Meet de opening na</h6>
                                <p class="text-muted small mb-0">Meet de vrije opening en vergelijk die direct met de bestelmaat hieronder.</p>
                            </div>
                        </div>

                        <div class="verificatie-maten mb-3 ps-5">
                            <div class="verificatie-maat">
                                <div class="verificatie-maat-waarde">@FormatMm(paneel.OpeningB)</div>
                                <div class="verificatie-maat-label">breedte in opening</div>
                            </div>
                            <div class="verificatie-maat-keer">&#215;</div>
                            <div class="verificatie-maat">
                                <div class="verificatie-maat-waarde">@FormatMm(paneel.OpeningH)</div>
                                <div class="verificatie-maat-label">hoogte in opening</div>
                            </div>
                        </div>

                        @if (r.MaatInfo is not null)
                        {
                            <HulpDetailsBlok Titel="Technische uitleg en berekening"
                                             Beschrijving="Open alleen als u wilt nalopen hoe opening, speling en bestelmaten samenhangen."
                                             CssClass="verificatie-techniek ps-5 small text-muted">
                                <div class="verificatie-afleiding mt-2">
                                    <div class="fw-semibold mb-1">@PaneelMaatUitlegHelper.MaatOmTeBestellenLabelMetTerm</div>
                                    <div>Breedte: @PaneelMaatUitlegHelper.BreedteFormule(r.MaatInfo)</div>
                                    @if (r.MaatInfo.TotaleInkortingBreedte > 0.001)
                                    {
                                        <div class="mb-1">@PaneelMaatUitlegHelper.BreedteAftrekUitleg(r.MaatInfo)</div>
                                    }
                                    <div>Hoogte: @PaneelMaatUitlegHelper.HoogteFormule(r.MaatInfo)</div>
                                    @if (r.MaatInfo.TotaleInkortingHoogte > 0.001)
                                    {
                                        <div>@PaneelMaatUitlegHelper.HoogteAftrekUitleg(r.MaatInfo)</div>
                                    }
                                </div>
                            </HulpDetailsBlok>
                        }
                    </div>

                    @if (paneel.IsDeur)
                    {
                        @* ── Controle 2: Controleer de gaatjesrij ── *@
                        <div class="verificatie-check @(checks.ScharnierPositiesOk ? "verificatie-check-ok" : "") mb-4">
                            <div class="d-flex align-items-start gap-3 mb-3">
                                <button class="verificatie-check-cirkel @(checks.ScharnierPositiesOk ? "ok" : "")"
                                        @onclick="() => ToggleScharnierCheck(r)"
                                        title="@(checks.ScharnierPositiesOk ? "Vink af" : "Markeer als gecontroleerd")"
                                        data-testid="verificatie-check-toggle-scharnier">
                                @if (checks.ScharnierPositiesOk) { <span>&#10003;</span> } else { <span>2</span> }
                                </button>
                                <div>
                                    <h6 class="mb-1 fw-bold">Controleer de gaatjesrij</h6>
                                    <p class="text-muted small mb-0">Controleer per scharnier de @(r.ScharnierZijde == ScharnierZijde.Links ? "linker" : "rechter") gaatjesrij vanaf boven.</p>
                                </div>
                            </div>

                            @if (r.Boorgaten.Any(g => g.Onderbouwing is not null))
                            {
                                <div class="verificatie-instructies ps-5 mb-3">
                                    @for (int j = 0; j < r.Boorgaten.Count; j++)
                                    {
                                        var g = r.Boorgaten[j];
                                        var o = g.Onderbouwing;
                                        if (o is not null)
                                        {
                                            <div class="verificatie-instructie">
                                                <div class="verificatie-instructie-nr">@(j + 1)</div>
                                                <div>
                                                    <div class="fw-semibold">Scharnier @(j + 1) — @o.KastNaam</div>
                                                    <div class="text-muted small">
                                                        Midden van de scharnierplaat tussen gat <strong>@o.GaatBovenIndex</strong> (@FormatMm(o.GaatBovenY) van boven)
                                                        en gat <strong>@o.GaatOnderIndex</strong> (@FormatMm(o.GaatOnderY) van boven).
                                                        Midden op <strong>@FormatMm(o.MontagePlaatMiddenInKast)</strong> in de kast.
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            }

                            <HulpDetailsBlok Titel="Technische verdieping en visualisatie"
                                             Beschrijving="Open alleen als u de gatenrij en scharnieronderbouwing technisch wilt nalopen."
                                             CssClass="verificatie-techniek ps-5">
                                <div class="mt-3">
                                    <ScharnierOverzichtVisueel Resultaat="@r"
                                                               Toewijzing="@paneel.Toewijzing"
                                                               Kasten="@paneel.PaneelKasten"
                                                               MaxHoogte="480" />
                                    <div class="small text-muted mt-2">
                                        <span>Scharnierzijde: <strong>@(r.ScharnierZijde == ScharnierZijde.Links ? "links" : "rechts")</strong></span>
                                        <span class="ms-3">Afstand scharnierpot tot rand: <strong>@FormatMm(paneel.PotHartVanRand)</strong></span>
                                    </div>
                                </div>
                            </HulpDetailsBlok>
                        </div>
                    }
            </div>

            @* ── Rechterkolom: paneel visualisatie ── *@
            <div class="col-lg-4">
                <div class="sticky-top" style="top: 4rem;">
                    <div class="text-center mb-2">
                        <PaneelVisueel Resultaat="@r" MaxHoogte="200" />
                    </div>
                        <div class="verificatie-zijkader small text-muted">
                            <div class="fw-semibold text-body mb-1">Paneelbeeld</div>
                            <div>@FormatMm(r.Breedte) &#215; @FormatMm(r.Hoogte) · @paneel.OpenChecksLabel</div>
                            @if (paneel.IsDeur)
                            {
                                <div>@r.Boorgaten.Count @(r.Boorgaten.Count == 1 ? "potscharniergat" : "potscharniergaten") &#216;@(r.Boorgaten.FirstOrDefault()?.Diameter ?? 35) mm</div>
                            }
                        </div>
                    </div>
            </div>
        </div>

        @if (pagina.Resultaten.Count > 1)
        {
            <details class="verificatie-paneelselectie mt-4"
                     data-testid="verificatie-paneelselectie-details">
                <summary class="verificatie-paneelselectie-summary"
                         data-testid="verificatie-paneelselectie-summary">
                    <div>
                        <div class="fw-semibold">Andere panelen</div>
                        <div class="small text-muted">Open dit alleen als u bewust naar een ander paneel wilt wisselen.</div>
                    </div>
                    <span class="small text-muted">@pagina.Resultaten.Count panelen</span>
                </summary>
                <div class="verificatie-paneelselectie-lijst">
                    @for (int i = 0; i < pagina.Resultaten.Count; i++)
                    {
                        var ri = pagina.Resultaten[i];
                        var idx = i;
                        var isActief = idx == _paneelIndex;
                        var isOk = AlleChecksVoorPaneel(idx, ri);

                        <button class="btn @(isActief ? "btn-primary" : isOk ? "btn-outline-success" : "btn-outline-secondary") btn-sm verificatie-paneelselectie-knop"
                                @onclick="() => GaNaarPaneel(idx)"
                                disabled="@isActief">
                            <span class="fw-semibold">Paneel @(i + 1) · @ri.KastNaam</span>
                            <span class="small @(isActief ? "opacity-75" : "text-muted")">@PaneelTabStatusTekst(idx, ri)</span>
                        </button>
                    }
                </div>
            </details>
        }

        @* Navigatie onderaan *@
        <hr />
        <div class="d-flex justify-content-between align-items-center">
            <button class="btn btn-outline-secondary" @onclick="VorigePaneel">
                &#8592; @(_paneelIndex == 0 ? "Terug naar taaklijst" : "Vorig paneel")
            </button>
            <div class="text-muted small">
                @if (AlleChecksVoorPaneel(_paneelIndex, r))
                {
                    <span class="text-success fw-semibold">&#10003; Alle controles afgevinkt</span>
                }
                else
                {
                    <span>@paneel.AantalAfgevinkt van @paneel.TotaalChecks controles afgevinkt</span>
                }
            </div>
            <button class="btn btn-success" @onclick="VolgendPaneel">
                @if (_paneelIndex < pagina.Resultaten.Count - 1)
                {
                    <span>Paneel @(_paneelIndex + 2) &#8594;</span>
                }
                else
                {
                    <span>Afronden &#8594;</span>
                }
            </button>
        </div>
    </div>
}
else if (_fase == VerificatieFase.Afronding && pagina.Afronding is not null)
{
    var afronding = pagina.Afronding;

    <div class="card mb-4" data-testid="verificatie-completion-card">
        <div class="card-body text-center py-5">
            @if (afronding.AlleGeverifieerd)
            {
                <div class="verificatie-resultaat-icoon succes">&#10003;</div>
                <h4 class="text-success">Alle @pagina.Resultaten.Count kastmetingen gecontroleerd</h4>
                <p class="text-muted">Alle controles op openingen en rijen systeemgaten zijn afgevinkt. Ga nu verder naar de bestellijst; delen en afdrukken blijven hieronder beschikbaar.</p>
            }
            else
            {
                <div class="verificatie-resultaat-icoon waarschuwing">&#9888;</div>
                <h4>@afronding.AantalGeverifieerd van @pagina.Resultaten.Count panelen afgevinkt</h4>
                <p class="text-muted">Niet alle controles zijn afgevinkt. Werk de ontbrekende controles af, of ga toch door naar de bestellijst als dat nu nodig is.</p>
            }

            <div class="d-flex flex-column align-items-center gap-3 mt-4">
                <a class="btn btn-success btn-lg px-4"
                   href="bestellijst"
                   data-testid="verificatie-completion-primary-button">
                    @(afronding.AlleGeverifieerd ? "Ga naar bestellijst →" : "Toch naar bestellijst →")
                </a>

                <div class="d-flex justify-content-center gap-3 flex-wrap"
                     data-testid="verificatie-completion-secondary-actions">
                    <button class="btn btn-outline-secondary" @onclick="TerugNaarOverzicht">&#8592; Terug naar taaklijst</button>
                    <button class="btn btn-outline-secondary" @onclick="DeelResultaat">&#128279; Deel link</button>
                    <button class="btn btn-outline-secondary" @onclick="PrintResultaat">&#128424; Afdrukken</button>
                </div>
            </div>

        </div>
    </div>
}

<StapNavigatie HuidigeStap="verificatie"
               VorigeHref="panelen"
               VolgendeHref="bestellijst" />
