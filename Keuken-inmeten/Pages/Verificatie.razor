@page "/verificatie"
@inject KeukenStateService State
@inject PersistentieService Persistentie
@inject IJSRuntime JS

<PageTitle>Stap 3 — Verificatie</PageTitle>

<StapIndicator HuidigeStap="verificatie" />

<h2 class="page-header">Stap 3: Verificatie</h2>
<p class="text-muted">Meet de bestaande kastopeningen na en controleer of de systeemgaten kloppen. Panelen worden daarna besteld op basis van uw maten.</p>

<TerminologieUitleg Sleutels="openingsmaat,werkmaat,gaatjesrij,montageplaat,pothart"
                    Beschrijving="Deze woordenlijst helpt bij de controletermen die u in de verificatiestap ziet." />

@{
    var resultaten = State.BerekenResultaten();
}

@if (resultaten.Count == 0)
{
    <div class="alert alert-warning">
        Geen panelen geconfigureerd. <a href="panelen">Ga terug om panelen toe te wijzen.</a>
    </div>
}
else if (_fase == VerificatieFase.Overzicht)
{
    @* Wandoverzichten *@
    @foreach (var wand in State.Wanden)
    {
        var wandKasten = State.KastenVoorWand(wand.Id);
        if (wandKasten.Count == 0) continue;
        var wandApparaten = State.ApparatenVoorWand(wand.Id);
        var toewijzingenVoorWand = State.Toewijzingen
            .Where(t => t.KastIds.Any(id => wandKasten.Any(k => k.Id == id)))
            .ToList();
        var resultatenOpId = resultaten
            .Where(r => r.ToewijzingId != Guid.Empty)
            .ToDictionary(r => r.ToewijzingId);

        <div class="mb-3">
            <div class="small fw-semibold text-muted mb-1">&#128205; @wand.Naam</div>
            <div class="paneel-overzicht-scroll">
                <WandPaneelOverzicht Kasten="@wandKasten"
                                     Apparaten="@wandApparaten"
                                     WandBreedte="@wand.Breedte"
                                     WandHoogte="@wand.Hoogte"
                                     PlintHoogte="@wand.PlintHoogte"
                                     AlleToewijzingen="@toewijzingenVoorWand"
                                     ResultatenOpToewijzingId="@resultatenOpId" />
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Te controleren kastopeningen</h5>
            <p class="text-muted small">Er zijn <strong>@resultaten.Count</strong> panelen. Meet voor elk paneel de kastopening na en controleer het gaatjespatroon op de kastromp.</p>

            <div class="table-responsive mb-3">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Kast</th>
                            <th>Wand</th>
                            <th>Type</th>
                            <th class="text-end">Opening B&#215;H</th>
                            <th class="text-center">Scharnieren</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < resultaten.Count; i++)
                        {
                            var r = resultaten[i];
                            var idx = i;
                            var wandNaam = State.WandNaamVoorKasten(r.KastIds);
                            var geverifieerd = AlleChecksVoorPaneel(idx, r);
                            var openingB = r.MaatInfo?.OpeningsRechthoek.Breedte ?? r.Breedte;
                            var openingH = r.MaatInfo?.OpeningsRechthoek.Hoogte ?? r.Hoogte;
                            <tr class="@(geverifieerd ? "table-success" : "")" style="cursor:pointer" @onclick="() => GaNaarPaneel(idx)">
                                <td class="text-muted">@(i + 1)</td>
                                <td><strong>@r.KastNaam</strong></td>
                                <td class="text-muted small">@wandNaam</td>
                                <td><span class="badge @TypeBadgeClass(r.Type)">@TypeNaam(r.Type)</span></td>
                                <td class="text-end text-nowrap">@FormatMm(openingB) &#215; @FormatMm(openingH)</td>
                                <td class="text-center">
                                    @if (r.Type == PaneelType.Deur && r.Boorgaten.Count > 0)
                                    {
                                        <span class="badge bg-body-secondary border">@r.Boorgaten.Count</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (geverifieerd)
                                    {
                                        <span class="text-success fw-bold">&#10003;</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">&#8226;</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @{
                var aantalAfgerond = Enumerable.Range(0, resultaten.Count).Count(i => AlleChecksVoorPaneel(i, resultaten[i]));
                var eersteOngecontroleerd = Enumerable.Range(0, resultaten.Count)
                    .FirstOrDefault(i => !AlleChecksVoorPaneel(i, resultaten[i]), 0);
                var alGestart = aantalAfgerond > 0;
            }
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-success btn-lg" @onclick="() => GaNaarPaneel(eersteOngecontroleerd)">
                    @(alGestart ? "Ga verder met verificatie" : "Start verificatie") &#8594;
                </button>
                @if (alGestart)
                {
                    <span class="text-muted small">@aantalAfgerond van @resultaten.Count afgerond</span>
                }
            </div>
        </div>
    </div>
}
else if (_fase == VerificatieFase.PaneelVerificatie && _paneelIndex < resultaten.Count)
{
    var r = resultaten[_paneelIndex];
    var toewijzing = State.Toewijzingen.FirstOrDefault(t => t.Id == r.ToewijzingId) ?? State.Toewijzingen[_paneelIndex];
    var potHartVanRand = r.Boorgaten.FirstOrDefault()?.X ?? toewijzing.PotHartVanRand;
    var paneelKasten = State.ZoekKasten(r.KastIds);
    var checks = GetChecks(_paneelIndex);
    var isDeur = r.Type == PaneelType.Deur && r.Boorgaten.Count > 0;
    var openingB = r.MaatInfo?.OpeningsRechthoek.Breedte ?? r.Breedte;
    var openingH = r.MaatInfo?.OpeningsRechthoek.Hoogte ?? r.Hoogte;
    var aantalAfgevinkt = AantalAfgevinktVoorPaneel(_paneelIndex, r);
    var totaalChecks = isDeur ? 2 : 1;

    @* Paneel-tabs navigatie *@
    <div class="mb-3 verificatie-tabs">
        <ul class="nav nav-pills nav-fill flex-wrap">
            @for (int i = 0; i < resultaten.Count; i++)
            {
                var ri = resultaten[i];
                var idx = i;
                var isActief = idx == _paneelIndex;
                var isOk = AlleChecksVoorPaneel(idx, ri);
                <li class="nav-item">
                    <button class="nav-link @(isActief ? "active" : "") @(isOk && !isActief ? "verificatie-tab-ok" : "")"
                            @onclick="() => GaNaarPaneel(idx)">
                        @if (isOk)
                        {
                            <span class="verificatie-tab-check">&#10003;</span>
                        }
                        @(i + 1). @ri.KastNaam
                    </button>
                </li>
            }
        </ul>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <span class="badge @TypeBadgeClass(r.Type) me-2">@TypeNaam(r.Type)</span>
                @r.KastNaam
            </h5>
            <span class="text-muted small">@State.WandNaamVoorKasten(r.KastIds)</span>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-lg-8">

                    @* ── Controle 1: Meet de kastopening na ── *@
                    <div class="verificatie-check @(checks.MatenOk ? "verificatie-check-ok" : "") mb-4">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <button class="verificatie-check-cirkel @(checks.MatenOk ? "ok" : "")"
                                    @onclick="() => ToggleCheck(_paneelIndex, c => c.MatenOk = !c.MatenOk)"
                                    title="@(checks.MatenOk ? "Vink af" : "Markeer als gecontroleerd")">
                                @if (checks.MatenOk) { <span>&#10003;</span> } else { <span>1</span> }
                            </button>
                            <div>
                                <h6 class="mb-1 fw-bold">Meet de kastopening na</h6>
                                <p class="text-muted small mb-0">Meet met een meetlint de vrije binnenafmeting van de kast (opening zonder deuren). Vergelijk met de maten hieronder.</p>
                            </div>
                        </div>

                        <div class="verificatie-maten mb-3 ps-5">
                            <div class="verificatie-maat">
                                <div class="verificatie-maat-waarde">@FormatMm(openingB)</div>
                                <div class="verificatie-maat-label">breedte opening</div>
                            </div>
                            <div class="verificatie-maat-keer">&#215;</div>
                            <div class="verificatie-maat">
                                <div class="verificatie-maat-waarde">@FormatMm(openingH)</div>
                                <div class="verificatie-maat-label">hoogte opening</div>
                            </div>
                        </div>

                        @if (r.MaatInfo is not null && r.MaatInfo.TotaleInkortingBreedte + r.MaatInfo.TotaleInkortingHoogte > 0.001)
                        {
                            <div class="verificatie-afleiding ps-5 small text-muted">
                                <div class="fw-semibold mb-1">Hieruit volgt een paneel van:</div>
                                <div>Breedte: @FormatMm(r.MaatInfo.PaneelRechthoek.Breedte) (@BreedteSpelingKort(r.MaatInfo))</div>
                                <div>Hoogte: @FormatMm(r.MaatInfo.PaneelRechthoek.Hoogte) (@HoogteSpelingKort(r.MaatInfo))</div>
                            </div>
                        }
                        else if (r.MaatInfo is not null)
                        {
                            <div class="verificatie-afleiding ps-5 small text-muted">
                                Paneel: @FormatMm(r.MaatInfo.PaneelRechthoek.Breedte) &#215; @FormatMm(r.MaatInfo.PaneelRechthoek.Hoogte) (geen spelingaftrek op vrije randen)
                            </div>
                        }
                    </div>

                    @if (isDeur)
                    {
                        @* ── Controle 2: Controleer de gaatjesrij ── *@
                        <div class="verificatie-check @(checks.ScharnierPositiesOk ? "verificatie-check-ok" : "") mb-4">
                            <div class="d-flex align-items-start gap-3 mb-3">
                                <button class="verificatie-check-cirkel @(checks.ScharnierPositiesOk ? "ok" : "")"
                                        @onclick="() => ToggleCheck(_paneelIndex, c => c.ScharnierPositiesOk = !c.ScharnierPositiesOk)"
                                        title="@(checks.ScharnierPositiesOk ? "Vink af" : "Markeer als gecontroleerd")">
                                    @if (checks.ScharnierPositiesOk) { <span>&#10003;</span> } else { <span>2</span> }
                                </button>
                                <div>
                                    <h6 class="mb-1 fw-bold">Controleer de rij systeemgaten (gaatjesrij) op de kastromp</h6>
                                    <p class="text-muted small mb-0">
                                        Open de kast en bekijk de @(r.ScharnierZijde == ScharnierZijde.Links ? "linker" : "rechter") zijwand.
                                        Tel de systeemgaten af van boven voor elk scharnier.
                                    </p>
                                </div>
                            </div>

                            @if (r.Boorgaten.Any(g => g.Onderbouwing is not null))
                            {
                                <div class="verificatie-instructies ps-5 mb-3">
                                    @for (int j = 0; j < r.Boorgaten.Count; j++)
                                    {
                                        var g = r.Boorgaten[j];
                                        var o = g.Onderbouwing;
                                        if (o is not null)
                                        {
                                            <div class="verificatie-instructie">
                                                <div class="verificatie-instructie-nr">@(j + 1)</div>
                                                <div>
                                                    <div class="fw-semibold">Scharnier @(j + 1) — @o.KastNaam</div>
                                                    <div class="text-muted small">
                                                        Midden van de scharnierplaat tussen gat <strong>@o.GaatBovenIndex</strong> (@FormatMm(o.GaatBovenY) van boven)
                                                        en gat <strong>@o.GaatOnderIndex</strong> (@FormatMm(o.GaatOnderY) van boven).
                                                        Midden op <strong>@FormatMm(o.MontagePlaatMiddenInKast)</strong> in de kast.
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            }

                            <div class="ps-5">
                                <ScharnierOverzichtVisueel Resultaat="@r"
                                                           Toewijzing="@toewijzing"
                                                           Kasten="@paneelKasten"
                                                           MaxHoogte="480" />
                                <div class="small text-muted mt-2">
                                    <span>Scharnierzijde: <strong>@(r.ScharnierZijde == ScharnierZijde.Links ? "links" : "rechts")</strong></span>
                                    <span class="ms-3">Afstand scharnierpot tot rand: <strong>@FormatMm(potHartVanRand)</strong></span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* ── Rechterkolom: paneel visualisatie ── *@
                <div class="col-lg-4">
                    <div class="sticky-top" style="top: 4rem;">
                        <div class="text-center mb-2">
                            <PaneelVisueel Resultaat="@r" MaxHoogte="200" />
                        </div>
                        <div class="card card-body small bg-body-tertiary">
                            <div class="fw-semibold mb-1">Berekend paneel</div>
                            <div>@FormatMm(r.Breedte) &#215; @FormatMm(r.Hoogte)</div>
                            @if (isDeur)
                            {
                                <div class="text-muted">@r.Boorgaten.Count boorgaten &#216;@(r.Boorgaten.FirstOrDefault()?.Diameter ?? 35) mm</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* Navigatie onderaan *@
            <hr />
            <div class="d-flex justify-content-between align-items-center">
                <button class="btn btn-outline-secondary" @onclick="VorigePaneel">
                    &#8592; @(_paneelIndex == 0 ? "Terug naar overzicht" : "Vorig paneel")
                </button>
                <div class="text-muted small">
                    @if (AlleChecksVoorPaneel(_paneelIndex, r))
                    {
                        <span class="text-success fw-semibold">&#10003; Alle controles afgevinkt</span>
                    }
                    else
                    {
                        <span>@aantalAfgevinkt van @totaalChecks controles afgevinkt</span>
                    }
                </div>
                <button class="btn btn-success" @onclick="VolgendPaneel">
                    @if (_paneelIndex < resultaten.Count - 1)
                    {
                        <span>Paneel @(_paneelIndex + 2) &#8594;</span>
                    }
                    else
                    {
                        <span>Afronden &#8594;</span>
                    }
                </button>
            </div>
        </div>
    </div>
}
else if (_fase == VerificatieFase.Afronding)
{
    var aantalGeverifieerd = Enumerable.Range(0, resultaten.Count).Count(i => AlleChecksVoorPaneel(i, resultaten[i]));
    var alleGeverifieerd = aantalGeverifieerd == resultaten.Count;

    <div class="card mb-4">
        <div class="card-body text-center py-5">
            @if (alleGeverifieerd)
            {
                <div class="verificatie-resultaat-icoon succes">&#10003;</div>
                <h4 class="text-success">Alle @resultaten.Count kastmetingen gecontroleerd</h4>
                <p class="text-muted">Alle controles op openingen en rijen systeemgaten zijn afgevinkt. U kunt doorgaan naar de bestellijst.</p>
            }
            else
            {
                <div class="verificatie-resultaat-icoon waarschuwing">&#9888;</div>
                <h4>@aantalGeverifieerd van @resultaten.Count panelen afgevinkt</h4>
                <p class="text-muted">Niet alle controles zijn afgevinkt. U kunt teruggaan om de ontbrekende controles te voltooien, of toch doorgaan.</p>
            }

            <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
                <button class="btn btn-outline-secondary" @onclick="TerugNaarOverzicht">&#8592; Terug naar overzicht</button>
                <button class="btn btn-outline-secondary" @onclick="DeelResultaat">&#128279; Deel link</button>
                <button class="btn btn-outline-primary" @onclick="PrintResultaat">&#128424; Afdrukken</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_deelStatus))
            {
                <div class="deel-status mt-2 @(_deelStatusIsFout ? "fout" : "")">@_deelStatus</div>
            }
        </div>
    </div>
}

<StapNavigatie HuidigeStap="verificatie"
               VorigeHref="panelen"
               VorigeLabel="Terug naar panelen"
               VolgendeHref="bestellijst"
               VolgendeLabel="Naar bestellijst" />

@code {
    private enum VerificatieFase { Overzicht, PaneelVerificatie, Afronding }

    private VerificatieFase _fase = VerificatieFase.Overzicht;
    private int _paneelIndex;
    private string? _deelStatus;
    private bool _deelStatusIsFout;

    private class VerificatieChecks
    {
        public bool MatenOk { get; set; }
        public bool ScharnierPositiesOk { get; set; }
    }

    private readonly Dictionary<int, VerificatieChecks> _checks = [];

    private VerificatieChecks GetChecks(int index)
    {
        if (!_checks.TryGetValue(index, out var checks))
        {
            checks = new VerificatieChecks();
            _checks[index] = checks;
        }
        return checks;
    }

    private void ToggleCheck(int index, Action<VerificatieChecks> toggle)
        => toggle(GetChecks(index));

    private bool AlleChecksVoorPaneel(int index, PaneelResultaat r)
    {
        if (!_checks.TryGetValue(index, out var checks)) return false;
        if (!checks.MatenOk) return false;
        if (r.Type == PaneelType.Deur && r.Boorgaten.Count > 0)
            return checks.ScharnierPositiesOk;
        return true;
    }

    private int AantalAfgevinktVoorPaneel(int index, PaneelResultaat r)
    {
        if (!_checks.TryGetValue(index, out var checks)) return 0;
        var count = checks.MatenOk ? 1 : 0;
        if (r.Type == PaneelType.Deur && r.Boorgaten.Count > 0 && checks.ScharnierPositiesOk)
            count++;
        return count;
    }

    private void GaNaarPaneel(int index)
    {
        _paneelIndex = index;
        _fase = VerificatieFase.PaneelVerificatie;
    }

    private void VorigePaneel()
    {
        if (_paneelIndex > 0)
            _paneelIndex--;
        else
            _fase = VerificatieFase.Overzicht;
    }

    private void VolgendPaneel()
    {
        var resultaten = State.BerekenResultaten();
        if (_paneelIndex < resultaten.Count - 1)
            _paneelIndex++;
        else
            _fase = VerificatieFase.Afronding;
    }

    private void TerugNaarOverzicht() => _fase = VerificatieFase.Overzicht;

    private static string TypeNaam(PaneelType type) => VisualisatieHelper.PaneelTypeLabel(type);

    private static string TypeBadgeClass(PaneelType type) => type switch
    {
        PaneelType.Deur => "bg-primary",
        PaneelType.LadeFront => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private static string BreedteSpelingKort(PaneelMaatInfo maatInfo)
    {
        var delen = SpelingDelen(maatInfo.RaaktLinks, maatInfo.InkortingLinks, "links",
                                 maatInfo.RaaktRechts, maatInfo.InkortingRechts, "rechts").ToList();
        return delen.Count == 0
            ? "geen aftrek"
            : $"opening {FormatMm(maatInfo.OpeningsRechthoek.Breedte)} − {string.Join(" − ", delen)}";
    }

    private static string HoogteSpelingKort(PaneelMaatInfo maatInfo)
    {
        var delen = SpelingDelen(maatInfo.RaaktOnder, maatInfo.InkortingOnder, "onder",
                                 maatInfo.RaaktBoven, maatInfo.InkortingBoven, "boven").ToList();
        return delen.Count == 0
            ? "geen aftrek"
            : $"opening {FormatMm(maatInfo.OpeningsRechthoek.Hoogte)} − {string.Join(" − ", delen)}";
    }

    private static IEnumerable<string> SpelingDelen(
        bool eersteRaakt, double eersteWaarde, string eersteLabel,
        bool tweedeRaakt, double tweedeWaarde, string tweedeLabel)
    {
        if (eersteRaakt) yield return $"{FormatMm(eersteWaarde)} {eersteLabel}";
        if (tweedeRaakt) yield return $"{FormatMm(tweedeWaarde)} {tweedeLabel}";
    }

    private static string FormatMm(double waarde)
        => $"{waarde:0.#} mm";

    private async Task PrintResultaat()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task DeelResultaat()
    {
        try
        {
            var deelUrl = Persistentie.MaakDeelUrl("verificatie");
            var resultaat = await JS.InvokeAsync<string>("keukenShare.shareUrl", deelUrl, "Keuken-inmeten", "Bekijk deze keukenconfiguratie");

            (_deelStatus, _deelStatusIsFout) = resultaat switch
            {
                "shared" => ("De share-sheet is geopend met de publieke GitHub Pages-link.", false),
                "copied" => ("De publieke deellink is gekopieerd naar het klembord.", false),
                "cancelled" => ("Delen geannuleerd; de link is niet verstuurd.", false),
                _ => ("Delen lukte niet in deze browser.", true)
            };
        }
        catch
        {
            _deelStatus = "Deellink maken of kopieren lukte niet.";
            _deelStatusIsFout = true;
        }
    }
}
