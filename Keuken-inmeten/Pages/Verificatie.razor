@page "/verificatie"
@using Keuken_inmeten.Services.Interop
@inject KeukenStateService State
@inject DeelLinkService Delen
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Stap 3 — Verificatie</PageTitle>

<StapIndicator HuidigeStap="verificatie" />

<h2 class="page-header">Stap 3: Verificatie</h2>
@if (_fase != VerificatieFase.Afronding)
{
    <p class="text-muted mb-3">Controleer per paneel eerst de maat in de opening en daarna de systeemgaten. De bestelmaat moet logisch volgen uit opening en speling.</p>
    <div class="stap-ondersteuning mb-3" data-testid="verificatie-stap-ondersteuning">
        <StapHulpDrawer StapId="verificatie" KnopLabel="Staphulp" />
        <TerminologieUitleg Compact="true"
                            CompactLabel="Begrippen"
                            Sleutels="openingsmaat,werkmaat,gaatjesrij,montageplaat,pothart"
                            Beschrijving="Deze woordenlijst helpt bij de controletermen die u in de verificatiestap ziet." />
    </div>
}

@{
    var flowStatus = StappenFlowHelper.BepaalStatus(State);
    var routeGate = StappenFlowHelper.BepaalRouteGate("verificatie", flowStatus);
    var resultaten = State.BerekenResultaten();
}

@if (routeGate is not null)
{
    <StapRouteMelding Gate="@routeGate" />
}
else if (_fase == VerificatieFase.Overzicht)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Verificatietaken per wand en paneel</h5>
            <p class="text-muted small">Er zijn <strong>@resultaten.Count</strong> panelen. Open per paneel de volgende controle; maatuitleg en techniek blijven daarna in de detailstap apart staan.</p>

            @{
                var verificatieTaken = resultaten
                    .Select((r, index) => new
                    {
                        Index = index,
                        Resultaat = r,
                        WandNaam = State.WandNaamVoorKasten(r.KastIds),
                        Geverifieerd = AlleChecksVoorPaneel(index, r),
                        OpenChecks = OpenChecksVoorPaneel(index, r),
                        VolgendeControle = VolgendeControleTitel(index, r),
                        OpeningB = r.MaatInfo?.OpeningsRechthoek.Breedte ?? r.Breedte,
                        OpeningH = r.MaatInfo?.OpeningsRechthoek.Hoogte ?? r.Hoogte
                    })
                    .ToList();
                var taakGroepen = State.Wanden
                    .Select(wand => new
                    {
                        Wand = wand,
                        Taken = verificatieTaken
                            .Where(taak => taak.WandNaam == wand.Naam)
                            .ToList()
                    })
                    .Where(groep => groep.Taken.Count > 0)
                    .ToList();
                var aantalAfgerond = Enumerable.Range(0, resultaten.Count).Count(i => AlleChecksVoorPaneel(i, resultaten[i]));
                var eersteOngecontroleerd = Enumerable.Range(0, resultaten.Count)
                    .FirstOrDefault(i => !AlleChecksVoorPaneel(i, resultaten[i]), 0);
                var alGestart = aantalAfgerond > 0;
                var totaalOpenChecks = Enumerable.Range(0, resultaten.Count).Sum(i => OpenChecksVoorPaneel(i, resultaten[i]));
                var samenvattingPaneelIndex = aantalAfgerond == resultaten.Count ? Math.Max(0, resultaten.Count - 1) : eersteOngecontroleerd;
                var volgendePaneel = resultaten[samenvattingPaneelIndex];
            }

            <div class="verificatie-samenvatting mb-3">
                <div class="verificatie-samenvatting-item">
                    <div class="verificatie-samenvatting-label">Volgende taak</div>
                    <div class="fw-semibold">@(aantalAfgerond == resultaten.Count ? "Alle controles zijn klaar" : VolgendeControleTitel(samenvattingPaneelIndex, volgendePaneel))</div>
                    <div class="small text-muted">@((aantalAfgerond == resultaten.Count) ? "U kunt afronden of een taak opnieuw openen." : $"Paneel {samenvattingPaneelIndex + 1} · {volgendePaneel.KastNaam}")</div>
                </div>
                <div class="verificatie-samenvatting-item">
                    <div class="verificatie-samenvatting-label">Voortgang</div>
                    <div class="fw-semibold">@aantalAfgerond van @resultaten.Count taken klaar</div>
                    <div class="small text-muted">@((aantalAfgerond == resultaten.Count) ? "Alle checklistcontroles zijn afgevinkt." : "Gebruik de taaklijst hieronder om de volgende open controle te kiezen.")</div>
                </div>
                <div class="verificatie-samenvatting-item">
                    <div class="verificatie-samenvatting-label">Open controles</div>
                    <div class="fw-semibold">@totaalOpenChecks nog te doen</div>
                    <div class="small text-muted">Technische verdieping opent pas wanneer u die echt nodig hebt.</div>
                </div>
            </div>

            <div class="verificatie-taaklijst mb-3" data-testid="verificatie-taaklijst">
                @foreach (var groep in taakGroepen)
                {
                    var openTaken = groep.Taken.Count(taak => !taak.Geverifieerd);

                    <div class="card shadow-sm mb-3"
                         data-testid="verificatie-taakgroep"
                         data-wand-naam="@groep.Wand.Naam">
                        <div class="card-header bg-body-tertiary d-flex justify-content-between align-items-start gap-3 flex-wrap">
                            <div>
                                <h6 class="mb-1">@groep.Wand.Naam</h6>
                                <div class="small text-muted">@groep.Taken.Count panelen · @groep.Taken.Count(taak => taak.Geverifieerd) klaar · @openTaken open</div>
                            </div>
                        </div>
                        <div class="list-group list-group-flush">
                            @foreach (var taak in groep.Taken)
                            {
                                <div class="list-group-item"
                                     data-testid="verificatie-taak-item"
                                     data-wand-naam="@groep.Wand.Naam"
                                     data-paneel-index="@taak.Index">
                                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                        <div class="verificatie-taak-meta">
                                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                                <span class="small text-muted">Paneel @(taak.Index + 1)</span>
                                                <span class="fw-semibold">@taak.Resultaat.KastNaam</span>
                                                @if (taak.Geverifieerd)
                                                {
                                                    <span class="small text-success fw-semibold">Klaar</span>
                                                }
                                            </div>
                                            <div class="small text-muted">@TypeNaam(taak.Resultaat.Type) · maat in opening @FormatMm(taak.OpeningB) &#215; @FormatMm(taak.OpeningH)</div>
                                            <div class="small mt-1">@taak.VolgendeControle</div>
                                        </div>
                                        <div class="verificatie-taak-acties">
                                            <div class="small text-muted text-sm-end">@OpenChecksLabel(taak.Index, taak.Resultaat)</div>
                                            <button class="btn btn-outline-primary btn-sm"
                                                    @onclick="() => GaNaarPaneel(taak.Index)"
                                                    data-testid="verificatie-open-controle-button">
                                                Open controle
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-success btn-lg"
                        @onclick="() => GaNaarPaneel(eersteOngecontroleerd)"
                        data-testid="verificatie-start-button">
                    @(alGestart ? "Open volgende taak" : "Start taaklijst") &#8594;
                </button>
                @if (alGestart)
                {
                    <span class="text-muted small">@aantalAfgerond van @resultaten.Count afgerond</span>
                }
            </div>
        </div>
    </div>
}
else if (_fase == VerificatieFase.PaneelVerificatie && _paneelIndex < resultaten.Count)
{
    var r = resultaten[_paneelIndex];
    var toewijzing = State.Toewijzingen.FirstOrDefault(t => t.Id == r.ToewijzingId) ?? State.Toewijzingen[_paneelIndex];
    var potHartVanRand = r.Boorgaten.FirstOrDefault()?.X ?? toewijzing.PotHartVanRand;
    var paneelKasten = State.ZoekKasten(r.KastIds);
    var checks = GetChecks(_paneelIndex);
    var isDeur = r.Type == PaneelType.Deur && r.Boorgaten.Count > 0;
    var openingB = r.MaatInfo?.OpeningsRechthoek.Breedte ?? r.Breedte;
    var openingH = r.MaatInfo?.OpeningsRechthoek.Hoogte ?? r.Hoogte;
    var aantalAfgevinkt = AantalAfgevinktVoorPaneel(_paneelIndex, r);
    var totaalChecks = isDeur ? 2 : 1;

    @* Paneel-tabs navigatie *@
    <div class="border rounded p-3 mb-3 bg-body-tertiary">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
            <div>
                <div class="text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Voortgang over alle panelen</div>
                <div class="fw-semibold">@Enumerable.Range(0, resultaten.Count).Count(i => AlleChecksVoorPaneel(i, resultaten[i])) van @resultaten.Count panelen klaar</div>
                <div class="small text-muted">Paneel @(_paneelIndex + 1) van @resultaten.Count staat nu open.</div>
            </div>
            <div class="small text-muted">@Enumerable.Range(0, resultaten.Count).Sum(i => OpenChecksVoorPaneel(i, resultaten[i])) open controles in deze stap</div>
        </div>
    </div>

    <div class="mb-3 verificatie-tabs">
        <ul class="nav nav-pills nav-fill flex-wrap">
            @for (int i = 0; i < resultaten.Count; i++)
            {
                var ri = resultaten[i];
                var idx = i;
                var isActief = idx == _paneelIndex;
                var isOk = AlleChecksVoorPaneel(idx, ri);
                <li class="nav-item">
                    <button class="nav-link @(isActief ? "active" : "") @(isOk && !isActief ? "verificatie-tab-ok" : "")"
                            @onclick="() => GaNaarPaneel(idx)">
                        <span class="fw-semibold">
                            @if (isOk)
                            {
                                <span class="verificatie-tab-check">&#10003;</span>
                            }
                            @(i + 1). @ri.KastNaam
                        </span>
                        <span class="small opacity-75">@PaneelTabStatusTekst(idx, ri)</span>
                    </button>
                </li>
            }
        </ul>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <span class="badge @TypeBadgeClass(r.Type) me-2">@TypeNaam(r.Type)</span>
                @r.KastNaam
            </h5>
            <span class="text-muted small">@State.WandNaamVoorKasten(r.KastIds)</span>
        </div>
        <div class="card-body">
            <div class="verificatie-samenvatting mb-4">
                <div class="verificatie-samenvatting-item">
                    <div class="verificatie-samenvatting-label">Nu controleren</div>
                    <div class="fw-semibold">@VolgendeControleTitel(_paneelIndex, r)</div>
                    <div class="small text-muted">@HuidigeControleHint(_paneelIndex, r)</div>
                </div>
                <div class="verificatie-samenvatting-item">
                    <div class="verificatie-samenvatting-label">Maat in opening</div>
                    <div class="fw-semibold">@FormatMm(openingB) &#215; @FormatMm(openingH)</div>
                    <div class="small text-muted">@PaneelMaatUitlegHelper.MaatOmTeBestellenLabel: @FormatMm(r.Breedte) &#215; @FormatMm(r.Hoogte)</div>
                </div>
                <div class="verificatie-samenvatting-item">
                    <div class="verificatie-samenvatting-label">Open controles</div>
                    <div class="fw-semibold">@OpenChecksLabel(_paneelIndex, r)</div>
                    <div class="small text-muted">@aantalAfgevinkt van @totaalChecks controles afgevinkt</div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-8">

                    @* ── Controle 1: Meet de kastopening na ── *@
                    <div class="verificatie-check @(checks.MatenOk ? "verificatie-check-ok" : "") mb-4">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <button class="verificatie-check-cirkel @(checks.MatenOk ? "ok" : "")"
                                    @onclick="() => ToggleCheck(_paneelIndex, c => c.MatenOk = !c.MatenOk)"
                                    title="@(checks.MatenOk ? "Vink af" : "Markeer als gecontroleerd")">
                                @if (checks.MatenOk) { <span>&#10003;</span> } else { <span>1</span> }
                            </button>
                            <div>
                                <h6 class="mb-1 fw-bold">Meet de maat in de opening na</h6>
                                <p class="text-muted small mb-0">Meet de vrije opening en vergelijk die met de maat hieronder. De maat om te bestellen staat er direct onder.</p>
                            </div>
                        </div>

                        <div class="verificatie-maten mb-3 ps-5">
                            <div class="verificatie-maat">
                                <div class="verificatie-maat-waarde">@FormatMm(openingB)</div>
                                <div class="verificatie-maat-label">breedte in opening</div>
                            </div>
                            <div class="verificatie-maat-keer">&#215;</div>
                            <div class="verificatie-maat">
                                <div class="verificatie-maat-waarde">@FormatMm(openingH)</div>
                                <div class="verificatie-maat-label">hoogte in opening</div>
                            </div>
                        </div>

                        @if (r.MaatInfo is not null)
                        {
                            <HulpDetailsBlok Titel="Technische uitleg en berekening"
                                             Beschrijving="Open alleen als u wilt nalopen hoe opening, speling en bestelmaten samenhangen."
                                             CssClass="verificatie-techniek ps-5 small text-muted">
                                <div class="verificatie-afleiding mt-2">
                                    <div class="fw-semibold mb-1">@PaneelMaatUitlegHelper.MaatOmTeBestellenLabelMetTerm</div>
                                    <div>Breedte: @PaneelMaatUitlegHelper.BreedteFormule(r.MaatInfo)</div>
                                    @if (r.MaatInfo.TotaleInkortingBreedte > 0.001)
                                    {
                                        <div class="mb-1">@PaneelMaatUitlegHelper.BreedteAftrekUitleg(r.MaatInfo)</div>
                                    }
                                    <div>Hoogte: @PaneelMaatUitlegHelper.HoogteFormule(r.MaatInfo)</div>
                                    @if (r.MaatInfo.TotaleInkortingHoogte > 0.001)
                                    {
                                        <div>@PaneelMaatUitlegHelper.HoogteAftrekUitleg(r.MaatInfo)</div>
                                    }
                                </div>
                            </HulpDetailsBlok>
                        }
                    </div>

                    @if (isDeur)
                    {
                        @* ── Controle 2: Controleer de gaatjesrij ── *@
                        <div class="verificatie-check @(checks.ScharnierPositiesOk ? "verificatie-check-ok" : "") mb-4">
                            <div class="d-flex align-items-start gap-3 mb-3">
                                <button class="verificatie-check-cirkel @(checks.ScharnierPositiesOk ? "ok" : "")"
                                        @onclick="() => ToggleCheck(_paneelIndex, c => c.ScharnierPositiesOk = !c.ScharnierPositiesOk)"
                                        title="@(checks.ScharnierPositiesOk ? "Vink af" : "Markeer als gecontroleerd")">
                                    @if (checks.ScharnierPositiesOk) { <span>&#10003;</span> } else { <span>2</span> }
                                </button>
                                <div>
                                    <h6 class="mb-1 fw-bold">Controleer de rij systeemgaten (gaatjesrij) op de kastromp</h6>
                                    <p class="text-muted small mb-0">Open de kast, kijk naar de @(r.ScharnierZijde == ScharnierZijde.Links ? "linker" : "rechter") zijwand en tel per scharnier de gaatjesrij vanaf boven.</p>
                                </div>
                            </div>

                            @if (r.Boorgaten.Any(g => g.Onderbouwing is not null))
                            {
                                <div class="verificatie-instructies ps-5 mb-3">
                                    @for (int j = 0; j < r.Boorgaten.Count; j++)
                                    {
                                        var g = r.Boorgaten[j];
                                        var o = g.Onderbouwing;
                                        if (o is not null)
                                        {
                                            <div class="verificatie-instructie">
                                                <div class="verificatie-instructie-nr">@(j + 1)</div>
                                                <div>
                                                    <div class="fw-semibold">Scharnier @(j + 1) — @o.KastNaam</div>
                                                    <div class="text-muted small">
                                                        Midden van de scharnierplaat tussen gat <strong>@o.GaatBovenIndex</strong> (@FormatMm(o.GaatBovenY) van boven)
                                                        en gat <strong>@o.GaatOnderIndex</strong> (@FormatMm(o.GaatOnderY) van boven).
                                                        Midden op <strong>@FormatMm(o.MontagePlaatMiddenInKast)</strong> in de kast.
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            }

                            <HulpDetailsBlok Titel="Technische verdieping en visualisatie"
                                             Beschrijving="Open alleen als u de gatenrij en scharnieronderbouwing technisch wilt nalopen."
                                             CssClass="verificatie-techniek ps-5">
                                <div class="mt-3">
                                    <ScharnierOverzichtVisueel Resultaat="@r"
                                                               Toewijzing="@toewijzing"
                                                               Kasten="@paneelKasten"
                                                               MaxHoogte="480" />
                                    <div class="small text-muted mt-2">
                                        <span>Scharnierzijde: <strong>@(r.ScharnierZijde == ScharnierZijde.Links ? "links" : "rechts")</strong></span>
                                        <span class="ms-3">Afstand scharnierpot tot rand: <strong>@FormatMm(potHartVanRand)</strong></span>
                                    </div>
                                </div>
                            </HulpDetailsBlok>
                        </div>
                    }
                </div>

                @* ── Rechterkolom: paneel visualisatie ── *@
                <div class="col-lg-4">
                    <div class="sticky-top" style="top: 4rem;">
                        <div class="text-center mb-2">
                            <PaneelVisueel Resultaat="@r" MaxHoogte="200" />
                        </div>
                        <div class="card card-body small bg-body-tertiary">
                            <div class="fw-semibold mb-1">Checkliststatus</div>
                            <div>@aantalAfgevinkt van @totaalChecks controles afgevinkt</div>
                            <div class="text-muted mb-3">@OpenChecksLabel(_paneelIndex, r)</div>
                            <div class="fw-semibold mb-1">Berekend paneel</div>
                            <div>@FormatMm(r.Breedte) &#215; @FormatMm(r.Hoogte)</div>
                            @if (isDeur)
                            {
                                <div class="text-muted">@r.Boorgaten.Count boorgaten &#216;@(r.Boorgaten.FirstOrDefault()?.Diameter ?? 35) mm</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* Navigatie onderaan *@
            <hr />
            <div class="d-flex justify-content-between align-items-center">
                <button class="btn btn-outline-secondary" @onclick="VorigePaneel">
                    &#8592; @(_paneelIndex == 0 ? "Terug naar taaklijst" : "Vorig paneel")
                </button>
                <div class="text-muted small">
                    @if (AlleChecksVoorPaneel(_paneelIndex, r))
                    {
                        <span class="text-success fw-semibold">&#10003; Alle controles afgevinkt</span>
                    }
                    else
                    {
                        <span>@aantalAfgevinkt van @totaalChecks controles afgevinkt</span>
                    }
                </div>
                <button class="btn btn-success" @onclick="VolgendPaneel">
                    @if (_paneelIndex < resultaten.Count - 1)
                    {
                        <span>Paneel @(_paneelIndex + 2) &#8594;</span>
                    }
                    else
                    {
                        <span>Afronden &#8594;</span>
                    }
                </button>
            </div>
        </div>
    </div>
}
else if (_fase == VerificatieFase.Afronding)
{
    var aantalGeverifieerd = Enumerable.Range(0, resultaten.Count).Count(i => AlleChecksVoorPaneel(i, resultaten[i]));
    var alleGeverifieerd = aantalGeverifieerd == resultaten.Count;

    <div class="card mb-4" data-testid="verificatie-completion-card">
        <div class="card-body text-center py-5">
            @if (alleGeverifieerd)
            {
                <div class="verificatie-resultaat-icoon succes">&#10003;</div>
                <h4 class="text-success">Alle @resultaten.Count kastmetingen gecontroleerd</h4>
                <p class="text-muted">Alle controles op openingen en rijen systeemgaten zijn afgevinkt. Ga nu verder naar de bestellijst; delen en afdrukken blijven hieronder beschikbaar.</p>
            }
            else
            {
                <div class="verificatie-resultaat-icoon waarschuwing">&#9888;</div>
                <h4>@aantalGeverifieerd van @resultaten.Count panelen afgevinkt</h4>
                <p class="text-muted">Niet alle controles zijn afgevinkt. Werk de ontbrekende controles af, of ga toch door naar de bestellijst als dat nu nodig is.</p>
            }

            <div class="d-flex flex-column align-items-center gap-3 mt-4">
                <a class="btn btn-success btn-lg px-4"
                   href="bestellijst"
                   data-testid="verificatie-completion-primary-button">
                    @(alleGeverifieerd ? "Ga naar bestellijst →" : "Toch naar bestellijst →")
                </a>

                <div class="d-flex justify-content-center gap-3 flex-wrap"
                     data-testid="verificatie-completion-secondary-actions">
                    <button class="btn btn-outline-secondary" @onclick="TerugNaarOverzicht">&#8592; Terug naar taaklijst</button>
                    <button class="btn btn-outline-secondary" @onclick="DeelResultaat">&#128279; Deel link</button>
                    <button class="btn btn-outline-secondary" @onclick="PrintResultaat">&#128424; Afdrukken</button>
                </div>
            </div>

        </div>
    </div>
}

<StapNavigatie HuidigeStap="verificatie"
               VorigeHref="panelen"
               VolgendeHref="bestellijst" />

@code {
    private enum VerificatieFase { Overzicht, PaneelVerificatie, Afronding }

    private VerificatieFase _fase = VerificatieFase.Overzicht;
    private int _paneelIndex;

    private class VerificatieChecks
    {
        public bool MatenOk { get; set; }
        public bool ScharnierPositiesOk { get; set; }
    }

    private readonly Dictionary<int, VerificatieChecks> _checks = [];

    private VerificatieChecks GetChecks(int index)
    {
        if (!_checks.TryGetValue(index, out var checks))
        {
            checks = new VerificatieChecks();
            _checks[index] = checks;
        }
        return checks;
    }

    private void ToggleCheck(int index, Action<VerificatieChecks> toggle)
        => toggle(GetChecks(index));

    private static bool HeeftScharnierCheck(PaneelResultaat r)
        => r.Type == PaneelType.Deur && r.Boorgaten.Count > 0;

    private bool AlleChecksVoorPaneel(int index, PaneelResultaat r)
    {
        if (!_checks.TryGetValue(index, out var checks)) return false;
        if (!checks.MatenOk) return false;
        if (HeeftScharnierCheck(r))
            return checks.ScharnierPositiesOk;
        return true;
    }

    private int AantalAfgevinktVoorPaneel(int index, PaneelResultaat r)
    {
        if (!_checks.TryGetValue(index, out var checks)) return 0;
        var count = checks.MatenOk ? 1 : 0;
        if (HeeftScharnierCheck(r) && checks.ScharnierPositiesOk)
            count++;
        return count;
    }

    private static int TotaalChecksVoorPaneel(PaneelResultaat r)
        => HeeftScharnierCheck(r) ? 2 : 1;

    private int OpenChecksVoorPaneel(int index, PaneelResultaat r)
        => TotaalChecksVoorPaneel(r) - AantalAfgevinktVoorPaneel(index, r);

    private string OpenChecksLabel(int index, PaneelResultaat r)
    {
        var open = OpenChecksVoorPaneel(index, r);
        return open == 0 ? "Alles klaar" : $"{open} open";
    }

    private string VolgendeControleTitel(int index, PaneelResultaat r)
    {
        _checks.TryGetValue(index, out var checks);

        if (checks?.MatenOk != true)
            return "Meet de maat in de opening na";

        if (HeeftScharnierCheck(r) && checks?.ScharnierPositiesOk != true)
            return "Controleer de systeemgaten";

        return "Alle controles voor dit paneel zijn klaar";
    }

    private string HuidigeControleHint(int index, PaneelResultaat r)
        => VolgendeControleTitel(index, r) switch
        {
            "Meet de maat in de opening na" => "Vergelijk de echte opening met de maat hieronder voordat u verdergaat.",
            "Controleer de systeemgaten" => "Bevestig nu of de scharnierplaatposities in de gaatjesrij kloppen.",
            _ => "Alle checkliststappen voor dit paneel zijn afgevinkt."
        };

    private string PaneelTabStatusTekst(int index, PaneelResultaat r)
        => AlleChecksVoorPaneel(index, r)
            ? "Klaar"
            : $"{AantalAfgevinktVoorPaneel(index, r)}/{TotaalChecksVoorPaneel(r)} controles";

    private void GaNaarPaneel(int index)
    {
        _paneelIndex = index;
        _fase = VerificatieFase.PaneelVerificatie;
    }

    private void VorigePaneel()
    {
        if (_paneelIndex > 0)
            _paneelIndex--;
        else
            _fase = VerificatieFase.Overzicht;
    }

    private void VolgendPaneel()
    {
        var resultaten = State.BerekenResultaten();
        if (_paneelIndex < resultaten.Count - 1)
            _paneelIndex++;
        else
            _fase = VerificatieFase.Afronding;
    }

    private void TerugNaarOverzicht() => _fase = VerificatieFase.Overzicht;

    private static string TypeNaam(PaneelType type) => VisualisatieHelper.PaneelTypeLabel(type);

    private static string TypeBadgeClass(PaneelType type) => type switch
    {
        PaneelType.Deur => "bg-primary",
        PaneelType.LadeFront => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private static string FormatMm(double waarde)
        => $"{waarde:0.#} mm";

    private BrowserWindowJsInterop? _browserWindowInterop;

    private BrowserWindowJsInterop BrowserWindowInterop => _browserWindowInterop ??= new(JS);

    private async Task PrintResultaat()
    {
        await BrowserWindowInterop.PrintCurrentPageAsync();
    }

    private Task DeelResultaat()
        => Delen.DeelKeukenAsync("verificatie");

    public async ValueTask DisposeAsync()
    {
        if (_browserWindowInterop is not null)
            await _browserWindowInterop.DisposeAsync();
    }
}
