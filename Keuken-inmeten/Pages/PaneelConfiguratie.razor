@page "/panelen"
@inject KeukenStateService State
@inject ActieFeedbackService Feedback
@implements IDisposable

<PageTitle>Stap 2 — Panelen</PageTitle>

<StapIndicator HuidigeStap="panelen" />

@{
    var flowStatus = StappenFlowHelper.BepaalStatus(State);
    var routeGate = StappenFlowHelper.BepaalRouteGate("panelen", flowStatus);
    var geopendeWand = GeopendeWand;
    var isReviewWeergaveActief = IsReviewWeergaveActief;
    var paneelEditorStatus = HuidigePaneelEditorStatus;
    var toonCompacteStapIntro = routeGate is null && geopendeWand is not null && !isReviewWeergaveActief;
    var toonCompacteWeergaveTabs = toonEditorDrawer && !isReviewWeergaveActief && geopendeWand is not null;
    var toonUitgeklapteProjectinstellingen = Math.Abs(State.PaneelRandSpeling - 3) > 0.001;
}

<section class="stap-pagina-kop mb-4">
    <div class="stap-pagina-kop__top">
        <div class="stap-pagina-kop__intro">
            <h2 class="page-header">Stap 2: Panelen</h2>
            @if (routeGate is null && isReviewWeergaveActief)
            {
                <p class="stap-pagina-kop__lead">Loop aantallen, maten en acties per wand rustig na. Ga alleen terug naar de editor als u opnieuw wilt plaatsen of bewerken.</p>
            }
            else if (toonCompacteStapIntro)
            {
                <div class="stap-pagina-kop__compact" data-testid="paneel-stap-intro-compact">
                    <span class="stap-pagina-kop__kicker">Actieve wand</span>
                    <span class="fw-semibold">@(geopendeWand?.Naam ?? "Paneel-editor")</span>
                    <span class="small text-muted">Rond selectie, maat en opslaan af zonder extra schermwissels.</span>
                </div>
            }
            else
            {
                <p class="stap-pagina-kop__lead">Open één wand en plaats daarna panelen in de editor. Het overzicht wordt pas nuttig zodra er panelen zijn.</p>
            }
        </div>
    </div>
</section>

@if (routeGate is not null)
{
    <StapRouteMelding Gate="@routeGate" />
}
else
{
    var paneelReviewGroepen = OverzichtGroeperingHelper.GroepeerPaneelToewijzingen(State);
    var paneelTypeTellingen = OverzichtGroeperingHelper.MaakTellingen(State.Toewijzingen, toewijzing => TypeNaam(toewijzing.Type));
    var reviewBeschikbaar = State.Toewijzingen.Count > 0;
    var wandWerkruimtes = State.LeesPaneelWerkruimtes(bewerkToewijzingId);
    var gerangschiktePaneelReviewGroepen = geopendeWand is null
        ? paneelReviewGroepen
        : paneelReviewGroepen
            .OrderBy(groep => groep.WandId == geopendeWand.Id ? 0 : 1)
            .ThenBy(groep => groep.WandNaam)
            .ThenBy(groep => groep.WandId?.ToString("N"))
            .ToList();
    var overzichtWerkruimtes = geopendeWand is null
        ? wandWerkruimtes
        : wandWerkruimtes.Where(werkruimte => werkruimte.Wand.Id != geopendeWand.Id).ToList();
    var geopendeWerkruimte = geopendeWand is null
        ? null
        : wandWerkruimtes.FirstOrDefault(werkruimte => werkruimte.Wand.Id == geopendeWand.Id);

    <div class="paneel-pagina-shell @((toonEditorDrawer && !isReviewWeergaveActief) ? "editor-open" : null)">
        <div class="border rounded p-3 mb-4 bg-body-tertiary paneel-weergave-tabs @(geopendeWand is not null ? "paneel-weergave-tabs--compact" : null) @(toonCompacteWeergaveTabs ? "paneel-weergave-tabs--editor-open" : null)" data-testid="paneel-weergave-tabs">
            @if (toonCompacteWeergaveTabs)
            {
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div>
                        <div class="text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Werklaag</div>
                        <div class="fw-semibold">Editor open voor @geopendeWand?.Naam</div>
                        <div class="small text-muted">Rond selectie, maat en opslaan af zonder extra schermwissels.</div>
                    </div>
                    @if (reviewBeschikbaar)
                    {
                        <div class="stap-meta-list paneel-weergave-meta-list">
                            <span>@State.Toewijzingen.Count paneel/panelen klaar</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                    <div>
                        <div class="text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Weergave</div>
                        <div class="fw-semibold">
                            @(isReviewWeergaveActief
                                ? "Overzicht van toegewezen panelen"
                                : geopendeWand is null
                                    ? "Open eerst één wand"
                                    : $"Editor — {geopendeWand.Naam}")
                        </div>
                        @if (isReviewWeergaveActief)
                        {
                            <div class="small text-muted">
                                Controleer hier aantallen, maten en acties zonder het canvas erboven.
                            </div>
                        }
                        else if (geopendeWand is not null)
                        {
                            <div class="small text-muted">
                                @(toonEditorDrawer
                                    ? "De editor staat open. Rond selectie, maat en opslaan in één werklaag af."
                                    : "Werk op één wand tegelijk en open de editor zodra uw selectie klaarstaat.")
                            </div>
                        }
                    </div>
                    <div class="stap-meta-list paneel-weergave-meta-list">
                        @if (geopendeWand is not null && !isReviewWeergaveActief)
                        {
                            <span>Actief: @geopendeWand.Naam</span>
                            <span>@(toonEditorDrawer ? "Editor open" : "Editor gesloten")</span>
                        }
                        @if (reviewBeschikbaar)
                        {
                            <span>@State.Toewijzingen.Count paneel/panelen</span>
                        }
                    </div>
                </div>
            }
            <ul class="nav nav-pills nav-fill flex-wrap @(toonCompacteWeergaveTabs ? "mt-2" : "mt-3")">
                <li class="nav-item">
                    <button type="button"
                            class="nav-link @(!isReviewWeergaveActief ? "active" : "")"
                            @onclick="ActiveerEditorWeergave"
                            data-testid="paneel-editor-weergave-tab">
                        <span class="fw-semibold">Editor</span>
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button"
                            class="nav-link @(isReviewWeergaveActief ? "active" : "")"
                            @onclick="ActiveerReviewWeergave"
                            disabled="@(State.Toewijzingen.Count == 0)"
                            data-testid="paneel-review-weergave-tab">
                        <span class="fw-semibold">Overzicht</span>
                    </button>
                </li>
            </ul>
        </div>

        <details class="indeling-overige-wanden paneel-projectinstellingen mb-4"
                 data-testid="paneel-projectinstellingen"
                 open="@toonUitgeklapteProjectinstellingen">
            <summary class="indeling-overige-wanden-summary">
                <div>
                    <div class="text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Projectinstelling</div>
                    <div class="fw-semibold">@PaneelMaatUitlegHelper.RandSpelingLabel</div>
                    <div class="small text-muted">Nu @($"{ProjectRandSpelingInput:0.#} mm") totaal. Open dit alleen als het hele project bewust meer of minder voeg nodig heeft.</div>
                </div>
                <span class="badge text-bg-light border paneel-projectinstellingen-badge">@($"{ProjectRandSpelingInput:0.#} mm")</span>
            </summary>
            <div class="indeling-overige-wanden-body">
                <div class="row g-3 align-items-start">
                    <div class="col-lg-7">
                        <div class="small text-muted">
                            Deze waarde geldt voor het hele project. Tussen twee panelen verdeelt de app de totale voeg automatisch zodat zaagmaten hele millimeters blijven. Vrije buitenranden blijven ongewijzigd.
                        </div>
                    </div>
                    <div class="col-lg-5">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <label class="form-label fw-semibold small text-uppercase mb-0" style="font-size: 0.72rem; letter-spacing: .04em;">@PaneelMaatUitlegHelper.RandSpelingLabel (mm)</label>
                            <HulpInfoKnop Titel="Totale voeg tussen rakende delen"
                                          Tekst="Deze projectinstelling bepaalt de totale vrije ruimte tussen een paneel en een apparaat of buurpaneel."
                                          Voorbeeld="Bij een totale voeg van 3 mm tussen twee panelen krijgt het ene paneel bijvoorbeeld 1 mm aftrek en het andere 2 mm."
                                          WatNuDoen="Laat de standaard staan tenzij uw beslag, afwerking of montage bewust om meer of minder totale voeg vraagt." />
                        </div>
                        <input type="number"
                               class="form-control"
                               @bind="ProjectRandSpelingInput"
                               min="0"
                               step="1"
                               data-testid="project-randspeling-input" />
                        <div class="form-text hulp-hint">Standaard 3 mm totaal voor het hele project.</div>
                    </div>
                </div>
            </div>
        </details>

        @if (!isReviewWeergaveActief)
        {
            <div data-testid="paneel-editor-weergave">
                @if (geopendeWand is null)
                {
                    <div class="mb-3">
                        <div>
                            <h5 class="mb-1">Wandenoverzicht</h5>
                            <p class="text-muted mb-0">Open één wand om panelen te plaatsen of te bewerken.</p>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        @foreach (var werkruimte in overzichtWerkruimtes)
                        {
                            var wand = werkruimte.Wand;
                            var wandKasten = werkruimte.Kasten;
                            var wandPanelen = werkruimte.Toewijzingen;
                            var isActieveWerkruimte = geopendeWand?.Id == wand.Id;
                            var overzichtBadges = isActieveWerkruimte
                                ? new List<IndelingBadge> { new("Nu open", "badge text-bg-primary") }
                                : [];
                            var overzichtMeta = new List<string>();
                            if (wandKasten.Count > 0)
                            {
                                overzichtMeta.Add($"{wandKasten.Count} kast(en)");
                            }
                            if (wandPanelen.Count > 0)
                            {
                                overzichtMeta.Add($"{wandPanelen.Count} paneel/panelen");
                            }
                            overzichtMeta.Add($"{wand.Breedte} mm wand");
                            var knopLabel = wandKasten.Count == 0
                                ? "Eerst stap 1"
                                : isActieveWerkruimte
                                    ? "Werkruimte geopend"
                                    : "Open wand";
                            var knopClass = wandKasten.Count == 0 ? "btn btn-outline-secondary" : "btn btn-primary";
                            var beschrijving = wandKasten.Count == 0
                                ? "Voeg eerst een kast toe in stap 1."
                                : wandPanelen.Count > 0
                                    ? "Open deze wand om panelen te bekijken of te bewerken."
                                    : "Open deze wand om uw eerste paneel te plaatsen.";

                            <div class="col-xl-6"
                                 @key="wand.Id">
                                <IndelingWandKaart WandId="wand.Id"
                                                   WandNaam="@wand.Naam"
                                                   DataTestId="paneel-wand-card"
                                                   KnopDataTestId="open-paneel-wand-button"
                                                   KnopLabel="@knopLabel"
                                                   KnopClass="@knopClass"
                                                   KnopUitgeschakeld="@(isActieveWerkruimte || wandKasten.Count == 0)"
                                                   MetaClass="stap-meta-list"
                                                   IsActief="isActieveWerkruimte"
                                                   Badges="overzichtBadges"
                                                   MetaItems="overzichtMeta"
                                                   Beschrijving="@beschrijving"
                                                   OnOpenen="@(() => ToggleWandWerkruimte(wand.Id))">
                                </IndelingWandKaart>
                            </div>
                        }
                    </div>
                }
                else if (overzichtWerkruimtes.Count > 0)
                {
                    <IndelingDetailsBlok Titel="Andere wanden"
                                         Beschrijving="Verborgen zodat de actieve werkruimte rustiger blijft."
                                         BadgeText="@($"{overzichtWerkruimtes.Count} wand(en) direct beschikbaar")"
                                         DetailsClass="indeling-overige-wanden paneel-overige-wanden-details mb-4"
                                         DetailsDataTestId="paneel-overige-wanden-details"
                                         SummaryDataTestId="paneel-overige-wanden-summary">
                        <div class="indeling-overige-wanden-lijst">
                            @foreach (var werkruimte in overzichtWerkruimtes)
                            {
                                var wand = werkruimte.Wand;
                                var wandKasten = werkruimte.Kasten;
                                var wandApparaten = werkruimte.Apparaten;
                                var wandPanelen = werkruimte.Toewijzingen;
                                var overzichtMeta = new List<string> { $"{wandKasten.Count} kast(en)" };
                                if (wandPanelen.Count > 0)
                                {
                                    overzichtMeta.Add($"{wandPanelen.Count} paneel/panelen");
                                }
                                overzichtMeta.Add($"{wand.Breedte} mm wand");
                                var beschrijving = wandKasten.Count == 0
                                    ? "Nog geen kasten op deze wand. Voeg die eerst in stap 1 toe."
                                    : $"{wandPanelen.Count} paneel/panelen · {wandApparaten.Count} apparaat(en) · {wand.Breedte} mm wandbreedte";
                                var knopLabel = wandKasten.Count == 0 ? "Eerst kast toevoegen" : "Open wand";

                                <IndelingWandSchakelaar WandId="wand.Id"
                                                        WandNaam="@wand.Naam"
                                                        DataTestId="paneel-wand-card"
                                                        KnopDataTestId="open-paneel-wand-button"
                                                        KnopLabel="@knopLabel"
                                                        KnopUitgeschakeld="@(wandKasten.Count == 0)"
                                                        MetaClass="stap-meta-list"
                                                        MetaItems="overzichtMeta"
                                                        Beschrijving="@beschrijving"
                                                        OnOpenen="@(() => ToggleWandWerkruimte(wand.Id))"
                                                        @key="wand.Id">
                                </IndelingWandSchakelaar>
                            }
                        </div>
                    </IndelingDetailsBlok>
                }

                @if (geopendeWand is not null && geopendeWerkruimte is not null)
                {
                    var geopendeWandKasten = geopendeWerkruimte.Kasten;
                    var geopendeWandApparaten = geopendeWerkruimte.Apparaten;
                    var geopendeWandPanelen = geopendeWerkruimte.Toewijzingen;

                    <div class="card border-0 shadow-sm mb-4 indeling-actieve-werkruimte paneel-actieve-werkruimte"
                         data-testid="paneel-actieve-wand-werkruimte"
                         data-wand-id="@geopendeWand.Id"
                         data-wand-naam="@geopendeWand.Naam">
                        <div class="card-body">
                            <div class="indeling-workspace-header paneel-workspace-header mb-3">
                                <button type="button"
                                        class="btn btn-link p-0 text-start text-body text-decoration-none"
                                        @onclick="() => ToggleWandWerkruimte(geopendeWand.Id)"
                                        data-testid="toggle-paneel-actieve-wand-button"
                                        data-wand-id="@geopendeWand.Id"
                                        data-wand-naam="@geopendeWand.Naam">
                                    <span class="indeling-workspace-kicker d-block">Actieve wand</span>
                                    <span class="h5 d-block mb-1 text-body">@geopendeWand.Naam</span>
                                    <span class="stap-meta-list">
                                        <span>@geopendeWandKasten.Count kast(en)</span>
                                        <span>@geopendeWandPanelen.Count paneel/panelen</span>
                                        @if (geopendeWandApparaten.Count > 0)
                                        {
                                            <span>@geopendeWandApparaten.Count apparaat(en)</span>
                                        }
                                        <span>@(toonEditorDrawer ? "Editor open" : "Editor gesloten")</span>
                                    </span>
                                </button>
                                <div class="d-flex flex-wrap align-items-center justify-content-sm-end gap-2">
                                    @if (!toonEditorDrawer)
                                    {
                                        <button type="button"
                                            class="btn btn-sm btn-primary"
                                            @onclick="OpenEditorDrawer"
                                            data-testid="open-paneel-editor-button">
                                            @paneelEditorStatus.OpenEditorKnopLabel
                                        </button>
                                    }
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SluitWandWerkruimte">
                                        Werkruimte sluiten
                                    </button>
                                </div>
                            </div>

                            @if (!toonEditorDrawer)
                            {
                                <div class="paneel-werkruimte-status border rounded p-3 mb-3 bg-body-tertiary">
                                    <div>
                                        <div class="small text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Volgende stap</div>
                                        <div class="fw-semibold mb-1">@paneelEditorStatus.VolgendePaneelStapTekst</div>
                                        <div class="small text-muted">@paneelEditorStatus.WerkruimteStatusDetailTekst</div>
                                    </div>
                                </div>
                            }

                            <div class="paneel-overzicht-scroll border rounded">
                                <PaneelPlaatsEditor Kasten="@geopendeWandKasten"
                                                    Apparaten="@geopendeWandApparaten"
                                                    WandHoogte="@geopendeWand.Hoogte"
                                                    WandBreedte="@geopendeWand.Breedte"
                                                    PlintHoogte="@geopendeWand.PlintHoogte"
                                                    TotaleRandSpeling="@State.PaneelRandSpeling"
                                                    GeselecteerdeKastIds="@geselecteerdeKastIds"
                                                    SvgMaxHoogte="65vh"
                                                    BeperkTotContainerBreedte="true"
                                                    Toewijzingen="@geopendeWandPanelen"
                                                    VrijeSegmenten="@VrijeSegmentenVoorSelectie()"
                                                    ConceptPaneel="@conceptPaneel"
                                                    ConceptPaneelType="@formToewijzing.Type"
                                                    ConceptPaneelScharnierZijde="@formToewijzing.ScharnierZijde"
                                                    OnKastGeselecteerd="ToggleKast"
                                                    OnConceptPaneelGewijzigd="VerwerkConceptPaneel" />
                            </div>

                            @if (geselecteerdeKastIds.Count > 0 && !toonEditorDrawer)
                            {
                                <div class="paneel-selectie-strip mt-3">
                                    <div class="small text-muted">Uw selectie staat klaar. Open of houd de editor open om plaatsing, maat en opslaan af te ronden.</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <button type="button" class="btn btn-sm btn-link text-secondary p-0" @onclick="DeselecteerAlles">
                                            Alles deselecteren ×
                                        </button>
                                        @if (!toonEditorDrawer)
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-primary btn-sm"
                                                    @onclick="OpenEditorDrawer"
                                                    data-testid="open-paneel-editor-button-secondary">
                                                @paneelEditorStatus.OpenEditorKnopLabel
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (toonCompacteStapIntro)
                {
                    <div class="mt-3" data-testid="paneel-terminologie-blok">
                        <TerminologieUitleg Titel="Paneeltermen in gewone taal"
                                            Sleutels="openingsmaat,werkmaat,randspeling,scharnierzijde,scharnierpot,pothart"
                                            Beschrijving="Open alleen als u tijdens het plaatsen nog een term wilt opfrissen." />
                    </div>
                }
            </div>
        }
        else
        {
            <PaneelReviewOverzicht ToewijzingenAantal="@State.Toewijzingen.Count"
                                   Groepen="@gerangschiktePaneelReviewGroepen"
                                   PaneelTypeTellingen="@paneelTypeTellingen"
                                   ActieveWandId="@geopendeWand?.Id"
                                   BewerkToewijzingId="@bewerkToewijzingId"
                                   GeopendeWandNaam="@geopendeWand?.Naam"
                                   OnTerugNaarEditor="ActiveerEditorWeergave"
                                   OnBewerkPaneel="BewerkPaneel"
                                   OnVerwijderPaneel="VerwijderPaneel" />
        }
    </div>

    @if (geopendeWand is not null && toonEditorDrawer && !isReviewWeergaveActief)
    {
        var conceptMaatInfo = BerekenConceptMaatInfo();
        var vrijeSegmenten = VrijeSegmentenVoorSelectie();
        <PaneelEditorDrawer Status="@paneelEditorStatus"
                            OpdeelBereik="@OpdeelBereik"
                            GeselecteerdType="@formToewijzing.Type"
                            GeselecteerdeScharnierZijde="@formToewijzing.ScharnierZijde"
                            PotHartInput="@PotHartInput"
                            PotHartInputChanged="@(EventCallback.Factory.Create<double>(this, value => PotHartInput = value))"
                            BreedteInput="@BreedteInput"
                            BreedteInputChanged="@(EventCallback.Factory.Create<double>(this, value => BreedteInput = value))"
                            HoogteInput="@HoogteInput"
                            HoogteInputChanged="@(EventCallback.Factory.Create<double>(this, value => HoogteInput = value))"
                            LinksInput="@LinksInput"
                            LinksInputChanged="@(EventCallback.Factory.Create<double>(this, value => LinksInput = value))"
                            OnderkantInput="@OnderkantInput"
                            OnderkantInputChanged="@(EventCallback.Factory.Create<double>(this, value => OnderkantInput = value))"
                            ConceptPaneel="@conceptPaneel"
                            ConceptMaatInfo="@conceptMaatInfo"
                            VrijeSegmenten="@vrijeSegmenten"
                            GeselecteerdeKast="@(geselecteerdeKasten.Count == 1 ? geselecteerdeKasten[0] : null)"
                            ToonKastOpdelenModal="@toonKastOpdelenModal"
                            OpdeelAantal="@opdeelAantal"
                            OpdeelHoogtes="opdeelHoogtes"
                            OpdeelAnalyse="@OpdeelAnalyse"
                            KanKastOpdelenIn="KanKastOpdelenIn"
                            OnTypeGewijzigd="@(EventCallback.Factory.Create<PaneelType>(this, value => formToewijzing.Type = value))"
                            OnScharnierZijdeGewijzigd="@(EventCallback.Factory.Create<ScharnierZijde>(this, value => formToewijzing.ScharnierZijde = value))"
                            OnVrijSegmentGekozen="@(EventCallback.Factory.Create<PaneelRechthoek>(this, GebruikVrijSegment))"
                            OnReset="ResetConceptPaneel"
                            OnOpslaan="PaneelOpslaan"
                            OnOpenKastOpdelenModal="OpenKastOpdelenModal"
                            OnSluitKastOpdelenModal="SluitKastOpdelenModal"
                            OnStelOpdeelAantalIn="StelOpdeelAantalIn"
                            OnBevestigKastOpdelen="BevestigKastOpdelen"
                            OnOpdeelHoogtesGewijzigd="@(EventCallback.Factory.Create(this, StateHasChanged))"
                            OnAnnuleerBewerken="AnnuleerBewerken"
                            OnSluiten="SluitEditorDrawer" />
    }
}

<StapNavigatie HuidigeStap="panelen"
               VorigeHref="kasten"
               VolgendeHref="verificatie"
               VolgendeDisabled="@(State.Toewijzingen.Count == 0)" />
