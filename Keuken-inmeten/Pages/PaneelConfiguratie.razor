@page "/panelen"
@inject KeukenStateService State
@inject ActieFeedbackService Feedback
@implements IDisposable

<PageTitle>Stap 2 — Panelen</PageTitle>

<StapIndicator HuidigeStap="panelen" />

@{
    var flowStatus = StappenFlowHelper.BepaalStatus(State);
    var routeGate = StappenFlowHelper.BepaalRouteGate("panelen", flowStatus);
    var geopendeWand = GeopendeWand;
    var isReviewWeergaveActief = IsReviewWeergaveActief;
    var toonCompacteStapIntro = routeGate is null && geopendeWand is not null && !isReviewWeergaveActief;
    var toonCompacteWeergaveTabs = toonEditorDrawer && !isReviewWeergaveActief && geopendeWand is not null;
}

<h2 class="page-header">Stap 2: Panelen</h2>

@if (routeGate is null && isReviewWeergaveActief)
{
    <div class="paneel-stap-intro paneel-stap-intro--compact mb-3" data-testid="paneel-stap-intro-review">
        <div>
            <div class="paneel-stap-intro-kicker text-muted fw-semibold text-uppercase">Review</div>
            <div class="fw-semibold">Loop aantallen, maten en acties per wand rustig na.</div>
        </div>
    </div>
}
else if (toonCompacteStapIntro)
{
    <div class="paneel-stap-intro paneel-stap-intro--compact mb-3" data-testid="paneel-stap-intro-compact">
        <div>
            <div class="paneel-stap-intro-kicker text-muted fw-semibold text-uppercase">Actieve wand</div>
            <div class="fw-semibold">@(geopendeWand?.Naam ?? "Paneel-editor")</div>
        </div>
    </div>
}
else
{
    <p class="text-muted mb-3">Open één wand en plaats daarna panelen in de editor. Review gebruikt u pas zodra er panelen zijn.</p>
}

@if (routeGate is not null)
{
    <StapRouteMelding Gate="@routeGate" />
}
else
{
    var paneelReviewGroepen = OverzichtGroeperingHelper.GroepeerPaneelToewijzingen(State);
    var paneelTypeTellingen = OverzichtGroeperingHelper.MaakTellingen(State.Toewijzingen, toewijzing => TypeNaam(toewijzing.Type));
    var reviewBeschikbaar = State.Toewijzingen.Count > 0;
    var gerangschiktePaneelReviewGroepen = geopendeWand is null
        ? paneelReviewGroepen
        : paneelReviewGroepen
            .OrderBy(groep => groep.WandNaam == geopendeWand.Naam ? 0 : 1)
            .ThenBy(groep => groep.WandNaam)
            .ToList();
    var overzichtWanden = geopendeWand is null
        ? State.Wanden
        : State.Wanden.Where(wand => wand.Id != geopendeWand.Id).ToList();

    <div class="paneel-pagina-shell @((toonEditorDrawer && !isReviewWeergaveActief) ? "editor-open" : null)">
        <div class="border rounded p-3 mb-4 bg-body-tertiary paneel-weergave-tabs @(geopendeWand is not null ? "paneel-weergave-tabs--compact" : null) @(toonCompacteWeergaveTabs ? "paneel-weergave-tabs--editor-open" : null)" data-testid="paneel-weergave-tabs">
            @if (toonCompacteWeergaveTabs)
            {
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div>
                        <div class="text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Werklaag</div>
                        <div class="fw-semibold">Editor open voor @geopendeWand?.Naam</div>
                    </div>
                    @if (reviewBeschikbaar)
                    {
                        <span class="badge text-bg-light border">@State.Toewijzingen.Count paneel/panelen klaar</span>
                    }
                </div>
            }
            else
            {
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                    <div>
                        <div class="text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Focus</div>
                        <div class="fw-semibold">
                            @(isReviewWeergaveActief
                                ? "Review van toegewezen panelen"
                                : geopendeWand is null
                                    ? "Open eerst één wand"
                                    : $"Editor — {geopendeWand.Naam}")
                        </div>
                        @if (isReviewWeergaveActief)
                        {
                            <div class="small text-muted">
                                Controleer hier aantallen, maten en acties zonder het canvas erboven.
                            </div>
                        }
                        else if (geopendeWand is not null)
                        {
                            <div class="small text-muted">
                                @(toonEditorDrawer
                                    ? "De editor staat open. Rond selectie, maat en opslaan in één werklaag af."
                                    : "Werk op één wand tegelijk en open de editor zodra uw selectie klaarstaat.")
                            </div>
                        }
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2 paneel-weergave-meta">
                        @if (geopendeWand is not null && !isReviewWeergaveActief)
                        {
                            <span class="badge text-bg-light border">Actief: @geopendeWand.Naam</span>
                            <span class="badge text-bg-light border">@(toonEditorDrawer ? "Editor open" : "Editor klaar")</span>
                        }
                        @if (reviewBeschikbaar)
                        {
                            <span class="badge text-bg-light border">@State.Toewijzingen.Count paneel/panelen</span>
                        }
                    </div>
                </div>
            }
            <ul class="nav nav-pills nav-fill flex-wrap @(toonCompacteWeergaveTabs ? "mt-2" : "mt-3")">
                <li class="nav-item">
                    <button type="button"
                            class="nav-link @(!isReviewWeergaveActief ? "active" : "")"
                            @onclick="ActiveerEditorWeergave"
                            data-testid="paneel-editor-weergave-tab">
                        <span class="fw-semibold">Editor</span>
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button"
                            class="nav-link @(isReviewWeergaveActief ? "active" : "")"
                            @onclick="ActiveerReviewWeergave"
                            disabled="@(State.Toewijzingen.Count == 0)"
                            data-testid="paneel-review-weergave-tab">
                        <span class="fw-semibold">Review</span>
                    </button>
                </li>
            </ul>
        </div>

        @if (!isReviewWeergaveActief)
        {
            <div data-testid="paneel-editor-weergave">
                @if (geopendeWand is null)
                {
                    <div class="mb-3">
                        <div>
                            <h5 class="mb-1">Wandenoverzicht</h5>
                            <p class="text-muted mb-0">Open één wand om panelen te plaatsen of te bewerken.</p>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        @foreach (var wand in overzichtWanden)
                        {
                            var wandKasten = State.KastenVoorWand(wand.Id);
                            var wandPanelen = ToewijzingenVoorWand(wand);
                            var isActieveWerkruimte = geopendeWand?.Id == wand.Id;

                            <div class="col-xl-6"
                                 @key="wand.Id">
                                <div class="card h-100 indeling-wand-samenvatting @(isActieveWerkruimte ? "actief" : "")"
                                     data-testid="paneel-wand-card"
                                     data-wand-id="@wand.Id"
                                     data-wand-naam="@wand.Naam">
                                    <div class="card-body d-flex flex-column gap-2">
                                        <div class="d-flex flex-wrap align-items-start gap-2">
                                            <div>
                                                <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                                    <h5 class="mb-0">@wand.Naam</h5>
                                                    @if (isActieveWerkruimte)
                                                    {
                                                        <span class="badge text-bg-primary">Nu open</span>
                                                    }
                                                    @if (wandKasten.Count > 0)
                                                    {
                                                        <span class="badge text-bg-light">@wandKasten.Count kast(en)</span>
                                                    }
                                                    @if (wandPanelen.Count > 0)
                                                    {
                                                        <span class="badge text-bg-light">@wandPanelen.Count paneel/panelen</span>
                                                    }
                                                </div>
                                                <div class="small text-muted">
                                                    @(wandKasten.Count == 0
                                                        ? "Voeg eerst een kast toe in stap 1."
                                                        : wandPanelen.Count > 0
                                                            ? "Open deze wand om panelen te bekijken of te bewerken."
                                                            : "Open deze wand om uw eerste paneel te plaatsen.")
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mt-auto">
                                            <button class="btn @(wandKasten.Count == 0 ? "btn-outline-secondary" : "btn-primary")"
                                                    @onclick="() => OpenWandWerkruimte(wand.Id)"
                                                    disabled="@(isActieveWerkruimte || wandKasten.Count == 0)"
                                                    data-testid="open-paneel-wand-button"
                                                    data-wand-id="@wand.Id">
                                                @(wandKasten.Count == 0 ? "Eerst stap 1" : isActieveWerkruimte ? "Werkruimte geopend" : "Open wand")
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (overzichtWanden.Count > 0)
                {
                    <details class="indeling-overige-wanden paneel-overige-wanden-details mb-4"
                             data-testid="paneel-overige-wanden-details">
                        <summary class="indeling-overige-wanden-summary"
                                 data-testid="paneel-overige-wanden-summary">
                            <div>
                                <h5 class="mb-0">Andere wanden</h5>
                                <div class="small text-muted">Verborgen zodat de actieve werkruimte rustiger blijft.</div>
                            </div>
                            <span class="badge text-bg-light indeling-workspace-hint">@overzichtWanden.Count wand(en) direct beschikbaar</span>
                        </summary>
                        <div class="indeling-overige-wanden-body">
                            <div class="indeling-overige-wanden-lijst">
                                @foreach (var wand in overzichtWanden)
                                {
                                    var wandKasten = State.KastenVoorWand(wand.Id);
                                    var wandApparaten = State.ApparatenVoorWand(wand.Id);
                                    var wandPanelen = ToewijzingenVoorWand(wand);

                                    <div class="indeling-overige-wand-schakelaar"
                                         data-testid="paneel-wand-card"
                                         data-wand-id="@wand.Id"
                                         data-wand-naam="@wand.Naam"
                                         @key="wand.Id">
                                        <div class="indeling-overige-wand-inhoud">
                                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                                <h6 class="mb-0">@wand.Naam</h6>
                                                <span class="badge text-bg-light">@wandKasten.Count kast(en)</span>
                                                @if (wandPanelen.Count > 0)
                                                {
                                                    <span class="badge text-bg-light">@wandPanelen.Count paneel/panelen</span>
                                                }
                                            </div>
                                            <div class="small text-muted">
                                                @(wandKasten.Count == 0
                                                    ? "Nog geen kasten op deze wand. Voeg die eerst in stap 1 toe."
                                                    : $"{wandPanelen.Count} paneel/panelen · {wandApparaten.Count} apparaat(en) · {wand.Breedte} mm wandbreedte")
                                            </div>
                                        </div>
                                        <button class="btn btn-outline-primary btn-sm"
                                                @onclick="() => OpenWandWerkruimte(wand.Id)"
                                                disabled="@(wandKasten.Count == 0)"
                                                data-testid="open-paneel-wand-button"
                                                data-wand-id="@wand.Id">
                                            @(wandKasten.Count == 0 ? "Eerst kast toevoegen" : "Open wand")
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </details>
                }

                @if (geopendeWand is not null)
                {
                    var geopendeWandKasten = State.KastenVoorWand(geopendeWand.Id);
                    var geopendeWandApparaten = State.ApparatenVoorWand(geopendeWand.Id);
                    var geopendeWandPanelen = ToewijzingenVoorWand(geopendeWand);

                    <div class="card mb-4 border-primary shadow-sm indeling-actieve-werkruimte"
                         data-testid="paneel-actieve-wand-werkruimte"
                         data-wand-id="@geopendeWand.Id"
                         data-wand-naam="@geopendeWand.Naam">
                        <div class="card-header bg-primary bg-opacity-10">
                            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="small fw-semibold text-uppercase text-primary-emphasis">Actieve wand</div>
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                        <h5 class="mb-0">@geopendeWand.Naam</h5>
                                        <span class="badge text-bg-light">@geopendeWandKasten.Count kast(en)</span>
                                        <span class="badge text-bg-light">@geopendeWandPanelen.Count paneel/panelen</span>
                                        @if (geopendeWandApparaten.Count > 0)
                                        {
                                            <span class="badge text-bg-light">@geopendeWandApparaten.Count apparaat(en)</span>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex flex-wrap align-items-center justify-content-sm-end gap-2">
                                    <span class="badge text-bg-light border">@(toonEditorDrawer ? "Editor open" : "Editor klaar")</span>
                                    @if (!toonEditorDrawer)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-primary"
                                                @onclick="OpenEditorDrawer"
                                                data-testid="open-paneel-editor-button">
                                            @OpenEditorKnopLabel()
                                        </button>
                                    }
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SluitWandWerkruimte">
                                        Werkruimte sluiten
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            @if (!toonEditorDrawer)
                            {
                                <div class="paneel-werkruimte-status border rounded p-3 mb-3 bg-body-tertiary">
                                    <div>
                                        <div class="small text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Volgende stap</div>
                                        <div class="fw-semibold mb-1">@VolgendePaneelStapTekst()</div>
                                        <div class="small text-muted">@PaneelWerkruimteStatusDetailTekst()</div>
                                    </div>
                                </div>
                            }

                            <div class="paneel-overzicht-scroll border rounded">
                                <PaneelPlaatsEditor Kasten="@geopendeWandKasten"
                                                    Apparaten="@geopendeWandApparaten"
                                                    WandHoogte="@geopendeWand.Hoogte"
                                                    WandBreedte="@geopendeWand.Breedte"
                                                    PlintHoogte="@geopendeWand.PlintHoogte"
                                                    RandSpelingPerRaakrand="@State.PaneelRandSpeling"
                                                    GeselecteerdeKastIds="@geselecteerdeKastIds"
                                                    SvgMaxHoogte="65vh"
                                                    BeperkTotContainerBreedte="true"
                                                    Toewijzingen="@geopendeWandPanelen"
                                                    VrijeSegmenten="@VrijeSegmentenVoorSelectie()"
                                                    ConceptPaneel="@conceptPaneel"
                                                    ConceptPaneelType="@formToewijzing.Type"
                                                    ConceptPaneelScharnierZijde="@formToewijzing.ScharnierZijde"
                                                    OnKastGeselecteerd="ToggleKast"
                                                    OnConceptPaneelGewijzigd="VerwerkConceptPaneel" />
                            </div>

                            @if (geselecteerdeKastIds.Count > 0 && !toonEditorDrawer)
                            {
                                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-3">
                                    <div class="small text-muted">Uw selectie staat klaar. Open of houd de editor open om plaatsing, maat en opslaan af te ronden.</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <button type="button" class="btn btn-sm btn-link text-secondary p-0" @onclick="DeselecteerAlles">
                                            Alles deselecteren ×
                                        </button>
                                        @if (!toonEditorDrawer)
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-primary btn-sm"
                                                    @onclick="OpenEditorDrawer"
                                                    data-testid="open-paneel-editor-button-secondary">
                                                @OpenEditorKnopLabel()
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (toonCompacteStapIntro)
                {
                    <div class="mt-3" data-testid="paneel-terminologie-blok">
                        <TerminologieUitleg Titel="Paneeltermen in gewone taal"
                                            Sleutels="openingsmaat,werkmaat,randspeling,scharnierzijde,scharnierpot,pothart"
                                            Beschrijving="Open alleen als u tijdens het plaatsen nog een term wilt opfrissen." />
                    </div>
                }
            </div>
        }
        else
        {
            <div class="mt-4 paneel-review-weergave" data-testid="paneel-review-weergave">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
                    <div>
                        <h5 class="mb-1">Review: toegewezen panelen</h5>
                        <p class="text-muted mb-0 small">Deze weergave focust op lijstbeheer, status en acties. Gebruik de editorweergave om weer een wand te openen of panelen te plaatsen.</p>
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        @if (geopendeWand is not null)
                        {
                            <span class="badge text-bg-light">Actieve wand klaar in editor: @geopendeWand.Naam</span>
                        }
                        <button type="button"
                                class="btn btn-outline-primary btn-sm"
                                @onclick="ActiveerEditorWeergave"
                                data-testid="back-to-paneel-editor-button">
                            Terug naar editor
                        </button>
                    </div>
                </div>

                <div>
                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
                        <div>
                            <h6 class="d-flex align-items-center gap-2 mb-1">
                                Toegewezen panelen
                                <span class="badge bg-secondary rounded-pill">@State.Toewijzingen.Count</span>
                            </h6>
                            <p class="text-muted small mb-0">De review staat nu los van de editorweergave, zodat lijst, status en acties zonder canvas erboven scanbaar blijven.</p>
                        </div>
                        @if (geopendeWand is not null)
                        {
                            <span class="badge text-bg-light">Actieve wand: @geopendeWand.Naam</span>
                        }
                    </div>

                    @if (State.Toewijzingen.Count == 0)
                    {
                        <p class="text-muted small">Nog geen panelen. Open de editorweergave, kies een wand en voeg daarna een paneel toe.</p>
                    }
                    else
                    {
                        <div class="border rounded p-3 mb-3 paneel-review-samenvatting">
                            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                                <div>
                                    <div class="fw-semibold">@State.Toewijzingen.Count paneeltoewijzingen in @paneelReviewGroepen.Count wand(en)</div>
                                    <div class="small text-muted">
                                        @(paneelTypeTellingen.Count == 0
                                            ? "Nog geen verdeling per paneeltype."
                                            : OverzichtGroeperingHelper.FormatteerTellingen(paneelTypeTellingen))
                                    </div>
                                </div>
                                <details class="paneel-review-samenvatting-details">
                                    <summary class="small fw-semibold text-secondary">Bekijk verdeling per wand</summary>
                                    <div class="small text-muted mt-2 d-grid gap-1">
                                        @foreach (var groep in gerangschiktePaneelReviewGroepen)
                                        {
                                            <div>@groep.WandNaam · @groep.AantalPanelen paneel/panelen</div>
                                        }
                                    </div>
                                </details>
                            </div>
                        </div>

                        @foreach (var groep in gerangschiktePaneelReviewGroepen)
                        {
                            var isActieveGroep = geopendeWand is not null && groep.WandNaam == geopendeWand.Naam;

                            <div class="card shadow-sm mb-3 @(isActieveGroep ? "border-primary-subtle" : "border-0")">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                        <div>
                                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                                <h6 class="mb-0">@groep.WandNaam</h6>
                                                @if (isActieveGroep)
                                                {
                                                    <span class="badge text-bg-primary">Nu actief</span>
                                                }
                                            </div>
                                            <div class="small text-muted">
                                                @groep.AantalPanelen paneel/panelen op deze wand
                                                @if (groep.TypeTellingen.Count > 0)
                                                {
                                                    <span> · @OverzichtGroeperingHelper.FormatteerTellingen(groep.TypeTellingen)</span>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="list-group list-group-flush mt-3">
                                        @foreach (var item in groep.Items)
                                        {
                                            var isOpen = bewerkToewijzingId == item.Id;

                                            <div class="list-group-item px-0 paneel-review-item" @key="item.Id">
                                                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                                    <div class="paneel-review-item-main">
                                                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                                            <span class="badge @TypeBadgeClass(item.Type)">@item.TypeLabel</span>
                                                            <span class="fw-semibold">Paneel @item.Volgnummer</span>
                                                            <span class="text-muted">@FormatMm(item.Breedte) × @FormatMm(item.Hoogte)</span>
                                                            @if (isOpen)
                                                            {
                                                                <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle">Open in editor</span>
                                                            }
                                                        </div>
                                                        <div class="small text-muted">Kast(en): @item.KastenLabel</div>
                                                        <div class="small text-muted">@item.PlaatsingLabel</div>
                                                    </div>
                                                    <div class="d-flex gap-2">
                                                        <button type="button"
                                                                class="btn btn-outline-primary btn-sm"
                                                                @onclick="() => BewerkPaneel(item.Id)">
                                                            @(isOpen ? "Open" : "Bewerk")
                                                        </button>
                                                    </div>
                                                </div>

                                                <details class="mt-2 small paneel-review-item-details">
                                                    <summary class="text-secondary">Technische details en verwijderen</summary>
                                                    <div class="mt-2 d-flex flex-column gap-3">
                                                        <div class="d-flex flex-wrap gap-3">
                                                        <span><strong>Plaatsing:</strong> @item.PlaatsingLabel</span>
                                                        @if (item.Type == PaneelType.Deur)
                                                        {
                                                            <span><strong>Scharnier:</strong> @item.ScharnierLabel</span>
                                                        }
                                                        </div>
                                                        <div>
                                                            <button type="button"
                                                                    class="btn btn-outline-danger btn-sm"
                                                                    @onclick="() => VerwijderPaneel(item.Id)">
                                                                Verwijder paneel
                                                            </button>
                                                        </div>
                                                    </div>
                                                </details>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>

    @if (geopendeWand is not null && toonEditorDrawer && !isReviewWeergaveActief)
    {
        var kanOpslaan = KanPaneelOpslaan();
        var conceptMaatInfo = BerekenConceptMaatInfo();
        var vrijeSegmenten = VrijeSegmentenVoorSelectie();

        <section class="paneel-editor-drawer-layer">
            <div class="paneel-editor-drawer @(ToonCompacteEditorLeegstaat ? "paneel-editor-drawer--waiting" : null)"
                 data-testid="paneel-editor-drawer"
                 aria-labelledby="paneel-editor-drawer-title">
                <div class="card border-0 h-100">
                    <div class="card-header bg-primary bg-opacity-10">
                        <div class="d-flex justify-content-between align-items-center gap-3">
                            <div>
                                <div class="small fw-semibold text-uppercase text-primary-emphasis">Paneel-editor</div>
                                <h5 id="paneel-editor-drawer-title" class="mb-0" style="font-size: 1rem;">
                                    @EditorDrawerTitel()
                                </h5>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                @if (IsBewerkModus)
                                {
                                    <button type="button" class="btn btn-sm btn-link text-secondary p-0" @onclick="AnnuleerBewerken">
                                        Annuleer
                                    </button>
                                }
                                @if (geselecteerdeKastIds.Count > 0)
                                {
                                    <span class="badge bg-primary rounded-pill">
                                        @(IsBewerkModus ? $"Paneel {BewerkIndex}" : $"{geselecteerdeKastIds.Count} kast(en)")
                                    </span>
                                }
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary"
                                        @onclick="SluitEditorDrawer"
                                        data-testid="close-paneel-editor-button">
                                    Sluiten
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="card-body paneel-editor-drawer-body">
                        @if (ToonCompacteEditorLeegstaat)
                        {
                            <div class="paneel-editor-empty-state border rounded p-2 p-sm-3 bg-body-tertiary">
                                <h6 class="mb-1">Selecteer nu kast(en) in de tekening</h6>
                                <p class="small text-muted mb-0">Tik de juiste kast(en) binnen <strong>@geopendeWand.Naam</strong>. Zodra u selecteert, verschijnen plaatsing, maat en opslaan hier.</p>
                            </div>
                        }
                        else
                        {
                            <div class="paneel-editor-focus border rounded p-3 mb-3 bg-body-tertiary">
                                <div class="fw-semibold mb-1">@VolgendePaneelStapTekst()</div>
                                <div class="small text-muted">@PaneelEditorKernHintTekst(kanOpslaan)</div>
                                <div class="d-flex flex-wrap gap-2 align-items-start paneel-editor-focus-meta mt-2">
                                    <span class="badge text-bg-light border">Selectie: @PaneelEditorSelectieSamenvatting()</span>
                                    <span class="badge @(kanOpslaan ? "text-bg-success" : "text-bg-light border")">Opslaan: @PaneelEditorOpslaanSamenvatting(kanOpslaan)</span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <label class="form-label fw-semibold small text-uppercase mb-0" style="font-size: 0.72rem; letter-spacing: .04em;">@PaneelMaatUitlegHelper.RandSpelingLabel (randspeling, mm)</label>
                                    <HulpInfoKnop Titel="Vrije ruimte langs de rand"
                                                  Tekst="Randspeling voorkomt dat een paneel klemt tegen een kast-, apparaat- of paneelrand. Die aftrek wordt meteen in de bestelmaten meegenomen."
                                                  Voorbeeld="Standaard is dit vaak 2 mm per rakende rand."
                                                  WatNuDoen="Laat de standaard staan tenzij uw beslag, spuitwerk of stelruimte om meer of minder speling vraagt." />
                                </div>
                                <input type="number"
                                       class="form-control"
                                       @bind="RandSpelingInput"
                                       min="0"
                                       step="0.5" />
                                <div class="form-text hulp-hint">Standaard 2 mm. Elke rand die een andere kast-, apparaat- of paneelrand raakt, krijgt deze aftrek meteen mee in de maat om te bestellen.</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Type paneel</label>
                                <div class="d-flex gap-2 flex-wrap">
                                    @foreach (var type in Enum.GetValues<PaneelType>())
                                    {
                                        <button type="button"
                                                class="btn btn-sm @(formToewijzing.Type == type ? "btn-primary" : "btn-outline-secondary")"
                                                @onclick="() => formToewijzing.Type = type">
                                            @TypeNaam(type)
                                        </button>
                                    }
                                </div>
                            </div>

                            @if (formToewijzing.Type == PaneelType.Deur)
                            {
                                <div class="mb-3">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <label class="form-label fw-semibold small text-uppercase mb-0" style="font-size: 0.72rem; letter-spacing: .04em;">Draairichting van de deur (scharnierzijde)</label>
                                        <HulpInfoKnop Titel="Draairichting van de deur"
                                                      Tekst="De scharnierzijde bepaalt aan welke kant de scharnieren komen en welke kant van het paneel de technische boorgaten krijgt."
                                                      Voorbeeld="Kiest u links, dan scharniert de deur links en opent hij naar rechts."
                                                      WatNuDoen="Kies de kant waar de deur aan de kast wordt bevestigd." />
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button type="button"
                                                class="btn btn-sm @(formToewijzing.ScharnierZijde == ScharnierZijde.Links ? "btn-primary" : "btn-outline-secondary")"
                                                @onclick="() => formToewijzing.ScharnierZijde = ScharnierZijde.Links">
                                            ◄ Links
                                        </button>
                                        <button type="button"
                                                class="btn btn-sm @(formToewijzing.ScharnierZijde == ScharnierZijde.Rechts ? "btn-primary" : "btn-outline-secondary")"
                                                @onclick="() => formToewijzing.ScharnierZijde = ScharnierZijde.Rechts">
                                            Rechts ►
                                        </button>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <label class="form-label fw-semibold small text-uppercase mb-0" style="font-size: 0.72rem; letter-spacing: .04em;">Afstand hart scharnierpot tot rand (mm)</label>
                                        <HulpInfoKnop Titel="Afstand hart scharnierpot tot rand"
                                                      Tekst="Dit is de maat van het midden van het 35 mm potgat naar de scharnierkant van het paneel."
                                                      Voorbeeld="Een veelgebruikte standaard is 22,5 mm."
                                                      WatNuDoen="Gebruik de maat van uw beslag of laat de laatst gebruikte standaard staan als die al klopt." />
                                    </div>
                                    <input type="number"
                                           class="form-control"
                                           @bind="PotHartInput"
                                           min="@ScharnierBerekeningService.MinCupCenterVanRand"
                                           step="0.5" />
                                    <div class="form-text hulp-hint">Technische term: pot-hart van rand. Deze maat wordt gebruikt voor alle 35 mm scharnierpotjes in dit deurpaneel en de laatst gebruikte waarde wordt onthouden.</div>
                                </div>
                            }

                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Breedte (mm)</label>
                                    <input type="number" class="form-control" @bind="BreedteInput" min="50" step="1" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Hoogte (mm)</label>
                                    <input type="number" class="form-control" @bind="HoogteInput" min="50" step="1" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Links (mm)</label>
                                    <input type="number" class="form-control" @bind="LinksInput" min="0" step="1" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Onderkant (mm)</label>
                                    <input type="number" class="form-control" @bind="OnderkantInput" min="0" step="1" />
                                </div>
                            </div>

                            @if (conceptPaneel is not null)
                            {
                                <div class="border rounded bg-light p-3 mb-3 small">
                                    <div class="fw-semibold mb-2">Plaatsing</div>
                                    <div class="d-flex flex-wrap gap-3">
                                        <span>Links <strong>@FormatMm(conceptPaneel.XPositie)</strong></span>
                                        <span>Onderkant <strong>@FormatMm(conceptPaneel.HoogteVanVloer)</strong></span>
                                        <span>Rechts <strong>@FormatMm(conceptPaneel.Rechterkant)</strong></span>
                                        <span>Bovenkant <strong>@FormatMm(conceptPaneel.Bovenzijde)</strong></span>
                                    </div>
                                </div>
                            }

                            @if (conceptMaatInfo is not null)
                            {
                                <HulpDetailsBlok Titel="Van maat in de opening naar maat om te bestellen"
                                                 Beschrijving="Open alleen als u de volledige aftrek per rand wilt nalopen."
                                                 CssClass="mb-3 small">
                                    <div class="mb-1">@PaneelMaatUitlegHelper.MaatInOpeningLabelMetTerm <strong>@FormatMm(conceptMaatInfo.OpeningsRechthoek.Breedte)</strong> × <strong>@FormatMm(conceptMaatInfo.OpeningsRechthoek.Hoogte)</strong></div>
                                    <div class="mb-2">@PaneelMaatUitlegHelper.MaatOmTeBestellenLabelMetTerm <strong>@FormatMm(conceptMaatInfo.PaneelRechthoek.Breedte)</strong> × <strong>@FormatMm(conceptMaatInfo.PaneelRechthoek.Hoogte)</strong></div>
                                    <div><strong>Breedteformule:</strong> @PaneelMaatUitlegHelper.BreedteFormule(conceptMaatInfo)</div>
                                    <div class="mb-2">@PaneelMaatUitlegHelper.BreedteAftrekUitleg(conceptMaatInfo)</div>
                                    <div><strong>Hoogteformule:</strong> @PaneelMaatUitlegHelper.HoogteFormule(conceptMaatInfo)</div>
                                    <div>@PaneelMaatUitlegHelper.HoogteAftrekUitleg(conceptMaatInfo)</div>
                                </HulpDetailsBlok>
                            }

                            @if (vrijeSegmenten.Count > 0)
                            {
                                <div class="border rounded bg-light p-3 mb-3 small">
                                    <div class="fw-semibold mb-2">Vrije vakken</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        @for (int i = 0; i < vrijeSegmenten.Count; i++)
                                        {
                                            var segment = vrijeSegmenten[i];
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-success"
                                                    @onclick="() => GebruikVrijSegment(segment)">
                                                @VrijSegmentLabel(i, segment)
                                            </button>
                                        }
                                    </div>
                                </div>
                            }

                            <HulpDetailsBlok Titel="Zo leest u de tekening"
                                             Beschrijving="Open alleen als u maatlagen of sleepgedrag wilt nalopen."
                                             CssClass="mb-3 small">
                                <div class="text-muted mb-3">
                                    Sleep het blauwe paneel in de tekening en trek aan de hoekpunten om het korter of langer te maken. De gestreepte buitenrand laat de <strong>@PaneelMaatUitlegHelper.MaatInOpeningLabel.ToLower()</strong> zien; de volle binnenvorm laat direct de <strong>@PaneelMaatUitlegHelper.MaatOmTeBestellenLabel.ToLower()</strong> zien nadat de vrije ruimte langs rakende randen is afgetrokken.
                                </div>
                                <div class="row g-3 align-items-center">
                                    <div class="col-sm-5">
                                        <svg viewBox="0 0 180 110" class="w-100" role="img" aria-label="Verschil tussen maat in de opening en maat om te bestellen">
                                            <rect x="20" y="16" width="120" height="72" fill="none" stroke="var(--bs-secondary-color)" stroke-width="2" stroke-dasharray="6 4" />
                                            <rect x="32" y="28" width="96" height="48" fill="var(--bs-primary-bg-subtle)" stroke="var(--bs-primary)" stroke-width="2" />
                                        </svg>
                                    </div>
                                    <div class="col-sm-7">
                                        <div class="d-flex align-items-start gap-2 mb-2">
                                            <span class="d-inline-block border border-2 border-secondary rounded flex-shrink-0" style="width: 1rem; height: 1rem; border-style: dashed;"></span>
                                            <div><strong>@PaneelMaatUitlegHelper.MaatInOpeningLabel</strong>: de vrije ruimte waar het paneel in moet passen.</div>
                                        </div>
                                        <div class="d-flex align-items-start gap-2">
                                            <span class="d-inline-block border border-primary rounded bg-primary bg-opacity-10 flex-shrink-0" style="width: 1rem; height: 1rem;"></span>
                                            <div><strong>@PaneelMaatUitlegHelper.MaatOmTeBestellenLabel</strong>: de maat die overblijft nadat de aftrek per rakende rand is toegepast.</div>
                                        </div>
                                    </div>
                                </div>
                            </HulpDetailsBlok>

                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary flex-grow-1" @onclick="ResetConceptPaneel">
                                    @(IsBewerkModus ? "Reset naar origineel" : "Reset naar selectie")
                                </button>
                                <button type="button" class="btn btn-primary flex-grow-1" @onclick="PaneelOpslaan"
                                        disabled="@(!kanOpslaan)"
                                        data-testid="paneel-opslaan-button">
                                    @(IsBewerkModus ? "Paneel opslaan" : "+ Paneel toevoegen")
                                </button>
                            </div>
                            @if (!kanOpslaan)
                            {
                                <div class="form-text mt-2">@OpslaanStatusTekst()</div>
                            }
                        }
                    </div>
                </div>
            </div>
        </section>
    }
}

<StapNavigatie HuidigeStap="panelen"
               VorigeHref="kasten"
               VolgendeHref="verificatie"
               VolgendeDisabled="@(State.Toewijzingen.Count == 0)" />
