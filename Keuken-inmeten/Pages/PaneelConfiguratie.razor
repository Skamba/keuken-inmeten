@page "/panelen"
@inject KeukenStateService State
@inject ActieFeedbackService Feedback
@implements IDisposable

<PageTitle>Stap 2 — Panelen</PageTitle>

<StapIndicator HuidigeStap="panelen" />

<h2 class="page-header">Stap 2: Panelen</h2>
<p class="text-muted">Volg deze mini-flow: 1. selecteer kast(en), 2. plaats of pas het paneel aan, 3. controleer maat en type, 4. sla op. Het paneel snapt automatisch aan kast- en paneelranden.</p>

<TerminologieUitleg Sleutels="openingsmaat,werkmaat,randspeling,scharnierzijde,scharnierpot,pothart"
                    Beschrijving="Deze woordenlijst legt de belangrijkste paneel- en scharniertermen in gewone taal uit." />

@{
    var flowStatus = StappenFlowHelper.BepaalStatus(State);
    var routeGate = StappenFlowHelper.BepaalRouteGate("panelen", flowStatus);
}

@if (routeGate is not null)
{
    <StapRouteMelding Gate="@routeGate" />
}
else
{
    var paneelReviewGroepen = OverzichtGroeperingHelper.GroepeerPaneelToewijzingen(State);
    var paneelTypeTellingen = OverzichtGroeperingHelper.MaakTellingen(State.Toewijzingen, toewijzing => TypeNaam(toewijzing.Type));

    <div class="row g-4">
        <div class="col-xl-7 col-lg-6">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <small class="text-uppercase text-muted fw-semibold" style="font-size: 0.72rem; letter-spacing: .06em;">1. Selecteer kast(en) op een wand · 2. Plaats daarna het paneel in het schema</small>
                @if (geselecteerdeKastIds.Count > 0)
                {
                    <button class="btn btn-sm btn-link text-secondary p-0" @onclick="DeselecteerAlles">Alles deselecteren ×</button>
                }
            </div>

            @foreach (var wand in State.Wanden)
            {
                var wandKasten = State.KastenVoorWand(wand.Id);
                if (wandKasten.Count == 0) continue;

                var wandApparaten = State.ApparatenVoorWand(wand.Id);
                var wandHasSelection = geselecteerdeKastIds.Any(id => wandKasten.Any(k => k.Id == id));
                var conceptVoorWand = ActieveWandId == wand.Id ? conceptPaneel : null;
                var vrijeSegmentenVoorWand = ActieveWandId == wand.Id ? VrijeSegmentenVoorSelectie() : [];

                <div class="mb-3 border @(wandHasSelection ? "border-primary" : "") rounded overflow-hidden">
                    <div class="d-flex justify-content-between align-items-center px-2 py-1 @(wandHasSelection ? "bg-primary bg-opacity-10" : "bg-light")">
                        <small class="fw-semibold">@wand.Naam</small>
                        @if (wandHasSelection)
                        {
                            <button class="btn btn-sm btn-link text-secondary p-0 text-decoration-none" style="font-size: 0.8rem;" @onclick="() => DeselecteerWand(wand.Id)">× deselecteer wand</button>
                        }
                    </div>
                    <div class="paneel-overzicht-scroll">
                        <PaneelPlaatsEditor Kasten="@wandKasten"
                                            Apparaten="@wandApparaten"
                                            WandHoogte="@wand.Hoogte"
                                            WandBreedte="@wand.Breedte"
                                            PlintHoogte="@wand.PlintHoogte"
                                            RandSpelingPerRaakrand="@State.PaneelRandSpeling"
                                            GeselecteerdeKastIds="@geselecteerdeKastIds"
                                            SvgMaxHoogte="55vh"
                                            BeperkTotContainerBreedte="false"
                                            Toewijzingen="@ToewijzingenVoorWand(wand)"
                                            VrijeSegmenten="@vrijeSegmentenVoorWand"
                                            ConceptPaneel="@conceptVoorWand"
                                            ConceptPaneelType="@formToewijzing.Type"
                                            ConceptPaneelScharnierZijde="@formToewijzing.ScharnierZijde"
                                            OnKastGeselecteerd="ToggleKast"
                                            OnConceptPaneelGewijzigd="VerwerkConceptPaneel" />
                    </div>
                </div>
            }

            <div class="mt-4">
                <h6 class="d-flex align-items-center gap-2 mb-2">
                    Toegewezen panelen
                    <span class="badge bg-secondary rounded-pill">@State.Toewijzingen.Count</span>
                </h6>
                @if (State.Toewijzingen.Count == 0)
                {
                    <p class="text-muted small">Nog geen panelen. Selecteer een kast in het schema en voeg een paneel toe.</p>
                }
                else
                {
                    <p class="text-muted small mb-3">Bekijk eerst per wand welke panelen al klaarstaan. Plaatsing en scharnierdetails blijven beschikbaar per paneel, maar staan niet meer standaard op het hoogste niveau.</p>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-5">
                            <div class="border rounded p-3 h-100">
                                <div class="text-uppercase text-muted fw-semibold mb-2" style="font-size: 0.72rem; letter-spacing: .04em;">Samenvatting</div>
                                <div class="fw-semibold">@paneelReviewGroepen.Count wand(en) met panelen</div>
                                <div class="small text-muted">@State.Toewijzingen.Count paneeltoewijzingen klaar voor review of bewerking.</div>
                            </div>
                        </div>
                        <div class="col-sm-7">
                            <div class="border rounded p-3 h-100">
                                <div class="text-uppercase text-muted fw-semibold mb-2" style="font-size: 0.72rem; letter-spacing: .04em;">Per paneeltype</div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var telling in paneelTypeTellingen)
                                    {
                                        <span class="badge text-bg-light border">@telling.Label @telling.Aantal</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    @foreach (var groep in paneelReviewGroepen)
                    {
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                    <div>
                                        <h6 class="mb-1">@groep.WandNaam</h6>
                                        <div class="small text-muted">@groep.AantalPanelen paneel/panelen op deze wand</div>
                                    </div>
                                    <div class="d-flex flex-wrap gap-2 justify-content-lg-end">
                                        @foreach (var telling in groep.TypeTellingen)
                                        {
                                            <span class="badge text-bg-light border">@telling.Label @telling.Aantal</span>
                                        }
                                    </div>
                                </div>

                                <div class="list-group list-group-flush mt-3">
                                    @foreach (var item in groep.Items)
                                    {
                                        var isOpen = bewerkToewijzingId == item.Id;
                                        <div class="list-group-item px-0" @key="item.Id">
                                            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                                <div>
                                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                                        <span class="badge @TypeBadgeClass(item.Type)">@item.TypeLabel</span>
                                                        <span class="fw-semibold">Paneel @item.Volgnummer</span>
                                                        <span class="text-muted">@FormatMm(item.Breedte) × @FormatMm(item.Hoogte)</span>
                                                        @if (isOpen)
                                                        {
                                                            <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle">Open in editor</span>
                                                        }
                                                    </div>
                                                    <div class="small text-muted">Kast(en): @item.KastenLabel</div>
                                                </div>
                                                <div class="d-flex gap-2">
                                                    <button type="button"
                                                            class="btn btn-outline-primary btn-sm"
                                                            @onclick="() => BewerkPaneel(item.Id)">
                                                        @(isOpen ? "Open" : "Bewerk")
                                                    </button>
                                                    <button type="button"
                                                            class="btn btn-outline-danger btn-sm"
                                                            @onclick="() => VerwijderPaneel(item.Id)">
                                                        Verwijder
                                                    </button>
                                                </div>
                                            </div>

                                            <details class="mt-2 small">
                                                <summary class="text-secondary">Plaatsing en technische details</summary>
                                                <div class="mt-2 d-flex flex-wrap gap-3">
                                                    <span><strong>Plaatsing:</strong> @item.PlaatsingLabel</span>
                                                    @if (item.Type == PaneelType.Deur)
                                                    {
                                                        <span><strong>Scharnier:</strong> @item.ScharnierLabel</span>
                                                    }
                                                </div>
                                            </details>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-xl-5 col-lg-6">
            <div class="sticky-top" style="top: 1rem;">
                <div class="card @(geselecteerdeKastIds.Count > 0 ? "border-primary shadow-sm" : "")">
                    <div class="card-header @(geselecteerdeKastIds.Count > 0 ? "bg-primary bg-opacity-10" : "bg-light")">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0" style="font-size: 1rem;">
                                @(IsBewerkModus ? "Paneel bewerken" : geselecteerdeKastIds.Count > 0 ? "Paneel plaatsen" : "Paneel configureren")
                            </h5>
                            <div class="d-flex align-items-center gap-2">
                                @if (IsBewerkModus)
                                {
                                    <button type="button" class="btn btn-sm btn-link text-secondary p-0" @onclick="AnnuleerBewerken">
                                        Annuleer
                                    </button>
                                }
                                @if (geselecteerdeKastIds.Count > 0)
                                {
                                    <span class="badge bg-primary rounded-pill">
                                        @(IsBewerkModus ? $"Paneel {BewerkIndex}" : $"{geselecteerdeKastIds.Count} kast(en)")
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        @{
                            var kanOpslaan = KanPaneelOpslaan();
                        }

                        <div class="border rounded p-3 mb-3 bg-body-tertiary">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0">Begeleide flow</h6>
                                <span class="badge text-bg-light">4 stappen</span>
                            </div>
                            <div class="d-grid gap-2 mb-3">
                                @foreach (var stap in PaneelFlowStappen)
                                {
                                    var status = PaneelFlowStatus(stap.Id);
                                    <div class="d-flex justify-content-between align-items-start gap-3 border rounded px-3 py-2 @PaneelFlowContainerClass(status)">
                                        <div>
                                            <div class="fw-semibold">@stap.Titel</div>
                                            <div class="small text-muted">@stap.Beschrijving</div>
                                        </div>
                                        <span class="badge @PaneelFlowBadgeClass(status)">@PaneelFlowLabel(status)</span>
                                    </div>
                                }
                            </div>
                            <div class="row g-3 small">
                                <div class="col-md-4">
                                    <div class="text-uppercase text-muted fw-semibold" style="font-size: 0.72rem; letter-spacing: .04em;">Nog te doen</div>
                                    <div>@VolgendePaneelStapTekst()</div>
                                </div>
                                <div class="col-md-4">
                                    <div class="text-uppercase text-muted fw-semibold" style="font-size: 0.72rem; letter-spacing: .04em;">Geselecteerd</div>
                                    <div>@GeselecteerdePaneelStatusTekst()</div>
                                </div>
                                <div class="col-md-4">
                                    <div class="text-uppercase text-muted fw-semibold" style="font-size: 0.72rem; letter-spacing: .04em;">Klaar om op te slaan</div>
                                    <div>@(kanOpslaan ? "Ja, u kunt nu opslaan." : OpslaanStatusTekst())</div>
                                </div>
                            </div>
                        </div>

                        @if (geselecteerdeKastIds.Count == 0)
                        {
                            <div class="text-center text-muted py-4">
                                <div class="mb-3" style="font-size: 3rem; opacity: 0.15;">🪟</div>
                                <p class="mb-3">Klik op een of meer kasten binnen dezelfde wand om te beginnen. Daarna worden plaatsing, maat, type en opslaan hier actief.</p>
                                <div class="d-grid gap-2 col-lg-8 mx-auto">
                                    <button type="button" class="btn btn-outline-secondary" disabled>2. Plaats of pas paneel aan</button>
                                    <button type="button" class="btn btn-outline-secondary" disabled>3. Controleer maat en type</button>
                                    <button type="button" class="btn btn-primary" disabled>4. Sla op</button>
                                </div>
                                <div class="form-text mt-2">Deze onderdelen worden actief zodra stap 1 klaar is.</div>
                            </div>
                        }
                        else
                        {
                            var conceptMaatInfo = BerekenConceptMaatInfo();
                            var vrijeSegmenten = VrijeSegmentenVoorSelectie();

                            <div class="alert alert-primary small py-2">
                                Sleep het blauwe paneel in de tekening en trek aan de hoekpunten om het korter of langer te maken. De gestreepte buitenrand laat de <strong>@PaneelMaatUitlegHelper.MaatInOpeningLabel.ToLower()</strong> zien; de volle binnenvorm laat direct de <strong>@PaneelMaatUitlegHelper.MaatOmTeBestellenLabel.ToLower()</strong> zien nadat de vrije ruimte langs rakende randen is afgetrokken.
                            </div>

                            <div class="border rounded bg-light p-3 mb-3 small">
                                <div class="fw-semibold mb-2">Zo leest u de tekening</div>
                                <div class="row g-3 align-items-center">
                                    <div class="col-sm-5">
                                        <svg viewBox="0 0 180 110" class="w-100" role="img" aria-label="Verschil tussen maat in de opening en maat om te bestellen">
                                            <rect x="20" y="16" width="120" height="72" fill="none" stroke="var(--bs-secondary-color)" stroke-width="2" stroke-dasharray="6 4" />
                                            <rect x="32" y="28" width="96" height="48" fill="var(--bs-primary-bg-subtle)" stroke="var(--bs-primary)" stroke-width="2" />
                                        </svg>
                                    </div>
                                    <div class="col-sm-7">
                                        <div class="d-flex align-items-start gap-2 mb-2">
                                            <span class="d-inline-block border border-2 border-secondary rounded flex-shrink-0" style="width: 1rem; height: 1rem; border-style: dashed;"></span>
                                            <div><strong>@PaneelMaatUitlegHelper.MaatInOpeningLabel</strong>: de vrije ruimte waar het paneel in moet passen.</div>
                                        </div>
                                        <div class="d-flex align-items-start gap-2">
                                            <span class="d-inline-block border border-primary rounded bg-primary bg-opacity-10 flex-shrink-0" style="width: 1rem; height: 1rem;"></span>
                                            <div><strong>@PaneelMaatUitlegHelper.MaatOmTeBestellenLabel</strong>: de maat die overblijft nadat de aftrek per rakende rand is toegepast.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="small text-muted mb-3">
                                <div><strong>Wand:</strong> @ActieveWandNaam</div>
                                <div><strong>Geselecteerd:</strong> @GeselecteerdeKastNamen</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">@PaneelMaatUitlegHelper.RandSpelingLabel (randspeling, mm)</label>
                                <input type="number"
                                       class="form-control"
                                       @bind="RandSpelingInput"
                                       min="0"
                                       step="0.5" />
                                <div class="form-text">Standaard 2 mm. Elke rand die een andere kast-, apparaat- of paneelrand raakt, krijgt deze aftrek meteen mee in de maat om te bestellen.</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Type paneel</label>
                                <div class="d-flex gap-2 flex-wrap">
                                    @foreach (var type in Enum.GetValues<PaneelType>())
                                    {
                                        <button type="button"
                                                class="btn btn-sm @(formToewijzing.Type == type ? "btn-primary" : "btn-outline-secondary")"
                                                @onclick="() => formToewijzing.Type = type">
                                            @TypeNaam(type)
                                        </button>
                                    }
                                </div>
                            </div>

                            @if (formToewijzing.Type == PaneelType.Deur)
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Draairichting van de deur (scharnierzijde)</label>
                                    <div class="d-flex gap-2">
                                        <button type="button"
                                                class="btn btn-sm @(formToewijzing.ScharnierZijde == ScharnierZijde.Links ? "btn-primary" : "btn-outline-secondary")"
                                                @onclick="() => formToewijzing.ScharnierZijde = ScharnierZijde.Links">
                                            ◄ Links
                                        </button>
                                        <button type="button"
                                                class="btn btn-sm @(formToewijzing.ScharnierZijde == ScharnierZijde.Rechts ? "btn-primary" : "btn-outline-secondary")"
                                                @onclick="() => formToewijzing.ScharnierZijde = ScharnierZijde.Rechts">
                                            Rechts ►
                                        </button>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Afstand hart scharnierpot tot rand (mm)</label>
                                    <input type="number"
                                           class="form-control"
                                           @bind="PotHartInput"
                                           min="@ScharnierBerekeningService.MinCupCenterVanRand"
                                           step="0.5" />
                                    <div class="form-text">Technische term: pot-hart van rand. Deze maat wordt gebruikt voor alle 35 mm scharnierpotjes in dit deurpaneel en de laatst gebruikte waarde wordt onthouden.</div>
                                </div>
                            }

                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Breedte (mm)</label>
                                    <input type="number" class="form-control" @bind="BreedteInput" min="50" step="1" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Hoogte (mm)</label>
                                    <input type="number" class="form-control" @bind="HoogteInput" min="50" step="1" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Links (mm)</label>
                                    <input type="number" class="form-control" @bind="LinksInput" min="0" step="1" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold small text-uppercase" style="font-size: 0.72rem; letter-spacing: .04em;">Onderkant (mm)</label>
                                    <input type="number" class="form-control" @bind="OnderkantInput" min="0" step="1" />
                                </div>
                            </div>

                            @if (conceptPaneel is not null)
                            {
                                <div class="border rounded bg-light p-3 mb-3 small">
                                    <div class="fw-semibold mb-2">Plaatsing</div>
                                    <div class="d-flex flex-wrap gap-3">
                                        <span>Links <strong>@FormatMm(conceptPaneel.XPositie)</strong></span>
                                        <span>Onderkant <strong>@FormatMm(conceptPaneel.HoogteVanVloer)</strong></span>
                                        <span>Rechts <strong>@FormatMm(conceptPaneel.Rechterkant)</strong></span>
                                        <span>Bovenkant <strong>@FormatMm(conceptPaneel.Bovenzijde)</strong></span>
                                    </div>
                                </div>
                            }

                            @if (conceptMaatInfo is not null)
                            {
                                <div class="border rounded bg-light p-3 mb-3 small">
                                    <div class="fw-semibold mb-2">Van maat in de opening naar maat om te bestellen</div>
                                    <div class="mb-1">@PaneelMaatUitlegHelper.MaatInOpeningLabelMetTerm <strong>@FormatMm(conceptMaatInfo.OpeningsRechthoek.Breedte)</strong> × <strong>@FormatMm(conceptMaatInfo.OpeningsRechthoek.Hoogte)</strong></div>
                                    <div class="mb-2">@PaneelMaatUitlegHelper.MaatOmTeBestellenLabelMetTerm <strong>@FormatMm(conceptMaatInfo.PaneelRechthoek.Breedte)</strong> × <strong>@FormatMm(conceptMaatInfo.PaneelRechthoek.Hoogte)</strong></div>
                                    <div><strong>Breedteformule:</strong> @PaneelMaatUitlegHelper.BreedteFormule(conceptMaatInfo)</div>
                                    <div class="mb-2">@PaneelMaatUitlegHelper.BreedteAftrekUitleg(conceptMaatInfo)</div>
                                    <div><strong>Hoogteformule:</strong> @PaneelMaatUitlegHelper.HoogteFormule(conceptMaatInfo)</div>
                                    <div>@PaneelMaatUitlegHelper.HoogteAftrekUitleg(conceptMaatInfo)</div>
                                </div>
                            }

                            @if (vrijeSegmenten.Count > 0)
                            {
                                <div class="border rounded bg-light p-3 mb-3 small">
                                    <div class="fw-semibold mb-2">Vrije vakken</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        @for (int i = 0; i < vrijeSegmenten.Count; i++)
                                        {
                                            var segment = vrijeSegmenten[i];
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-success"
                                                    @onclick="() => GebruikVrijSegment(segment)">
                                                @VrijSegmentLabel(i, segment)
                                            </button>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary flex-grow-1" @onclick="ResetConceptPaneel">
                                    @(IsBewerkModus ? "Reset naar origineel" : "Reset naar selectie")
                                </button>
                                <button type="button" class="btn btn-primary flex-grow-1" @onclick="PaneelOpslaan"
                                        disabled="@(!kanOpslaan)">
                                    @(IsBewerkModus ? "Paneel opslaan" : "+ Paneel toevoegen")
                                </button>
                            </div>
                            @if (!kanOpslaan)
                            {
                                <div class="form-text mt-2">@OpslaanStatusTekst()</div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<StapNavigatie HuidigeStap="panelen"
               VorigeHref="kasten"
               VolgendeHref="verificatie"
               VolgendeDisabled="@(State.Toewijzingen.Count == 0)" />
