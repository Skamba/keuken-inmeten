@using Keuken_inmeten.Services.Interop
@inject IJSRuntime JS
@inject KeukenStateService State
@inject DeelLinkService Delen
@implements IAsyncDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Keuken Inmeten</a>
        <button title="Navigatiemenu openen of sluiten"
                aria-label="Navigatiemenu openen of sluiten"
                aria-expanded="@(!collapseNavMenu)"
                aria-controls="app-navmenu"
                class="navbar-toggler"
                @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div id="app-navmenu" class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    @{
        var flowStatus = StappenFlowHelper.BepaalStatus(State);
    }
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                🏠 Home
            </NavLink>
        </div>
        @foreach (var stap in StappenFlowHelper.AlleStappen)
        {
            var gate = StappenFlowHelper.BepaalRouteGate(stap.Id, flowStatus);
            <div class="nav-item px-3">
                @if (gate is null)
                {
                    <NavLink class="nav-link" href="@stap.Route">
                        @StapIcoon(stap.Id) @stap.Nummer. @stap.Label
                    </NavLink>
                }
                else
                {
                    <span class="nav-link disabled"
                          title="@gate.Reden"
                          aria-disabled="true"
                          aria-label="@($"{stap.Nummer}. {stap.Label}. {gate.Reden}")">
                        🔒 @stap.Nummer. @stap.Label
                    </span>
                }
            </div>
        }
        <div class="nav-item px-3">
            <button type="button"
                    class="nav-link border-0 w-100 text-start nav-action-button"
                    @onclick="DeelHuidigePagina"
                    title="Deel een link naar deze keukenconfiguratie"
                    data-testid="nav-share-button">
                🔗 Deel link
            </button>
        </div>
        <div class="nav-item px-3 mt-auto">
            <button type="button"
                    class="nav-link border-0 w-100 text-start nav-action-button"
                    @onclick="ToggleTheme"
                    title="Wissel tussen licht en donker thema">
                @themeIcon Thema
            </button>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string themeIcon = "🌙";
    private ThemeJsInterop? themeInterop;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private ThemeJsInterop ThemeInterop => themeInterop ??= new(JS);

    protected override void OnInitialized()
        => State.OnStateChanged += HandleStateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await ThemeInterop.GetThemeAsync();
            themeIcon = theme == "dark" ? "☀️" : "🌙";
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        var newTheme = await ThemeInterop.ToggleThemeAsync();
        themeIcon = newTheme == "dark" ? "☀️" : "🌙";
    }

    private Task DeelHuidigePagina()
        => Delen.DeelHuidigePaginaAsync();

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void HandleStateChanged() => _ = InvokeAsync(StateHasChanged);

    private static string StapIcoon(string stapId) => stapId switch
    {
        "kasten" => "📐",
        "panelen" => "🪟",
        "verificatie" => "✅",
        "bestellijst" => "🧾",
        "zaagplan" => "🪚",
        _ => "•"
    };

    public async ValueTask DisposeAsync()
    {
        State.OnStateChanged -= HandleStateChanged;

        if (themeInterop is not null)
            await themeInterop.DisposeAsync();
    }
}
