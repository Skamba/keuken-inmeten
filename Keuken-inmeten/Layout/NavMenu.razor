@inject IJSRuntime JS
@inject KeukenStateService State

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Keuken Inmeten</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    @{
        var flowStatus = StappenFlowHelper.BepaalStatus(State);
    }
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                🏠 Home
            </NavLink>
        </div>
        @foreach (var stap in StappenFlowHelper.AlleStappen)
        {
            var gate = StappenFlowHelper.BepaalRouteGate(stap.Id, flowStatus);
            <div class="nav-item px-3">
                @if (gate is null)
                {
                    <NavLink class="nav-link" href="@stap.Route">
                        @StapIcoon(stap.Id) @stap.Nummer. @stap.Label
                    </NavLink>
                }
                else
                {
                    <span class="nav-link disabled" title="@gate.Reden">
                        🔒 @stap.Nummer. @stap.Label
                    </span>
                }
            </div>
        }
        <div class="nav-item px-3 mt-auto">
            <button class="nav-link border-0 w-100 text-start theme-toggle" @onclick="ToggleTheme" title="Wissel tussen licht en donker thema">
                @themeIcon Thema
            </button>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string themeIcon = "🌙";

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("keukenTheme.get");
            themeIcon = theme == "dark" ? "☀️" : "🌙";
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        var newTheme = await JS.InvokeAsync<string>("keukenTheme.toggle");
        themeIcon = newTheme == "dark" ? "☀️" : "🌙";
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private static string StapIcoon(string stapId) => stapId switch
    {
        "kasten" => "📐",
        "panelen" => "🪟",
        "verificatie" => "✅",
        "bestellijst" => "🧾",
        "zaagplan" => "🪚",
        _ => "•"
    };
}
