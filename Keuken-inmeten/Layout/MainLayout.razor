@inherits LayoutComponentBase
@inject PersistentieService Persistentie

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-4">
            <div class="d-flex justify-content-end mt-3">
                <OpslagStatusBadge />
            </div>

            @if (Persistentie.HeeftGedeeldeLinkGeladen)
            {
                <div class="alert alert-info mt-3" role="status">
                    Gedeelde configuratie geladen. Wijzigingen worden vanaf nu automatisch op dit apparaat opgeslagen.
                </div>
            }

            @if (Persistentie.HeeftOngeldigeDeelLink)
            {
                <div class="alert alert-warning mt-3" role="alert">
                    De deellink kon niet worden gelezen. Controleer of de volledige URL is gekopieerd.
                </div>
            }

            @Body
        </article>
    </main>
</div>

<ActieFeedbackToast />
