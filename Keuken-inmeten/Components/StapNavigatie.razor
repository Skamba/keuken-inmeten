@inject KeukenStateService State

@{
    var flowStatus = StappenFlowHelper.BepaalStatus(State);
}

<div class="stap-navigatie">
    @if (!string.IsNullOrEmpty(VorigeHref))
    {
        <a href="@NormaliseerHref(VorigeHref)" class="btn btn-outline-secondary text-nowrap">← @BepaalVorigeLabel()</a>
    }
    else
    {
        <span></span>
    }

    <div class="stap-navigatie-stappen">
        @for (var i = 0; i < StappenFlowHelper.AlleStappen.Count; i++)
        {
            var stap = StappenFlowHelper.AlleStappen[i];
            var isActief = HuidigeStap == stap.Id;
            var isNavigeerbaar = StappenFlowHelper.MagNavigeren(stap.Id, HuidigeStap, flowStatus);

            @if (isNavigeerbaar)
            {
                <a href="@stap.Route" class="@(isActief ? "actief" : "")">@stap.Nummer. @stap.Label</a>
            }
            else
            {
                <span class="stap-navigatie-link vergrendeld"
                      title="@StappenFlowHelper.BepaalRouteGate(stap.Id, flowStatus)?.Reden">
                    @stap.Nummer. @stap.Label
                </span>
            }

            @if (i < StappenFlowHelper.AlleStappen.Count - 1)
            {
                <span class="stap-pijl">›</span>
            }
        }
    </div>

    @if (Midden is not null)
    {
        <div class="stap-navigatie-midden">@Midden</div>
    }

    @if (!string.IsNullOrEmpty(VolgendeHref))
    {
        @if (VolgendeDisabled || VolgendeIsVergrendeld(flowStatus))
        {
            <span class="btn btn-success disabled text-nowrap"
                  aria-disabled="true"
                  title="@VolgendeGateTekst(flowStatus)">
                @BepaalVolgendeLabel() →
            </span>
        }
        else
        {
            <a href="@NormaliseerHref(VolgendeHref)" class="btn btn-success text-nowrap">@BepaalVolgendeLabel() →</a>
        }
    }
    else
    {
        <span></span>
    }
</div>

@code {
    [Parameter] public string HuidigeStap { get; set; } = "";
    [Parameter] public string? VorigeHref { get; set; }
    [Parameter] public string? VorigeLabel { get; set; }
    [Parameter] public string? VolgendeHref { get; set; }
    [Parameter] public string? VolgendeLabel { get; set; }
    [Parameter] public bool VolgendeDisabled { get; set; }
    [Parameter] public RenderFragment? Midden { get; set; }

    private static string NormaliseerHref(string? href)
        => string.IsNullOrWhiteSpace(href) ? "" : href.TrimStart('/');

    private string BepaalVorigeLabel()
        => !string.IsNullOrWhiteSpace(VorigeLabel)
            ? VorigeLabel
            : string.IsNullOrWhiteSpace(VorigeHref)
                ? "Vorige stap"
                : StappenFlowHelper.MaakTerugNaarLabel(NormaliseerHref(VorigeHref));

    private string BepaalVolgendeLabel()
        => !string.IsNullOrWhiteSpace(VolgendeLabel)
            ? VolgendeLabel
            : string.IsNullOrWhiteSpace(VolgendeHref)
                ? "Volgende stap"
                : StappenFlowHelper.MaakVolgendeLabel(NormaliseerHref(VolgendeHref));

    private bool VolgendeIsVergrendeld(StappenFlowStatus flowStatus)
        => !string.IsNullOrWhiteSpace(VolgendeHref)
            && !StappenFlowHelper.IsBeschikbaar(NormaliseerHref(VolgendeHref), flowStatus);

    private string? VolgendeGateTekst(StappenFlowStatus flowStatus)
        => string.IsNullOrWhiteSpace(VolgendeHref)
            ? null
            : StappenFlowHelper.BepaalRouteGate(NormaliseerHref(VolgendeHref), flowStatus)?.Reden;
}
