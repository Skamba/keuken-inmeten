@using Keuken_inmeten.Models
@using Keuken_inmeten.Services

<section class="paneel-review-overzicht"
         data-testid="paneel-review-overzicht"
         data-wand-id="@Groep?.WandId"
         data-wand-naam="@GeopendeWandNaam">
    <div class="border rounded p-3 paneel-review-overzicht-kaart">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3 paneel-review-overzicht-header">
            <div>
                <div class="small text-uppercase text-muted fw-semibold mb-1" style="font-size: 0.72rem; letter-spacing: .04em;">Overzicht</div>
                <h6 class="mb-1">@GeopendeWandNaam</h6>
                @if (Groep is { } overzichtGroep)
                {
                    <div class="small text-muted">
                        @overzichtGroep.AantalPanelen paneel/panelen op deze wand
                        @if (overzichtGroep.TypeTellingen.Count > 0)
                        {
                            <span> · @OverzichtGroeperingHelper.FormatteerTellingen(overzichtGroep.TypeTellingen)</span>
                        }
                    </div>
                }
                else
                {
                    <div class="small text-muted">Nog geen panelen op deze wand. Voeg links een paneel toe om dit overzicht te vullen.</div>
                }
            </div>
            @if (Groep is not null)
            {
                <span class="badge text-bg-light border">@Groep.AantalPanelen paneel/panelen</span>
            }
        </div>

        @if (Groep is null)
        {
            <div class="paneel-review-empty-state small text-muted" data-testid="paneel-review-empty-state">
                <div>Gebruik de actieve werkruimte om een eerste paneel toe te voegen of te bewerken.</div>
                @if (ProjectToewijzingenAantal > 0)
                {
                    <div class="mt-2">Er staan al @ProjectToewijzingenAantal paneel/panelen elders in het project. Open die wand om ze hier te zien.</div>
                }
            </div>
        }
        else
        {
            <div class="paneel-review-groep paneel-review-groep--actief"
                 data-testid="paneel-review-groep"
                 data-wand-id="@Groep.WandId"
                 data-wand-naam="@Groep.WandNaam">
                <div class="list-group list-group-flush">
                    @foreach (var item in Groep.Items)
                    {
                        var isOpen = BewerkToewijzingId == item.Id;

                        <div class="list-group-item px-0 paneel-review-item" @key="item.Id">
                            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                <div class="paneel-review-item-main">
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                        <span class="badge @TypeBadgeClass(item.Type)">@item.TypeLabel</span>
                                        <span class="fw-semibold">Paneel @item.Volgnummer</span>
                                        @if (isOpen)
                                        {
                                            <span class="paneel-review-status">Open in editor</span>
                                        }
                                    </div>
                                    <div class="small text-muted">
                                        @FormatMm(item.Breedte) × @FormatMm(item.Hoogte) · Kast(en): @item.KastenLabel
                                    </div>
                                </div>
                                <div class="d-flex gap-2">
                                    <button type="button"
                                            class="btn btn-outline-primary btn-sm"
                                            @onclick="@(() => OnBewerkPaneel.InvokeAsync(item.Id))">
                                        @(isOpen ? "Open" : "Bewerk")
                                    </button>
                                </div>
                            </div>

                            <details class="mt-2 small paneel-review-item-details">
                                <summary class="text-secondary">Plaatsing en verwijderen</summary>
                                <div class="mt-2 d-flex flex-column gap-3">
                                    <div class="d-flex flex-wrap gap-3">
                                        <span><strong>Plaatsing:</strong> @item.PlaatsingLabel</span>
                                        @if (item.Type == PaneelType.Deur)
                                        {
                                            <span><strong>Scharnier:</strong> @item.ScharnierLabel</span>
                                        }
                                    </div>
                                    <div>
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm"
                                                @onclick="@(() => OnVerwijderPaneel.InvokeAsync(item.Id))">
                                            Verwijder paneel
                                        </button>
                                    </div>
                                </div>
                            </details>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public OverzichtGroeperingHelper.PaneelReviewGroep? Groep { get; set; }
    [Parameter, EditorRequired] public string GeopendeWandNaam { get; set; } = string.Empty;
    [Parameter, EditorRequired] public int ProjectToewijzingenAantal { get; set; }
    [Parameter] public Guid? BewerkToewijzingId { get; set; }
    [Parameter, EditorRequired] public EventCallback<Guid> OnBewerkPaneel { get; set; }
    [Parameter, EditorRequired] public EventCallback<Guid> OnVerwijderPaneel { get; set; }

    private static string TypeBadgeClass(PaneelType type)
        => PaneelConfiguratieHelper.TypeBadgeClass(type);

    private static string FormatMm(double waarde) => $"{waarde:0.#} mm";
}
