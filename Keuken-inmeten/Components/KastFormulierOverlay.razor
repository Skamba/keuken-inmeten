@using Keuken_inmeten.Models
@using Keuken_inmeten.Pages
@using Keuken_inmeten.Services

<div class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-start"
     style="z-index: 1050; background: rgba(0,0,0,0.4); overflow-y: auto; padding: 2rem 1rem;"
     @onclick="OnSluiten">
    <div class="card border-success shadow-lg"
         style="max-width: 900px; width: 100%;"
         data-testid="kast-form"
         @onclick:stopPropagation="true">
        <div class="card-header bg-success bg-opacity-10 d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@(IsBewerken ? "Kast bewerken" : "Kast toevoegen")</h5>
            <button type="button" class="btn-close" @onclick="OnSluiten"></button>
        </div>
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <div class="small fw-semibold text-uppercase text-success-emphasis">Huidige stap</div>
                    <div class="h6 mb-1" data-testid="kast-form-stap-label">Stap @HuidigFormulier.Stap.HuidigeStap van @HuidigFormulier.Stap.LaatsteStap: @HuidigFormulier.Stap.Label</div>
                    <p class="text-muted small mb-0">@HuidigFormulier.Stap.Intro</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge text-bg-light" data-testid="kast-form-progress">Stap @HuidigFormulier.Stap.HuidigeStap/@HuidigFormulier.Stap.LaatsteStap</span>
                    <StapHulpDrawer StapId="kasten" KnopLabel="Meer hulp" />
                </div>
            </div>

            @if (HuidigFormulier.Stap.HuidigeStap == 1)
            {
                @if (!IsBewerken && Templates.Count > 0)
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">Eerder gebruikte kasten</label>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var template in Templates.OrderByDescending(t => t.LaatstGebruikt))
                            {
                                var templateLocal = template;
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        @onclick="@(() => OnTemplateGekozen.InvokeAsync(templateLocal))"
                                        title="@template.Naam · @template.Breedte×@template.Hoogte×@template.Diepte mm">
                                    <span class="badge @KastTypeBadgeClass(template.Type) me-1">@template.Type</span>
                                    @template.Naam
                                    <small class="text-muted ms-1">@template.Breedte×@template.Hoogte</small>
                                </button>
                            }
                        </div>
                    </div>
                    <hr class="my-2" />
                }

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Wand</label>
                        <select class="form-select"
                                value="@ActieveWandId"
                                @onchange="OnWandGewijzigd"
                                data-testid="kast-wand-select">
                            @foreach (var wand in Wanden)
                            {
                                <option value="@wand.Id">@wand.Naam</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Naam</label>
                        <input type="text" class="form-control" @bind="FormKast.Naam" @bind:event="oninput"
                               data-testid="kast-naam-input" />
                        <div class="form-text hulp-hint" data-testid="kast-naam-hint">Bijvoorbeeld Onderkast spoelbak. Kies een naam die u later in panelen en bestellijst snel herkent.</div>
                    </div>
                </div>
            }
            else if (HuidigFormulier.Stap.HuidigeStap == 2)
            {
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Breedte (mm)</label>
                        <input type="number" class="form-control" @bind="FormKast.Breedte" min="100" step="10"
                               data-testid="kast-breedte-input" />
                        <div class="form-text hulp-hint" data-testid="kast-breedte-hint">Bijvoorbeeld 600. Gebruik de buitenmaat van de kastbreedte.</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Hoogte (mm)</label>
                        <input type="number" class="form-control" @bind="FormKast.Hoogte" @bind:after="HandleHoogteGewijzigd" min="100" step="10"
                               data-testid="kast-hoogte-input" />
                        <div class="form-text hulp-hint" data-testid="kast-hoogte-hint">Bijvoorbeeld 720 voor een onderkast of rond 2000 voor een hoge kast.</div>
                        <div class="form-text">Type: <span class="badge @KastTypeBadgeClass(FormKastType)">@FormKastType</span></div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Diepte (mm)</label>
                        <input type="number" class="form-control" @bind="FormKast.Diepte" min="100" step="10"
                               data-testid="kast-diepte-input" />
                        <div class="form-text hulp-hint" data-testid="kast-diepte-hint">Bijvoorbeeld 560. Gebruik de buitendiepte van de kastromp.</div>
                    </div>
                </div>

                <div class="small text-muted mb-0">
                    U vult hier alleen de hoofdmaten in. In de volgende stap controleert u bewust de gaatjesrij en kastdetails, ook als de standaard blijft staan.
                </div>
            }
            else if (HuidigFormulier.Stap.HuidigeStap == 3)
            {
                <div class="card border-0 bg-body-tertiary mb-3">
                    <div class="card-body">
                        <button type="button"
                                class="btn btn-outline-secondary w-100 d-flex justify-content-between align-items-center gap-3"
                                @onclick="ToggleTechnischeInstellingen">
                            <span class="text-start">
                                <span class="d-block fw-semibold">Controleer gaatjesrij en kastdetails</span>
                                <span class="small text-muted">Kritieke controle voor passende panelen en correcte boringen. Open om waarden te controleren of aan te passen.</span>
                            </span>
                            <span class="fs-5" aria-hidden="true">@(HuidigFormulier.ToonTechnischeInstellingen ? "−" : "+")</span>
                        </button>

                        @if (HuidigFormulier.ToonTechnischeInstellingen)
                        {
                            <div class="mt-3">
                                <div class="alert alert-warning small mb-3" role="alert">
                                    Controleer deze waarden bewust. Ze bepalen of panelen passen en of de gaatjesrij goed aansluit.
                                </div>
                                <div class="row g-3 mb-3">
                                    <div class="col-md-4">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <label class="form-label mb-0">Dikte van de kastwand (mm)</label>
                                            <HulpInfoKnop Titel="Dikte van de kastwand"
                                                          Tekst="Gebruik hier de werkelijke dikte van de zijplaten van deze kast. Die maat heeft invloed op systeemgaten en scharnieronderdelen."
                                                          Voorbeeld="Standaard is dit meestal 18 mm."
                                                          WatNuDoen="Controleer of deze standaard klopt; pas hem alleen aan als deze kast met een andere plaatdikte wordt gebouwd." />
                                        </div>
                                        <input type="number" class="form-control" @bind="FormKast.Wanddikte" @bind:after="HandleTechnischeInstellingGewijzigd" min="1" step="1" />
                                        <div class="form-text hulp-hint">Controleer deze maat bewust, ook als u 18 mm laat staan.</div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <label class="form-label mb-0">Afstand tussen systeemgaten (mm)</label>
                                            <HulpInfoKnop Titel="Rij systeemgaten"
                                                          Tekst="Dit is de vaste steek van de gatenrij in de kastzijwand. Die bepaalt waar de montageplaat en andere boringen uitkomen."
                                                          Voorbeeld="Voor veel keukenkasten is 32 mm de standaard."
                                                          WatNuDoen="Controleer of 32 mm klopt; pas dit aan als deze kast een andere gatensteek gebruikt dan de standaard." />
                                        </div>
                                        <input type="number" class="form-control" @bind="FormKast.GaatjesAfstand" @bind:after="HandleTechnischeInstellingGewijzigd" min="1" step="1" />
                                        <div class="form-text hulp-hint">De standaard gatensteek is vaak 32 mm, maar controle blijft nodig.</div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <label class="form-label mb-0">Afstand onderkant bovenplank tot eerste gat (mm)</label>
                                            <HulpInfoKnop Titel="Eerste gat vanaf de bovenste plank"
                                                          Tekst="Deze maat bepaalt waar de eerste positie van de systeemgaten start ten opzichte van de bovenkant van de kastromp."
                                                          Voorbeeld="Bij veel kasten is dit 19 mm vanaf de onderkant van de bovenste plank."
                                                          WatNuDoen="Controleer of deze maat klopt voor deze kast; pas alleen aan als leverancier of kasttype van de standaard afwijkt." />
                                        </div>
                                        <input type="number" class="form-control" @bind="FormKast.EersteGaatVanBoven" @bind:after="HandleTechnischeInstellingGewijzigd" min="1" step="1" />
                                        <div class="form-text hulp-hint">Meet vanaf de onderkant van de bovenste plank naar het eerste gat.</div>
                                    </div>
                                </div>

                                <div class="form-check mb-3">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="kast-technische-controle-checkbox"
                                           @bind="TechnischeControleBevestigdBinding"
                                           data-testid="kast-technische-controle-checkbox" />
                                    <label class="form-check-label" for="kast-technische-controle-checkbox">
                                        @HuidigFormulier.TechnischeControleCheckboxLabel
                                    </label>
                                </div>

                                <p class="text-muted small mb-0"><em>Tip: dubbelklik in de wandopstelling om een plank toe te voegen. Sleep planken of gebruik de pijltjestoetsen. Selecteer een plank en druk Delete om hem te verwijderen.</em></p>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mt-3 mb-0" role="alert">
                                <div class="fw-semibold mb-1">Kritieke controle</div>
                                <div class="small mb-2">Deze waarden bepalen of panelen passen en of de gaatjesrij aansluit. Controleer bewust of de standaard klopt voor deze kast.</div>
                                <div class="small text-body-secondary mb-3">@HuidigFormulier.TechnischeControleSamenvatting</div>
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="kast-technische-controle-checkbox-collapsed"
                                           @bind="TechnischeControleBevestigdBinding"
                                           data-testid="kast-technische-controle-checkbox" />
                                    <label class="form-check-label" for="kast-technische-controle-checkbox-collapsed">
                                        @HuidigFormulier.TechnischeControleCheckboxLabel
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="row g-4 align-items-start">
                    <div class="col-lg-6">
                        <div class="card border-0 bg-body-tertiary h-100">
                            <div class="card-body">
                                <h6 class="mb-3">Controle voor opslaan</h6>
                                <dl class="row mb-0 small">
                                    <dt class="col-sm-4">Wand</dt>
                                    <dd class="col-sm-8">@ActieveWandNaam</dd>

                                    <dt class="col-sm-4">Naam</dt>
                                    <dd class="col-sm-8">@FormKast.Naam</dd>

                                    <dt class="col-sm-4">Type</dt>
                                    <dd class="col-sm-8"><span class="badge @KastTypeBadgeClass(FormKastType)">@FormKastType</span></dd>

                                    <dt class="col-sm-4">Maten</dt>
                                    <dd class="col-sm-8">@FormKast.Breedte × @FormKast.Hoogte × @FormKast.Diepte mm</dd>

                                    <dt class="col-sm-4">Techniek</dt>
                                    <dd class="col-sm-8">
                                        <span>@HuidigFormulier.TechnischeControleSamenvatting</span>
                                    </dd>
                                </dl>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="text-center">
                            <KastVisueel Kast="@FormKast" MaxHoogte="180" />
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-4">
                <button type="button"
                        class="btn btn-outline-secondary"
                        @onclick="OnVorige"
                        disabled="@(HuidigFormulier.Stap.HuidigeStap == 1)"
                        data-testid="kast-form-terug-button">
                    Terug
                </button>
                <div class="d-flex gap-2">
                    @if (HuidigFormulier.Stap.HuidigeStap < HuidigFormulier.Stap.LaatsteStap)
                    {
                        <button type="button"
                                class="btn btn-primary"
                                @onclick="OnVolgende"
                                disabled="@(!HuidigFormulier.Stap.KanNaarVolgendeStap)"
                                data-testid="kast-form-volgende-button">
                            Volgende stap
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary" @onclick="OnOpslaan"
                                disabled="@string.IsNullOrWhiteSpace(FormKast.Naam)"
                                data-testid="kast-opslaan-button">
                            @(IsBewerken ? "Opslaan" : "Kast toevoegen")
                        </button>
                    }
                    <button type="button" class="btn btn-outline-secondary" @onclick="OnSluiten">
                        Annuleren
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public bool IsBewerken { get; set; }
    [Parameter, EditorRequired] public int Stap { get; set; }
    [Parameter, EditorRequired] public Guid? ActieveWandId { get; set; }
    [Parameter, EditorRequired] public IReadOnlyList<KeukenWand> Wanden { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<KastTemplate> Templates { get; set; } = [];
    [Parameter, EditorRequired] public Kast FormKast { get; set; } = default!;
    [Parameter, EditorRequired] public bool ToonTechnischeInstellingen { get; set; }
    [Parameter, EditorRequired] public EventCallback<bool> ToonTechnischeInstellingenChanged { get; set; }
    [Parameter, EditorRequired] public bool TechnischeControleBevestigd { get; set; }
    [Parameter, EditorRequired] public EventCallback<bool> TechnischeControleBevestigdChanged { get; set; }
    [Parameter, EditorRequired] public string ActieveWandNaam { get; set; } = string.Empty;
    [Parameter, EditorRequired] public EventCallback OnSluiten { get; set; }
    [Parameter, EditorRequired] public EventCallback OnVorige { get; set; }
    [Parameter, EditorRequired] public EventCallback OnVolgende { get; set; }
    [Parameter, EditorRequired] public EventCallback OnOpslaan { get; set; }
    [Parameter, EditorRequired] public EventCallback<ChangeEventArgs> OnWandGewijzigd { get; set; }
    [Parameter, EditorRequired] public EventCallback<KastTemplate> OnTemplateGekozen { get; set; }
    [Parameter, EditorRequired] public EventCallback OnHoogteGewijzigd { get; set; }
    [Parameter, EditorRequired] public EventCallback OnTechnischeInstellingGewijzigd { get; set; }

    private KastType FormKastType => IndelingFormulierHelper.InferKastType(FormKast.Hoogte);
    private KastFormulierModel HuidigFormulier
        => KastenInvoerFormulierFlowHelper.BouwKastFormulierModel(
            Stap,
            ActieveWandId,
            ActieveWandNaam,
            FormKast,
            ToonTechnischeInstellingen,
            TechnischeControleBevestigd);

    private bool TechnischeControleBevestigdBinding
    {
        get => TechnischeControleBevestigd;
        set => _ = TechnischeControleBevestigdChanged.InvokeAsync(value);
    }

    private Task ToggleTechnischeInstellingen()
        => ToonTechnischeInstellingenChanged.InvokeAsync(!ToonTechnischeInstellingen);

    private Task HandleHoogteGewijzigd()
        => OnHoogteGewijzigd.InvokeAsync();

    private Task HandleTechnischeInstellingGewijzigd()
        => OnTechnischeInstellingGewijzigd.InvokeAsync();

    private static string KastTypeBadgeClass(KastType type) => type switch
    {
        KastType.Onderkast => "bg-warning text-dark",
        KastType.Bovenkast => "bg-info text-dark",
        KastType.HogeKast => "bg-success",
        _ => "bg-secondary"
    };
}
