@inject KeukenStateService State

@{
    var stappen = StappenFlowHelper.AlleStappen;
    var huidigeIndex = stappen.ToList().FindIndex(stap => stap.Id == HuidigeStap);
    var huidigeStapInfo = huidigeIndex >= 0 ? stappen[huidigeIndex] : null;
}

<nav aria-label="Stappen" class="stap-indicator mb-3">
    @if (huidigeStapInfo is not null)
    {
        <div class="stap-indicator-current">
            <span class="stap-indicator-current-index">Stap @(huidigeIndex + 1) van @stappen.Count</span>
            <span class="stap-indicator-current-label">@huidigeStapInfo.Label</span>
        </div>
    }

    <ol class="stap-indicator-list">
        @for (int i = 0; i < stappen.Count; i++)
        {
            var stap = stappen[i];
            var nummer = i + 1;
            var isKlaar = i < huidigeIndex;
            var isActief = i == huidigeIndex;
            var stateClass = isKlaar ? "klaar" : isActief ? "actief" : "nog-niet";
            <li class="stap-indicator-item @stateClass"
                aria-current="@(isActief ? "step" : null)">
                @if (i > 0)
                {
                    <div class="stap-connector"></div>
                }
                <div class="stap-cirkel">
                    @if (isKlaar)
                    {
                        <a href="@stap.Route" class="stap-link" title="@stap.Label">
                            <span class="stap-check">✓</span>
                        </a>
                    }
                    else
                    {
                        <span class="stap-nummer">@nummer</span>
                    }
                </div>
                <div class="stap-label">
                    @if (isKlaar)
                    {
                        <a href="@stap.Route" class="stap-label-link">@stap.Label</a>
                    }
                    else
                    {
                        <span>@stap.Label</span>
                    }
                </div>
            </li>
        }
    </ol>
</nav>

@code {
    [Parameter, EditorRequired] public string HuidigeStap { get; set; } = "";
}
