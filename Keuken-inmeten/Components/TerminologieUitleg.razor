@{
    var termen = TerminologieHelper.HaalTermenOp(
        Sleutels.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
}

@if (termen.Count > 0)
{
    <details class="terminologie-card card border-0 shadow-sm mb-4">
        <summary class="terminologie-summary card-body">
            <div>
                <div class="fw-semibold">@Titel</div>
                <div class="small text-muted">@Beschrijving</div>
            </div>
        </summary>

        <div class="card-body pt-0">
            <dl class="terminologie-list mb-0">
                @foreach (var term in termen)
                {
                    <div class="terminologie-item">
                        <dt>@term.Label <span class="text-muted fw-normal">(@term.TechnischeTerm)</span></dt>
                        <dd class="text-muted mb-0">@term.Uitleg</dd>
                    </div>
                }
            </dl>
        </div>
    </details>
}

@code {
    [Parameter] public string Titel { get; set; } = "Wat betekent dit?";
    [Parameter] public string Beschrijving { get; set; } = "Korte uitleg bij de meet- en CNC-termen op deze pagina.";
    [Parameter, EditorRequired] public string Sleutels { get; set; } = "";
}
