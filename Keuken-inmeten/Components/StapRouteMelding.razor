@if (Gate is not null)
{
    <div class="alert alert-warning stap-route-melding" role="alert">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <div class="fw-semibold mb-1">Stap @Gate.HuidigeStap.Nummer: @Gate.HuidigeStap.Label is nog niet beschikbaar</div>
                <div class="small">@Gate.Reden</div>
            </div>
            <a href="@Gate.VereisteStap.Route" class="btn btn-primary btn-sm text-nowrap">@Gate.ActieLabel</a>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public StapRouteGate Gate { get; set; } = default!;
}
