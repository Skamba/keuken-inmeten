@using System.Globalization
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="wand-opstelling-container" style="text-align: center;">
    <svg @ref="svgRef"
         viewBox="0 0 @Fmt(SvgWidth) @Fmt(SvgHeight)"
         class="border rounded bg-body wand-opstelling-svg"
         style="max-height: @(SvgMaxHoogte ?? "65vh"); width: auto; max-width: @(BeperkTotContainerBreedte ? "100%" : "none"); display: block; cursor: default; outline: none; margin: 0 auto;"
         tabindex="0">

        @* Muur achtergrond *@
        <rect x="@Fmt(P)" y="@Fmt(P)" width="@Fmt(MuurBreedtePx)" height="@Fmt(MuurHoogtePx)"
              fill="#f5f0e8" stroke="#bbb" stroke-width="1.5" />

        @* Rasterlijnen horizontaal *@
        @foreach (var h in HoogteMarkeringen())
        {
            var y = VloerY - h * Schaal;
            <line x1="@Fmt(P)" y1="@Fmt(y)" x2="@Fmt(P + MuurBreedtePx)" y2="@Fmt(y)"
                  stroke="#e8e0d4" stroke-width="0.5" />
            <line x1="@Fmt(P - 5)" y1="@Fmt(y)" x2="@Fmt(P)" y2="@Fmt(y)"
                  stroke="#999" stroke-width="1" />
            @((MarkupString)$"<text x=\"{Fmt(P - 8)}\" y=\"{Fmt(y + 3)}\" font-size=\"9\" fill=\"#999\" text-anchor=\"end\">{h}</text>")
        }

        @* Plint *@
        @if (PlintHoogte > 0)
        {
            var plintPx = PlintHoogte * Schaal;
            <rect x="@Fmt(P)" y="@Fmt(VloerY - plintPx)" width="@Fmt(MuurBreedtePx)" height="@Fmt(plintPx)"
                  fill="#c8a87c" opacity="0.5" pointer-events="none" />
            @((MarkupString)$"<text x=\"{Fmt(P + 4)}\" y=\"{Fmt(VloerY - plintPx / 2 + 3)}\" font-size=\"8\" fill=\"#7a5c2e\" pointer-events=\"none\">plint {PlintHoogte:F0}mm</text>")
        }

        @* Vloerlijn *@
        <line x1="@Fmt(P)" y1="@Fmt(VloerY)" x2="@Fmt(P + MuurBreedtePx)" y2="@Fmt(VloerY)"
              stroke="#8b7355" stroke-width="2" />
        @((MarkupString)$"<text x=\"{Fmt(P - 8)}\" y=\"{Fmt(VloerY + 4)}\" font-size=\"9\" fill=\"#8b7355\" text-anchor=\"end\">0</text>")

        @* Breedte markeringen *@
        @foreach (var b in BreedteMarkeringen())
        {
            var x = P + b * Schaal;
            <line x1="@Fmt(x)" y1="@Fmt(VloerY)" x2="@Fmt(x)" y2="@Fmt(VloerY + 5)"
                  stroke="#999" stroke-width="1" />
            @((MarkupString)$"<text x=\"{Fmt(x)}\" y=\"{Fmt(VloerY + 16)}\" font-size=\"9\" fill=\"#999\" text-anchor=\"middle\">{b}</text>")
        }

        @* Muurafmetingen labels *@
        @((MarkupString)$"<text x=\"{Fmt(P + MuurBreedtePx / 2)}\" y=\"{Fmt(P - 8)}\" font-size=\"11\" fill=\"#666\" text-anchor=\"middle\" font-weight=\"bold\">{WandBreedte:F0} mm</text>")
        @((MarkupString)$"<text x=\"{Fmt(P + MuurBreedtePx + 12)}\" y=\"{Fmt(P + MuurHoogtePx / 2)}\" font-size=\"11\" fill=\"#666\" text-anchor=\"start\" transform=\"rotate(90, {Fmt(P + MuurBreedtePx + 12)}, {Fmt(P + MuurHoogtePx / 2)})\">{WandHoogte:F0} mm</text>")

        @* Kasten *@
        @foreach (var kast in Kasten)
        {
            var w = kast.Breedte * Schaal;
            var h = kast.Hoogte * Schaal;
            var x = P + kast.XPositie * Schaal;
            var y = VloerY - (kast.HoogteVanVloer + kast.Hoogte) * Schaal;
            var wdPx = kast.Wanddikte * Schaal;
            var isSelected = GeselecteerdeKastId == kast.Id || (GeselecteerdeKastIds?.Contains(kast.Id) ?? false);

            <g class="wand-kast-sleepbaar @(isSelected ? "geselecteerd" : "")"
               data-kast-id="@kast.Id"
               data-bot-y="@Fmt(y + h)"
               data-wd-px="@Fmt(wdPx)"
               data-schaal="@Fmt(Schaal)"
               style="cursor: @(LeesAlleen ? "pointer" : "grab");">

                <rect x="@Fmt(x)" y="@Fmt(y)" width="@Fmt(w)" height="@Fmt(h)"
                      fill="@KastKleur(kast.Type)" stroke="@(isSelected ? "#0d6efd" : "#8b7355")"
                      stroke-width="@(isSelected ? "2.5" : "1.5")" rx="2" opacity="0.85" />

                @* Wanddikte *@
                @if (wdPx > 1)
                {
                    <rect x="@Fmt(x + wdPx)" y="@Fmt(y + wdPx)" width="@Fmt(Math.Max(w - 2 * wdPx, 0))" height="@Fmt(Math.Max(h - 2 * wdPx, 0))"
                          fill="none" stroke="#c9b896" stroke-width="0.4" stroke-dasharray="1,1" pointer-events="none" />
                }

                @* Maatlijn breedte (horizontaal, boven in kast) *@
                @{
                    var dimW_y = y + wdPx + 9;
                    var dimW_x1 = x + wdPx + 1;
                    var dimW_x2 = x + w - wdPx - 1;
                }
                @if (w > 20 && h > 25)
                {
                    <line x1="@Fmt(dimW_x1)" y1="@Fmt(dimW_y)" x2="@Fmt(dimW_x2)" y2="@Fmt(dimW_y)"
                          stroke="#ccc" stroke-width="0.6" pointer-events="none" />
                    <line x1="@Fmt(dimW_x1)" y1="@Fmt(dimW_y - 2.5)" x2="@Fmt(dimW_x1)" y2="@Fmt(dimW_y + 2.5)"
                          stroke="#ccc" stroke-width="0.6" pointer-events="none" />
                    <line x1="@Fmt(dimW_x2)" y1="@Fmt(dimW_y - 2.5)" x2="@Fmt(dimW_x2)" y2="@Fmt(dimW_y + 2.5)"
                          stroke="#ccc" stroke-width="0.6" pointer-events="none" />
                    @((MarkupString)$"<text x=\"{Fmt((dimW_x1 + dimW_x2) / 2)}\" y=\"{Fmt(dimW_y - 2)}\" font-size=\"7\" fill=\"#aaa\" text-anchor=\"middle\" pointer-events=\"none\">{kast.Breedte:F0}mm</text>")
                }

                @* Maatlijn hoogte (verticaal, rechterkant van kast) *@
                @{
                    var dimH_x = x + w - wdPx - 5;
                    var dimH_y1 = y + wdPx + 1;
                    var dimH_y2 = y + h - wdPx - 1;
                    var dimH_my = (dimH_y1 + dimH_y2) / 2;
                }
                @if (w > 20 && h > 25)
                {
                    <line x1="@Fmt(dimH_x)" y1="@Fmt(dimH_y1)" x2="@Fmt(dimH_x)" y2="@Fmt(dimH_y2)"
                          stroke="#ccc" stroke-width="0.6" pointer-events="none" />
                    <line x1="@Fmt(dimH_x - 2.5)" y1="@Fmt(dimH_y1)" x2="@Fmt(dimH_x + 2.5)" y2="@Fmt(dimH_y1)"
                          stroke="#ccc" stroke-width="0.6" pointer-events="none" />
                    <line x1="@Fmt(dimH_x - 2.5)" y1="@Fmt(dimH_y2)" x2="@Fmt(dimH_x + 2.5)" y2="@Fmt(dimH_y2)"
                          stroke="#ccc" stroke-width="0.6" pointer-events="none" />
                    @((MarkupString)$"<text x=\"{Fmt(dimH_x - 2)}\" y=\"{Fmt(dimH_my)}\" font-size=\"7\" fill=\"#aaa\" text-anchor=\"middle\" pointer-events=\"none\" transform=\"rotate(-90, {Fmt(dimH_x - 2)}, {Fmt(dimH_my)})\">{kast.Hoogte:F0}mm</text>")
                }

                @* Gaatjesrij — beide kanten *@
                @if (kast.GaatjesAfstand > 0)
                {
                    var gaatYMm = kast.EersteGaatPositieVanafBoven;
                    while (gaatYMm < kast.Hoogte - 5)
                    {
                        var gy = y + gaatYMm * Schaal;
                        <circle cx="@Fmt(x + 5)" cy="@Fmt(gy)" r="1.2" fill="#999" pointer-events="none" />
                        <circle cx="@Fmt(x + w - 5)" cy="@Fmt(gy)" r="1.2" fill="#999" pointer-events="none" />
                        gaatYMm += kast.GaatjesAfstand;
                    }
                }

                @* Montageplaat posities *@
                @foreach (var pos in kast.MontagePlaatPosities)
                {
                    var cy = y + pos.AfstandVanBoven * Schaal;
                    var cx = pos.Zijde == ScharnierZijde.Links ? x + 6 : x + w - 6;
                    <circle cx="@Fmt(cx)" cy="@Fmt(cy)" r="3" fill="#e74c3c" stroke="#c0392b" stroke-width="0.6" />
                }

                @* Planken *@
                @foreach (var plank in kast.Planken)
                {
                    var plankDiktePx = Math.Max(wdPx, 2.0);
                    var plankCenterY = y + h - wdPx - plank.HoogteVanBodem * Schaal;
                    var plankRectY = plankCenterY - plankDiktePx / 2;
                    var isPlankSelected = _geselecteerdeePlankId == plank.Id;
                    <g class="wand-plank-sleepbaar"
                       data-kast-id="@kast.Id"
                       data-plank-id="@plank.Id"
                       style="cursor: ns-resize;">
                        <rect x="@Fmt(x + wdPx)" y="@Fmt(plankRectY)"
                              width="@Fmt(Math.Max(w - 2 * wdPx, 0))" height="@Fmt(plankDiktePx)"
                              fill="@(isPlankSelected ? "#a8d5ff" : "#c8a040")"
                              stroke="@(isPlankSelected ? "#0d6efd" : "#7a5e20")"
                              stroke-width="@(isPlankSelected ? "1.5" : "0.8")" />
                        @((MarkupString)$"<text class=\"plank-label\" x=\"{Fmt(x + wdPx + 3)}\" y=\"{Fmt(plankRectY - 2)}\" font-size=\"9\" fill=\"{(isPlankSelected ? "#0d6efd" : "#7a5e20")}\" font-weight=\"bold\" text-anchor=\"start\" pointer-events=\"none\">{plank.HoogteVanBodem:F0} mm</text>")
                    </g>
                }

                @* Panel overlays *@
                @if (Toewijzingen is not null)
                {
                    foreach (var t in Toewijzingen.Where(tt => tt.KastIds.Contains(kast.Id)))
                    {
                        var kleur = t.Type switch { PaneelType.Deur => "#0d6efd", PaneelType.LadeFront => "#e67e22", _ => "#6c757d" };
                        var typeStr = t.Type switch { PaneelType.Deur => "Deur", PaneelType.LadeFront => "Lade", _ => "Blind" };
                        var labelH = Math.Min(14.0, h * 0.28);
                        <rect x="@Fmt(x)" y="@Fmt(y)" width="@Fmt(w)" height="@Fmt(h)"
                              fill="none" stroke="@kleur" stroke-width="2.5" rx="2" pointer-events="none" />
                        <rect x="@Fmt(x)" y="@Fmt(y)" width="@Fmt(w)" height="@Fmt(labelH)"
                              fill="@kleur" opacity="0.85" rx="2" pointer-events="none" />
                        @((MarkupString)$"<text x=\"{Fmt(x + w / 2)}\" y=\"{Fmt(y + labelH * 0.75)}\" font-size=\"8\" fill=\"#fff\" text-anchor=\"middle\" font-weight=\"bold\" pointer-events=\"none\">{typeStr}</text>")
                    }
                }

                @* Label *@
                @((MarkupString)$"<text x=\"{Fmt(x + w / 2)}\" y=\"{Fmt(y + h / 2 + 4)}\" font-size=\"10\" fill=\"#333\" text-anchor=\"middle\" font-weight=\"bold\" pointer-events=\"none\">{kast.Naam}</text>")

                @* Hoogte van vloer stippellijn *@
                @if (kast.HoogteVanVloer > 0)
                {
                    <line x1="@Fmt(x + w / 2)" y1="@Fmt(y + h)" x2="@Fmt(x + w / 2)" y2="@Fmt(VloerY)"
                          stroke="#999" stroke-width="1" stroke-dasharray="3,3" pointer-events="none" />
                    @((MarkupString)$"<text x=\"{Fmt(x + w / 2 + 10)}\" y=\"{Fmt(y + h + (VloerY - y - h) / 2 + 3)}\" font-size=\"8\" fill=\"#999\" text-anchor=\"start\" pointer-events=\"none\">↕{kast.HoogteVanVloer:F0}</text>")
                }
            </g>
        }

        @* Apparaten *@
        @foreach (var apparaat in Apparaten)
        {
            const double apparaatStroke = 1.5;
            var aw = apparaat.Breedte * Schaal;
            var ah = apparaat.Hoogte * Schaal;
            var ax = P + apparaat.XPositie * Schaal;
            var ay = VloerY - (apparaat.HoogteVanVloer + apparaat.Hoogte) * Schaal;
            var labelBandHoogte = Math.Min(18.0, Math.Max(12.0, ah * 0.22));
            var naamY = ay + ah - Math.Min(8.0, Math.Max(5.0, ah * 0.12));
            var naamFontSize = Math.Min(11.0, Math.Max(7.0, Math.Min(aw * 0.16, ah * 0.18)));

            <g class="wand-kast-sleepbaar"
               data-kast-id="apparaat-@apparaat.Id"
               data-bot-y="@Fmt(ay + ah)"
               data-wd-px="0"
               data-schaal="@Fmt(Schaal)"
               style="cursor: @(LeesAlleen ? "default" : "grab");">

                <rect x="@Fmt(ax + apparaatStroke / 2)" y="@Fmt(ay + apparaatStroke / 2)"
                      width="@Fmt(Math.Max(0, aw - apparaatStroke))" height="@Fmt(Math.Max(0, ah - apparaatStroke))"
                      fill="@ApparaatKleur(apparaat.Type)" stroke="#555" stroke-width="@Fmt(apparaatStroke)" rx="4" opacity="0.9" />

                <ApparaatPictogram Type="apparaat.Type"
                                   X="ax"
                                   Y="ay"
                                   Width="aw"
                                   Height="ah"
                                   ReservedBottom="labelBandHoogte"
                                   StrokeColor="#4b5563" />

                @* Label *@
                @((MarkupString)$"<text x=\"{Fmt(ax + aw / 2)}\" y=\"{Fmt(naamY)}\" font-size=\"{Fmt(naamFontSize)}\" fill=\"#333\" text-anchor=\"middle\" font-weight=\"bold\" pointer-events=\"none\">{apparaat.Naam}</text>")

                @* Afmetingen *@
                @if (aw > 20 && ah > 25)
                {
                    @((MarkupString)$"<text x=\"{Fmt(ax + aw / 2)}\" y=\"{Fmt(ay - 3)}\" font-size=\"7\" fill=\"#888\" text-anchor=\"middle\" pointer-events=\"none\">{apparaat.Breedte:F0}×{apparaat.Hoogte:F0}mm</text>")
                }

                @* Hoogte van vloer stippellijn *@
                @if (apparaat.HoogteVanVloer > 0)
                {
                    <line x1="@Fmt(ax + aw / 2)" y1="@Fmt(ay + ah)" x2="@Fmt(ax + aw / 2)" y2="@Fmt(VloerY)"
                          stroke="#999" stroke-width="1" stroke-dasharray="3,3" pointer-events="none" />
                    @((MarkupString)$"<text x=\"{Fmt(ax + aw / 2 + 10)}\" y=\"{Fmt(ay + ah + (VloerY - ay - ah) / 2 + 3)}\" font-size=\"8\" fill=\"#999\" text-anchor=\"start\" pointer-events=\"none\">↕{apparaat.HoogteVanVloer:F0}</text>")
                }
            </g>
        }

        @* Instructie *@
        @if (Kasten.Count > 0)
        {
            @((MarkupString)$"<text x=\"{Fmt(P + MuurBreedtePx / 2)}\" y=\"{Fmt(SvgHeight - 4)}\" font-size=\"9\" fill=\"#aaa\" text-anchor=\"middle\" font-style=\"italic\">Sleep kasten/planken · dubbelklik in kast voor plank · dubbelklik op plank verwijdert · pijltjestoetsen werken ook</text>")
        }
    </svg>
</div>

@code {
    [Parameter, EditorRequired] public List<Kast> Kasten { get; set; } = [];
    [Parameter] public List<Apparaat> Apparaten { get; set; } = [];
    [Parameter] public double WandHoogte { get; set; } = 2600;
    [Parameter] public double WandBreedte { get; set; } = 3000;
    [Parameter] public double PlintHoogte { get; set; }
    [Parameter] public string? SvgMaxHoogte { get; set; }
    [Parameter] public bool BeperkTotContainerBreedte { get; set; } = true;
    [Parameter] public Guid? GeselecteerdeKastId { get; set; }
    [Parameter] public IReadOnlySet<Guid>? GeselecteerdeKastIds { get; set; }
    [Parameter] public bool LeesAlleen { get; set; }
    [Parameter] public EventCallback<Guid> OnKastGeselecteerd { get; set; }
    [Parameter] public EventCallback<Guid> OnKastKopieren { get; set; }
    [Parameter] public EventCallback OnKastPlakken { get; set; }
    [Parameter] public EventCallback<(Guid kastId, double xPositie, double hoogteVanVloer)> OnKastVerplaatst { get; set; }
    [Parameter] public EventCallback<Guid> OnKastGewijzigd { get; set; }
    [Parameter] public EventCallback<(Guid apparaatId, double xPositie, double hoogteVanVloer)> OnApparaatVerplaatst { get; set; }
    [Parameter] public IReadOnlyList<PaneelToewijzing>? Toewijzingen { get; set; }

    private ElementReference svgRef;
    private Guid? _geselecteerdeePlankId;
    private Guid? _geselecteerdeePlankKastId;
    private DotNetObjectReference<WandOpstelling>? dotNetRef;
    private IJSObjectReference? jsModule;

    private const double P = 50;
    private const double MaxVisueleHoogte = 500;

    private double Schaal => MaxVisueleHoogte / Math.Max(WandHoogte, 1);
    private double MuurHoogtePx => WandHoogte * Schaal;
    private double MuurBreedtePx => WandBreedte * Schaal;
    private double VloerY => P + MuurHoogtePx;
    private double SvgWidth => MuurBreedtePx + P * 2 + 30;
    private double SvgHeight => MuurHoogtePx + P + 30;

    private IEnumerable<int> HoogteMarkeringen()
    {
        var step = WandHoogte > 2000 ? 500 : 250;
        for (int h = step; h < WandHoogte; h += step)
            yield return h;
    }

    private IEnumerable<int> BreedteMarkeringen()
    {
        var step = WandBreedte > 2000 ? 500 : 250;
        for (int b = step; b < WandBreedte; b += step)
            yield return b;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/WandOpstelling.razor.js");
            await jsModule.InvokeVoidAsync("init", svgRef, dotNetRef, LeesAlleen);
        }
    }

    [JSInvokable]
    public async Task OnKastKlik(string kastIdStr)
    {
        if (Guid.TryParse(kastIdStr, out var kastId))
        {
            await OnKastGeselecteerd.InvokeAsync(kastId);
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnDrop(string kastIdStr, double svgX, double svgY)
    {
        if (LeesAlleen) return;

        // Handle apparaat drag
        if (kastIdStr.StartsWith("apparaat-"))
        {
            var apparaatIdStr = kastIdStr["apparaat-".Length..];
            if (!Guid.TryParse(apparaatIdStr, out var apparaatId)) return;

            var apparaat = Apparaten.Find(a => a.Id == apparaatId);
            if (apparaat is null) return;

            var appXMm = (svgX - P) / Schaal;
            var appTopFromFloorMm = (VloerY - svgY) / Schaal;
            var appHoogteVanVloer = appTopFromFloorMm - apparaat.Hoogte;

            appXMm = Math.Clamp(Math.Round(appXMm / 10) * 10, 0, Math.Max(0, WandBreedte - apparaat.Breedte));
            appHoogteVanVloer = Math.Clamp(Math.Round(appHoogteVanVloer / 10) * 10, 0, Math.Max(0, WandHoogte - apparaat.Hoogte));

            await OnApparaatVerplaatst.InvokeAsync((apparaatId, appXMm, appHoogteVanVloer));
            StateHasChanged();
            return;
        }

        if (!Guid.TryParse(kastIdStr, out var kastId)) return;

        var kast = Kasten.Find(k => k.Id == kastId);
        if (kast is null) return;

        // SVG coords → mm
        var xMm = (svgX - P) / Schaal;
        var topFromFloorMm = (VloerY - svgY) / Schaal;
        var hoogteVanVloer = topFromFloorMm - kast.Hoogte;

        // Snap to smart targets (threshold 20mm)
        const double snapThr = 20;
        var andereKasten = Kasten.Where(k => k.Id != kastId).ToList();

        xMm = SnapValue(xMm, XSnapTargets(kast, andereKasten), snapThr);
        hoogteVanVloer = SnapValue(hoogteVanVloer, YSnapTargets(kast, andereKasten), snapThr);

        // Clamp within wall
        xMm = Math.Clamp(xMm, 0, Math.Max(0, WandBreedte - kast.Breedte));
        hoogteVanVloer = Math.Clamp(hoogteVanVloer, 0, Math.Max(0, WandHoogte - kast.Hoogte));

        await OnKastVerplaatst.InvokeAsync((kastId, xMm, hoogteVanVloer));
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnPlankKlik(string kastIdStr, string plankIdStr)
    {
        if (LeesAlleen) return;
        if (Guid.TryParse(kastIdStr, out var kastId) && Guid.TryParse(plankIdStr, out var plankId))
        {
            _geselecteerdeePlankKastId = kastId;
            _geselecteerdeePlankId = plankId;
            await OnKastGeselecteerd.InvokeAsync(kastId);
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnPlankVerwijderen(string kastIdStr, string plankIdStr)
    {
        if (LeesAlleen) return;
        if (!Guid.TryParse(kastIdStr, out var kastId)) return;
        if (!Guid.TryParse(plankIdStr, out var plankId)) return;

        var kast = Kasten.Find(k => k.Id == kastId);
        var plank = kast?.Planken.Find(p => p.Id == plankId);
        if (kast is null || plank is null) return;

        kast.Planken.Remove(plank);

        if (_geselecteerdeePlankId == plankId)
        {
            _geselecteerdeePlankId = null;
            _geselecteerdeePlankKastId = null;
        }

        await OnKastGewijzigd.InvokeAsync(kastId);
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnPlankDrop(string kastIdStr, string plankIdStr, double svgCenterY)
    {
        if (LeesAlleen) return;
        if (!Guid.TryParse(kastIdStr, out var kastId)) return;
        if (!Guid.TryParse(plankIdStr, out var plankId)) return;

        var kast = Kasten.Find(k => k.Id == kastId);
        if (kast is null) return;
        var plank = kast.Planken.Find(p => p.Id == plankId);
        if (plank is null) return;

        var kastBotY = VloerY - kast.HoogteVanVloer * Schaal;
        var wdPx = kast.Wanddikte * Schaal;
        var hoogteVanBodem = (kastBotY - wdPx - svgCenterY) / Schaal;
        hoogteVanBodem = Math.Round(Math.Clamp(hoogteVanBodem, kast.Wanddikte, kast.Hoogte - kast.Wanddikte * 2), 1);

        plank.HoogteVanBodem = hoogteVanBodem;
        _geselecteerdeePlankKastId = kastId;
        _geselecteerdeePlankId = plankId;

        await OnKastGewijzigd.InvokeAsync(kastId);
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnPlankToevoegen(string kastIdStr, double svgY)
    {
        if (LeesAlleen) return;
        if (!Guid.TryParse(kastIdStr, out var kastId)) return;

        var kast = Kasten.Find(k => k.Id == kastId);
        if (kast is null) return;

        var kastBotY = VloerY - kast.HoogteVanVloer * Schaal;
        var wdPx = kast.Wanddikte * Schaal;
        var hoogteVanBodem = (kastBotY - wdPx - svgY) / Schaal;
        var gaatjesAfstand = kast.GaatjesAfstand > 0 ? kast.GaatjesAfstand : 32.0;
        hoogteVanBodem = Math.Round(hoogteVanBodem / gaatjesAfstand) * gaatjesAfstand;
        hoogteVanBodem = Math.Clamp(Math.Round(hoogteVanBodem, 1), kast.Wanddikte, kast.Hoogte - kast.Wanddikte * 2);

        var nieuwePlank = new Plank { HoogteVanBodem = hoogteVanBodem };
        kast.Planken.Add(nieuwePlank);
        _geselecteerdeePlankKastId = kastId;
        _geselecteerdeePlankId = nieuwePlank.Id;

        await OnKastGeselecteerd.InvokeAsync(kastId);
        await OnKastGewijzigd.InvokeAsync(kastId);
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnToets(string key, double stap)
    {
        if (LeesAlleen) return;
        if (_geselecteerdeePlankId.HasValue && _geselecteerdeePlankKastId.HasValue)
        {
            var kast = Kasten.Find(k => k.Id == _geselecteerdeePlankKastId.Value);
            var plank = kast?.Planken.Find(p => p.Id == _geselecteerdeePlankId.Value);
            if (plank != null && kast != null)
            {
                if (key == "ArrowUp")
                    plank.HoogteVanBodem = Math.Min(kast.Hoogte - kast.Wanddikte * 2, plank.HoogteVanBodem + stap);
                else if (key == "ArrowDown")
                    plank.HoogteVanBodem = Math.Max(kast.Wanddikte, plank.HoogteVanBodem - stap);
                else if (key == "Delete")
                {
                    kast.Planken.Remove(plank);
                    _geselecteerdeePlankId = null;
                    _geselecteerdeePlankKastId = null;
                }
                await OnKastGewijzigd.InvokeAsync(kast.Id);
            }
        }
        else if (GeselecteerdeKastId.HasValue)
        {
            var kast = Kasten.Find(k => k.Id == GeselecteerdeKastId.Value);
            if (kast != null)
            {
                if (key == "ArrowLeft")
                    kast.XPositie = Math.Max(0, kast.XPositie - stap);
                else if (key == "ArrowRight")
                    kast.XPositie = Math.Min(WandBreedte - kast.Breedte, kast.XPositie + stap);
                else if (key == "ArrowUp")
                    kast.HoogteVanVloer = Math.Min(WandHoogte - kast.Hoogte, kast.HoogteVanVloer + stap);
                else if (key == "ArrowDown")
                    kast.HoogteVanVloer = Math.Max(0, kast.HoogteVanVloer - stap);
                await OnKastVerplaatst.InvokeAsync((GeselecteerdeKastId.Value, kast.XPositie, kast.HoogteVanVloer));
            }
        }
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnKopierenToets(string kastIdStr)
    {
        if (Guid.TryParse(kastIdStr, out var kastId))
            await OnKastKopieren.InvokeAsync(kastId);
    }

    [JSInvokable]
    public async Task OnPlakkenToets()
    {
        await OnKastPlakken.InvokeAsync();
    }

    private IEnumerable<double> XSnapTargets(Kast kast, List<Kast> andereKasten)
    {
        yield return 0;                           // wall left
        yield return WandBreedte - kast.Breedte;  // wall right
        foreach (var a in andereKasten)
        {
            yield return a.XPositie;                  // snap left edge to other's left
            yield return a.XPositie + a.Breedte;      // snap left edge to other's right (adjacent)
            yield return a.XPositie - kast.Breedte;   // snap right edge to other's left
        }
    }

    private IEnumerable<double> YSnapTargets(Kast kast, List<Kast> andereKasten)
    {
        yield return 0;            // on the floor
        yield return PlintHoogte;  // on top of the plinth
        foreach (var a in andereKasten)
        {
            yield return a.HoogteVanVloer;                // align bottom edges
            yield return a.HoogteVanVloer + a.Hoogte;     // sit on top of other kast
            yield return a.HoogteVanVloer - kast.Hoogte;  // sit under other kast
        }
    }

    private static double SnapValue(double value, IEnumerable<double> targets, double threshold)
    {
        var best = targets.MinBy(t => Math.Abs(t - value));
        return Math.Abs(best - value) <= threshold ? Math.Round(best) : Math.Round(value / 10) * 10;
    }

