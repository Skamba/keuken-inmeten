@using System.Globalization

<svg width="@Fmt(SvgWidth)" height="@Fmt(SvgHeight)" class="border rounded bg-body">
    <rect x="@Fmt(P)" y="@Fmt(P)" width="@Fmt(W)" height="@Fmt(H)"
          fill="#dce6f0" stroke="#5b7ea1" stroke-width="2" />

    @{
        var labelYs = new double[Resultaat.Boorgaten.Count];
        double prevLabelBottom = double.MinValue;
        for (int j = 0; j < Resultaat.Boorgaten.Count; j++)
        {
            double idealY = P + Resultaat.Boorgaten[j].Y * Schaal;
            double nudgedY = Math.Max(idealY, prevLabelBottom + 14.0);
            labelYs[j] = nudgedY;
            prevLabelBottom = nudgedY + 5.0;
        }
    }
    @for (int i = 0; i < Resultaat.Boorgaten.Count; i++)
    {
        var gat = Resultaat.Boorgaten[i];
        var cx = Resultaat.ScharnierZijde == ScharnierZijde.Links
            ? P + gat.X * Schaal
            : P + W - gat.X * Schaal;
        var cy = P + gat.Y * Schaal;
        var r = Math.Max((gat.Diameter / 2) * Schaal, 4);
        var labelX = Resultaat.ScharnierZijde == ScharnierZijde.Links ? cx + r + 8 : cx - r - 8;
        var anchor = Resultaat.ScharnierZijde == ScharnierZijde.Links ? "start" : "end";
        var labelY = labelYs[i];
        var nudged = (labelY - cy) > 0.5;

        <circle cx="@Fmt(cx)" cy="@Fmt(cy)" r="@Fmt(r)"
                fill="#2c3e50" stroke="#1a252f" stroke-width="1" opacity="0.7" />
        @if (nudged)
        {
            <line x1="@Fmt(labelX)" y1="@Fmt(cy + r + 2)"
                  x2="@Fmt(labelX)" y2="@Fmt(labelY - 2)"
                  stroke="#bbb" stroke-width="0.5" stroke-dasharray="2,2" />
        }
        @((MarkupString)$"<text x=\"{Fmt(labelX)}\" y=\"{Fmt(labelY + 4)}\" font-size=\"9\" fill=\"#555\" text-anchor=\"{anchor}\">{gat.Y} mm</text>")
    }

    @((MarkupString)$"<text x=\"{Fmt(P + W / 2)}\" y=\"{Fmt(P - 8)}\" font-size=\"11\" fill=\"#333\" text-anchor=\"middle\">{Resultaat.Breedte} mm</text>")
    @((MarkupString)$"<text x=\"{Fmt(P - 8)}\" y=\"{Fmt(P + H / 2)}\" font-size=\"11\" fill=\"#333\" text-anchor=\"middle\" transform=\"rotate(-90, {Fmt(P - 8)}, {Fmt(P + H / 2)})\">{Resultaat.Hoogte} mm</text>")
</svg>

@code {
    [Parameter, EditorRequired] public PaneelResultaat Resultaat { get; set; } = default!;
    [Parameter] public double MaxHoogte { get; set; } = 200;

    private const double P = 40;
    private double Schaal => MaxHoogte / Math.Max(Resultaat.Hoogte, 1);
    private double W => Resultaat.Breedte * Schaal;
    private double H => Resultaat.Hoogte * Schaal;
    private double SvgWidth => W + P * 2;
    private double SvgHeight => H + P * 2;

    private static string Fmt(double v) => VisualisatieHelper.Fmt(v);
}
