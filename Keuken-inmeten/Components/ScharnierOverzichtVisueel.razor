@using Keuken_inmeten.Services.Interop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="scharnier-overzicht-wrap">
    <button type="button"
            class="scharnier-overzicht-trigger"
            @onclick="OpenViewer"
            aria-label="Open volledige weergave van gecombineerd scharnieroverzicht">
        <span class="scharnier-overzicht-trigger-hint">Open voor fullscreen, zoom en pan</span>
        <ScharnierOverzichtSvg Resultaat="@Resultaat"
                              Toewijzing="@Toewijzing"
                              Kasten="@Kasten"
                              MaxHoogte="@MaxHoogte"
                              CssClass="scharnier-overzicht-svg scharnier-overzicht-svg--preview" />
    </button>
</div>

<div class="d-flex flex-wrap gap-3 mt-2 scharnier-overzicht-legenda">
    <span>
        <svg width="12" height="12" style="display:inline-block;vertical-align:middle;">
            <circle cx="6" cy="6" r="5" fill="#e74c3c" />
        </svg>
        Gebruikt gat
    </span>
    <span>
        <svg width="12" height="12" style="display:inline-block;vertical-align:middle;">
            <circle cx="6" cy="6" r="3" fill="#8899bb" />
        </svg>
        Overig gat
    </span>
    <span>
        <svg width="24" height="12" style="display:inline-block;vertical-align:middle;">
            <line x1="0" y1="6" x2="24" y2="6" stroke="#e67e22" stroke-width="2" stroke-dasharray="4,3" />
        </svg>
        Hartlijn scharnierplaat / scharnierpot
    </span>
    <span>
        <svg width="6" height="12" style="display:inline-block;vertical-align:middle;">
            <line x1="3" y1="0" x2="3" y2="12" stroke="#c0392b" stroke-width="2.5" />
        </svg>
        Scharnierrand
    </span>
</div>

@if (_viewerOpen)
{
    <div class="scharnier-viewer-backdrop" @onclick="CloseViewer">
        <div class="scharnier-viewer-shell"
             role="dialog"
             aria-modal="true"
             aria-label="Gecombineerd scharnieroverzicht"
             tabindex="0"
             @ref="viewerShell"
             @onclick:stopPropagation="true"
             @onkeydown="HandleViewerKeyDown">
            <div class="scharnier-viewer-toolbar">
                <div>
                    <div class="scharnier-viewer-title">Gecombineerd scharnieroverzicht</div>
                    <div class="scharnier-viewer-subtitle">Sleep om te pannen en gebruik het muiswiel of de knoppen om te zoomen.</div>
                </div>
                <div class="scharnier-viewer-actions">
                    <button type="button" class="btn btn-light btn-sm" @onclick="ZoomOutViewer" aria-label="Zoom uit" disabled="@(!_viewerInitialized)">−</button>
                    <button type="button" class="btn btn-light btn-sm" @onclick="ResetViewer" disabled="@(!_viewerInitialized)">100%</button>
                    <button type="button" class="btn btn-light btn-sm" @onclick="ZoomInViewer" aria-label="Zoom in" disabled="@(!_viewerInitialized)">+</button>
                    <button type="button" class="btn btn-outline-light btn-sm" @onclick="CloseViewer">Sluiten</button>
                </div>
            </div>

            <div class="scharnier-viewer-stage" @ref="viewerStage">
                <div class="scharnier-viewer-canvas" @ref="viewerCanvas">
                    <ScharnierOverzichtSvg Resultaat="@Resultaat"
                                          Toewijzing="@Toewijzing"
                                          Kasten="@Kasten"
                                          MaxHoogte="@ViewerHoogte"
                                          CssClass="scharnier-overzicht-svg scharnier-overzicht-svg--viewer" />
                </div>
            </div>

            <div class="scharnier-viewer-footer">
                <div class="d-flex flex-wrap gap-3 scharnier-overzicht-legenda">
                    <span>
                        <svg width="12" height="12" style="display:inline-block;vertical-align:middle;">
                            <circle cx="6" cy="6" r="5" fill="#e74c3c" />
                        </svg>
                        Gebruikt gat
                    </span>
                    <span>
                        <svg width="12" height="12" style="display:inline-block;vertical-align:middle;">
                            <circle cx="6" cy="6" r="3" fill="#8899bb" />
                        </svg>
                        Overig gat
                    </span>
                    <span>
                        <svg width="24" height="12" style="display:inline-block;vertical-align:middle;">
                            <line x1="0" y1="6" x2="24" y2="6" stroke="#e67e22" stroke-width="2" stroke-dasharray="4,3" />
                        </svg>
                        Hartlijn scharnierplaat / scharnierpot
                    </span>
                    <span>
                        <svg width="6" height="12" style="display:inline-block;vertical-align:middle;">
                            <line x1="3" y1="0" x2="3" y2="12" stroke="#c0392b" stroke-width="2.5" />
                        </svg>
                        Scharnierrand
                    </span>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public PaneelResultaat Resultaat { get; set; } = default!;
    [Parameter, EditorRequired] public PaneelToewijzing Toewijzing { get; set; } = default!;
    [Parameter, EditorRequired] public IReadOnlyList<Kast> Kasten { get; set; } = [];
    [Parameter] public double MaxHoogte { get; set; } = 360;

    private ElementReference viewerStage;
    private ElementReference viewerCanvas;
    private ElementReference viewerShell;
    private ScharnierOverzichtViewerJsInterop? viewerInterop;
    private bool _viewerOpen;
    private bool _viewerInitialized;
    private double ViewerHoogte => Math.Max(720, MaxHoogte * 2.5);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_viewerOpen || _viewerInitialized)
            return;

        viewerInterop ??= new ScharnierOverzichtViewerJsInterop(JS);
        await viewerInterop.InitAsync(viewerStage, viewerCanvas, viewerShell);
        _viewerInitialized = true;
        await InvokeAsync(StateHasChanged);
    }

    private void OpenViewer()
    {
        _viewerInitialized = false;
        _viewerOpen = true;
    }

    private async Task CloseViewer()
    {
        if (viewerInterop is not null && _viewerInitialized)
        {
            await viewerInterop.DisposeViewerAsync(viewerStage);
            _viewerInitialized = false;
        }

        _viewerOpen = false;
    }

    private async Task ZoomInViewer()
    {
        if (viewerInterop is not null && _viewerInitialized)
            await viewerInterop.ZoomInAsync(viewerStage);
    }

    private async Task ZoomOutViewer()
    {
        if (viewerInterop is not null && _viewerInitialized)
            await viewerInterop.ZoomOutAsync(viewerStage);
    }

    private async Task ResetViewer()
    {
        if (viewerInterop is not null && _viewerInitialized)
            await viewerInterop.ResetAsync(viewerStage);
    }

    private async Task HandleViewerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            await CloseViewer();
    }

    public async ValueTask DisposeAsync()
    {
        if (viewerInterop is not null)
        {
            if (_viewerInitialized)
                await viewerInterop.DisposeViewerAsync(viewerStage);

            await viewerInterop.DisposeAsync();
        }
    }
}
